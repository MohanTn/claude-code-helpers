=== TaxCalculator.cs ===
using Dapper;
using FinanceAnalyser.Core.Tax;
using FinanceAnalyser.Data;
using Microsoft.Data.Sqlite;

namespace FinanceAnalyser.Import;

/// <summary>
/// Tax calculation orchestrator: combines both filers' gross income,
/// Werbungskosten (employee) or business expenses (freelancer),
/// Vorsorgeaufwendungen (payslip contributions + Insurance-category
/// fallback), and property rental results into a combined zvE, then
/// applies Splitting (§§26/26b EStG) + Solidaritätszuschlag.
///
/// Tax class only affects monthly withholding display, never this
/// calculation. No Kirchensteuer is computed (household has no
/// church-tax members).
///
/// Ported 1:1 from src/tax/calculation.ts.
/// </summary>
public static class TaxCalculator
{
    /// <summary>
    /// Full tax calculation for the household in `year`, combining both
    /// filers' incomes, deductions, property results, and social
    /// contributions.
    /// </summary>
    public static TaxCalculationResult CalculateTax(SqliteConnection connection, int year)
    {
        // ── 1. Fetch tax filers ──────────────────────────────────────────
        var employee = Db.GetFilerByRole(connection, "employee");
        var freelancer = Db.GetFilerByRole(connection, "freelancer");

        // ── 2. Fetch payslip data for the employee ───────────────────────
        var payslips = employee is not null
            ? Db.GetPayslips(connection, employee.Id, year)
            : Array.Empty<Data.Models.PayslipRecord>();

        var nonCorrected = payslips.Where(p => p.IsCorrection == 0).ToList();

        // Gross income from payslips (sum of all non-correction months' gross).
        var grossIncome = nonCorrected.Sum(p => p.GrossCents);

        // Social contributions from payslips — total and per-component breakdown.
        // NOTE: on Infoniqa payslips, health_cents/care_cents are
        // "AG-Zuschuss private Kranken-/Pflegevers." — the EMPLOYER's tax-free
        // subsidy toward private insurance (§3 Nr. 62 EStG), not an employee
        // contribution. They must not be added to payslipVorsorge; instead they
        // reduce the deductible premium below (§3c EStG bars deducting the
        // subsidized portion).
        var payslipPension = nonCorrected.Sum(p => p.PensionCents);
        var payslipUnemployment = nonCorrected.Sum(p => p.UnemploymentCents);
        var employerHealthSubsidy = nonCorrected.Sum(p => p.HealthCents);
        var employerCareSubsidy = nonCorrected.Sum(p => p.CareCents);
        var employerHealthCareSubsidy = employerHealthSubsidy + employerCareSubsidy;
        var payslipVorsorge = payslipPension + payslipUnemployment;

        // Already withheld income tax (sum of non-correction months' income_tax_cents).
        var alreadyWithheld = nonCorrected.Sum(p => p.IncomeTaxCents);

        // ── 3. Werbungskosten: itemized expenses vs the flat Pauschale, whichever is higher ─
        var flatPauschale = TaxConstants.WerbungskostenPauschaleByYear.TryGetValue(year, out var wkPauschale)
            ? wkPauschale
            : 123_000; // default to €1,230

        var itemizedWk = employee is not null ? Db.GetWerbungskostenItemized(connection, employee.Id, year) : null;

        long entfernungspauschaleCents = 0;
        long tagespauschaleCents = 0;
        long workEquipmentCents = 0;
        long homeOfficeRoomCents = 0;
        if (itemizedWk is not null)
        {
            if (TaxConstants.EntfernungspauschaleRatesByYear.TryGetValue(year, out var kmRate)
                && itemizedWk.CommuteKm > 0 && itemizedWk.CommuteDays > 0)
            {
                var firstTierKm = Math.Min(itemizedWk.CommuteKm, kmRate.FirstTierKm);
                var beyondTierKm = Math.Max(0, itemizedWk.CommuteKm - kmRate.FirstTierKm);
                var computedCents = itemizedWk.CommuteDays *
                    (firstTierKm * kmRate.FirstTierCentsPerKm + beyondTierKm * kmRate.BeyondTierCentsPerKm);
                // §9 Abs.1 Satz 3 Nr.4 Satz 4 EStG: take the actual ÖPNV cost
                // instead, if it's higher than the computed Entfernungspauschale.
                entfernungspauschaleCents = Math.Max(computedCents, itemizedWk.PublicTransportAnnualCents);
            }

            if (TaxConstants.TagespauschaleByYear.TryGetValue(year, out var dayRate) && itemizedWk.HomeOfficeDays > 0)
            {
                var cappedDays = Math.Min(itemizedWk.HomeOfficeDays, dayRate.MaxDays);
                tagespauschaleCents = cappedDays * dayRate.CentsPerDay;
            }

            workEquipmentCents = itemizedWk.WorkEquipmentCents;
            homeOfficeRoomCents = itemizedWk.HomeOfficeRoomCents;
        }

        var itemizedWkTotalCents = entfernungspauschaleCents + tagespauschaleCents + workEquipmentCents + homeOfficeRoomCents;
        var usedItemizedWk = itemizedWkTotalCents > flatPauschale;
        var werbungskosten = usedItemizedWk ? itemizedWkTotalCents : flatPauschale;

        // ── 4. Freelance income (if any) ──────────────────────────────────
        long freelanceRevenue = 0;
        long freelanceExpenses = 0;
        long freelancerVorsorge = 0;
        long freelancerHealthVorsorge = 0;
        long freelancerPensionVorsorge = 0;
        long freelancerAdvanceTax = 0;

        if (freelancer is not null)
        {
            var fi = Db.GetFreelanceIncome(connection, freelancer.Id, year);
            if (fi is not null)
            {
                freelanceRevenue = fi.RevenueCents;
                freelanceExpenses = fi.BusinessExpensesCents;
                freelancerHealthVorsorge = fi.HealthInsuranceCents;
                freelancerPensionVorsorge = fi.PensionInsuranceCents;
                freelancerVorsorge = freelancerHealthVorsorge + freelancerPensionVorsorge;
                freelancerAdvanceTax = fi.AdvanceTaxPaidCents;
            }
        }

        // Add freelancer's advance tax payments (Vorauszahlungen) to already withheld.
        alreadyWithheld += freelancerAdvanceTax;

        // ── 5. Vorsorgeaufwendungen ───────────────────────────────────────
        // Sum: payslip contributions + freelancer health/pension (if entered)
        // or Insurance-category fallback when freelancer data is missing.
        // Payslip contributions always count (they are mandatory social security).
        // Insurance transactions only serve as fallback for missing freelancer data
        // to avoid double-counting if the freelancer entered both.
        // The insurer's own annual certificate (Beitragsbescheinigung) reports
        // exactly the Basisabsicherung-equivalent premium — the figure that's
        // actually deductible under §10 Abs. 1 Nr. 3 EStG — so it takes
        // precedence whenever one has been uploaded for this filer/year.
        var healthCertificate = employee is not null
            ? Db.GetHealthInsuranceCertificate(connection, employee.Id, year)
            : null;

        long insuranceTotal = 0;
        if (healthCertificate is not null)
        {
            insuranceTotal = healthCertificate.HealthCents + healthCertificate.CareCents;
        }
        else if (freelancerVorsorge == 0)
        {
            // 'Insurance' (per the PRD's canonical category taxonomy) also covers
            // Bayern-Versicherung (life) and Neodigital Versicherung (general),
            // neither of which is deductible Krankenversicherung — only HALLESCHE
            // (private health insurance) counts here. Sum gross premium debits only;
            // the monthly Bonuszahlung is Hallesche's healthy-behavior bonus, not a
            // Beitragsrückerstattung, so per BMF guidance / BFH X R 16/19 it does
            // not reduce the deductible amount and must be excluded, not netted.
            // This is only a fallback for filers without an uploaded certificate —
            // it can't distinguish non-deductible riders bundled into the same debit.
            insuranceTotal = connection.ExecuteScalar<long?>(
                """
                SELECT COALESCE(SUM(CASE WHEN amount_cents < 0 THEN -amount_cents ELSE 0 END), 0) as total
                FROM transactions
                WHERE category = 'Insurance'
                  AND description LIKE '%HALLESCHE%'
                  AND date >= @StartDate AND date < @EndDate
                """,
                new { StartDate = $"{year}-01-01", EndDate = $"{year + 1}-01-01" }) ?? 0;
        }

        // Beitragsrückerstattung: HALLESCHE's "Bonuszahlung" credits are a
        // healthy-behavior bonus on a *private* policy, which is a distinct
        // question from the BFH X R 16/19 ruling (that case concerned the
        // §65a SGB V statutory-GKV bonus). This household's own ELSTER
        // assessment nets these credits against the deductible premium as a
        // genuine Beitragsrückerstattung, so this does the same — independent
        // of whether the certificate or the bank-transaction fallback above
        // supplied the gross premium.
        var beitragsrueckerstattungCents = connection.ExecuteScalar<long?>(
            """
            SELECT COALESCE(SUM(amount_cents), 0) as total
            FROM transactions
            WHERE category = 'Insurance'
              AND description LIKE '%HALLESCHE%'
              AND description LIKE '%Bonuszahlung%'
              AND amount_cents > 0
              AND date >= @StartDate AND date < @EndDate
            """,
            new { StartDate = $"{year}-01-01", EndDate = $"{year + 1}-01-01" }) ?? 0;

        // Net the Beitragsrückerstattung and the employer's tax-free
        // Arbeitgeberzuschuss against the private Kranken-/Pflegeversicherung
        // premium. The single HALLESCHE bank debit bundles both Kranken and
        // Pflege, so both subsidy components are netted against it together
        // rather than tracked as a separate "care" deduction.
        var netHealthCareCents = Math.Max(0, insuranceTotal - beitragsrueckerstattungCents - employerHealthSubsidy - employerCareSubsidy);

        // Altersvorsorgeaufwendungen (pension): 100% deductible, no cap.
        var altersvorsorge = payslipPension + freelancerPensionVorsorge;

        // Sonstige Vorsorgeaufwendungen (unemployment + health/care insurance):
        // capped per §10 Abs. 4 EStG at €1,900/person (employee, subsidized
        // health insurance) or €2,800/person (self-employed, no subsidy) —
        // but never below the actual basic health + long-term-care premiums
        // (Mindestbetrag, §10 Abs. 4 Satz 4), which in practice dominates the
        // cap once private health insurance is involved.
        var sonstigeVorsorgeActual = payslipUnemployment + netHealthCareCents + freelancerHealthVorsorge;
        var basicHealthCareFloor = netHealthCareCents + freelancerHealthVorsorge;
        // §10 Abs.4 EStG cap: €1,900/person for anyone entitled to subsidized,
        // statutory-equivalent coverage (the common case — e.g. a spouse
        // co-insured under the same employer-subsidized family policy), or
        // €2,800/person otherwise. This is a property of each filer's own
        // insurance situation (tracked on tax_filers), not of whether they
        // happen to have freelance revenue.
        var sonstigeVorsorgeCap = new[] { employee, freelancer }
            .Where(f => f is not null)
            .Sum(f => f!.HasSubsidizedHealthInsurance
                ? TaxConstants.SonstigeVorsorgeCapEmployeeCents
                : TaxConstants.SonstigeVorsorgeCapFreelancerCents);
        var sonstigeVorsorgeDeductible = Math.Max(Math.Min(sonstigeVorsorgeActual, sonstigeVorsorgeCap), basicHealthCareFloor);

        var vorsorgeaufwendungen = altersvorsorge + sonstigeVorsorgeDeductible;

        // ── 6. Property rental result ─────────────────────────────────────
        var rentalResult = PropertyAnnualResultCalculator.CalculatePropertiesAnnualResult(connection, year);

        // ── 7a. Filing settings — needed before zvE since the Sonderausgaben-
        // Pauschbetrag (§10c EStG) depends on filing status.
        // Splitting (§§26/26b EStG) only applies when tax_filing_settings
        // explicitly says 'joint' (married couples filing together). A single
        // person with both employee + freelance income still uses Grundtabelle.
        var filingSettings = Db.GetTaxFilingSettings(connection, year);
        var filingStatus = filingSettings?.FilingStatus == "joint" ? FilingStatus.Joint : FilingStatus.Single;
        var sonderausgabenPauschbetrag = filingStatus == FilingStatus.Joint
            ? TaxConstants.SonderausgabenPauschbetragJointCents
            : TaxConstants.SonderausgabenPauschbetragSingleCents;

        // ── 7b. Compute combined taxable income (zvE) ──────────────────────
        // Employee: gross income - Werbungskosten (never below 0)
        var employeeNet = Math.Max(0, grossIncome - werbungskosten);
        // Freelancer: revenue - business expenses (never below 0)
        var freelanceNet = Math.Max(0, freelanceRevenue - freelanceExpenses);

        // Gesamtbetrag der Einkünfte: sum of each income type, each already net
        // of its own costs (Werbungskosten / business expenses / rental costs) —
        // the subtotal ELSTER prints before Sonderausgaben are applied.
        var gesamtbetragDerEinkuenfte = employeeNet + freelanceNet + rentalResult.NetRentalResultCents;

        var einkommen = gesamtbetragDerEinkuenfte - vorsorgeaufwendungen - sonderausgabenPauschbetrag;

        // Härteausgleich (§46 Abs.3/5 EStG): sliding relief on minor
        // "Nebeneinkünfte" (income not subject to wage-tax withholding — here
        // freelance profit + rental result) below €820.
        var nebeneinkuenfte = Math.Max(0, freelanceNet + rentalResult.NetRentalResultCents);
        var haerteausgleich = IncomeTax.Haerteausgleich(nebeneinkuenfte);

        var taxableIncome = einkommen - haerteausgleich;

        // Floor taxable income to 0 (no negative zvE).
        var zvE = Math.Max(0, taxableIncome);

        var incomeTax = filingStatus == FilingStatus.Joint
            ? IncomeTax.CalculateSplittingTax(zvE, 0, year)
            : IncomeTax.CalculateIncomeTax(zvE, year);

        // ── 9. Solidarity Surcharge ───────────────────────────────────────
        var soli = IncomeTax.CalculateSolidaritySurcharge(incomeTax, year, filingStatus);

        // ── 10. Determine bracket zone ────────────────────────────────────
        // Under Splitting, the relevant bracket is determined by zvE/2,
        // not the combined zvE. Under Grundtabelle, use the full zvE.
        TaxConstants.TaxBracketsByYear.TryGetValue(year, out var bracket);
        var relevantZvECents = filingStatus == FilingStatus.Joint ? FloorDivBy2(zvE) : zvE;
        var zone = 0;
        if (bracket is not null)
        {
            var x = FloorDiv100(relevantZvECents);
            if (x <= FloorDiv100(bracket.GrundfreibetragCents)) zone = 1;
            else if (x <= FloorDiv100(bracket.Zone2UpperCents)) zone = 2;
            else if (x <= FloorDiv100(bracket.Zone3UpperCents)) zone = 3;
            else if (x < FloorDiv100(bracket.Zone5LowerCents)) zone = 4;
            else zone = 5;
        }

        // Grenzsteuersatz (marginal rate) at the rate-determining income.
        var marginalRate = IncomeTax.MarginalTaxRate(relevantZvECents, year);

        // ── 11. Final numbers ─────────────────────────────────────────────
        var totalTax = incomeTax + soli;
        var refundOrOwed = alreadyWithheld - totalTax;
        // Social Contributions: payroll-deducted pension + unemployment, plus
        // the employee's actual out-of-pocket medical insurance cost — the
        // private Kranken-/Pflegeversicherung premium net of the employer's
        // tax-free subsidy (netHealthCareCents, §3 Nr. 62 EStG already netted
        // out above). This is the real cash the household pays for statutory-
        // equivalent health/care cover, even though it leaves via a bank debit
        // rather than payroll withholding.
        var socialContributions = payslipVorsorge + netHealthCareCents;

        // Net in hand: a plain waterfall of numbers that are all already shown
        // elsewhere on this page — no hidden figure (e.g. a payslip's "payout",
        // which silently folds in the employer's tax-free health/care subsidy)
        // feeds into it.
        // Gross Income - Tax Already Withheld - Social Contributions (pension +
        // unemployment + net medical insurance) - Freelance Business Expenses
        // + Refund (or - Amount Owed)
        var netInHand =
            grossIncome + freelanceRevenue - alreadyWithheld - socialContributions - freelanceExpenses + refundOrOwed;

        // Durchschnittssteuersatz (average rate): assessed tax over taxable income.
        var averageTaxRate = zvE > 0 ? (double)incomeTax / zvE : 0;

        return new TaxCalculationResult(
            GrossIncomeCents: grossIncome + freelanceRevenue,
            WerbungskostenCents: werbungskosten,
            FreelanceRevenueCents: freelanceRevenue,
            FreelanceExpensesCents: freelanceExpenses,
            RentalResultCents: rentalResult.NetRentalResultCents,
            SonderausgabenPauschbetragCents: sonderausgabenPauschbetrag,
            VorsorgeaufwendungenCents: vorsorgeaufwendungen,
            // Health always shows the full basic-health/care floor (it's never
            // reduced); Unemployment shows only whatever deductible room is
            // left over above that floor — zero once the floor alone already
            // meets or exceeds the deductible sonstige total, since at that
            // point unemployment contributes nothing extra (see Vorsorgeaufwendungen
            // cap/floor comment above). This keeps the breakdown summing exactly
            // to VorsorgeaufwendungenCents instead of showing a misleading raw
            // contribution that isn't actually deductible.
            VorsorgeBreakdown: new VorsorgeBreakdown(
                PensionCents: payslipPension + freelancerPensionVorsorge,
                UnemploymentCents: Math.Max(0, sonstigeVorsorgeDeductible - basicHealthCareFloor),
                HealthCents: basicHealthCareFloor,
                CareCents: 0,
                BeitragsrueckerstattungCents: beitragsrueckerstattungCents),
            WerbungskostenBreakdown: new WerbungskostenBreakdown(
                EntfernungspauschaleCents: entfernungspauschaleCents,
                TagespauschaleCents: tagespauschaleCents,
                WorkEquipmentCents: workEquipmentCents,
                HomeOfficeRoomCents: homeOfficeRoomCents,
                FlatPauschaleCents: flatPauschale,
                UsedItemized: usedItemizedWk),
            GesamtbetragDerEinkuenfteCents: gesamtbetragDerEinkuenfte,
            HaerteausgleichCents: haerteausgleich,
            RentalBreakdown: new RentalBreakdown(
                RentalIncomeCents: rentalResult.TotalRentalIncomeCents,
                MortgageInterestCents: rentalResult.TotalMortgageInterestCents,
                AfaCents: rentalResult.TotalAfaCents,
                MaintenanceCents: rentalResult.TotalMaintenanceCents,
                PropertyTaxCents: rentalResult.TotalPropertyTaxCents),
            TaxableIncomeCents: zvE,
            IncomeTaxCents: incomeTax,
            SolidaritySurchargeCents: soli,
            SocialContributionsCents: socialContributions,
            AlreadyWithheldCents: alreadyWithheld,
            RefundOrOwedCents: refundOrOwed,
            NetInHandCents: netInHand,
            EmployerHealthCareSubsidyCents: employerHealthCareSubsidy,
            BracketZone: zone,
            SplittingApplied: filingStatus == FilingStatus.Joint,
            RateDeterminingIncomeCents: relevantZvECents,
            AverageTaxRate: averageTaxRate,
            MarginalTaxRate: marginalRate,
            InsuranceTransactionsTotalCents: insuranceTotal,
            HealthInsuranceCertificateCents: healthCertificate is not null ? insuranceTotal : null,
            MonthsImported: nonCorrected.Select(p => p.Month).Distinct().OrderBy(m => m).ToList(),
            Payslips: payslips.Select(p => new TaxCalculationPayslip(
                Id: p.Id,
                Month: p.Month,
                GrossCents: p.GrossCents,
                IncomeTaxCents: p.IncomeTaxCents,
                SolidaritySurchargeCents: p.SolidaritySurchargeCents,
                PensionCents: p.PensionCents,
                UnemploymentCents: p.UnemploymentCents,
                HealthCents: p.HealthCents,
                CareCents: p.CareCents,
                NetCents: p.NetCents,
                PayoutCents: p.PayoutCents,
                IsCorrection: p.IsCorrection,
                SourceFormat: p.SourceFormat)).ToList());
    }

    /// <summary>
    /// Floors a cents value down to whole euros (matches JS
    /// <c>Math.floor(cents / 100)</c>).
    /// </summary>
    private static long FloorDiv100(long cents) => (long)Math.Floor(cents / 100.0);

    /// <summary>
    /// Floors a value divided by 2 (matches JS <c>Math.floor(zvE / 2)</c>,
    /// including for negative inputs).
    /// </summary>
    private static long FloorDivBy2(long value) => (long)Math.Floor(value / 2.0);
}

/// <summary>Per-component breakdown of Vorsorgeaufwendungen (social insurance contributions).</summary>
public record VorsorgeBreakdown(
    long PensionCents,       // Rentenversicherung
    long UnemploymentCents,  // Arbeitslosenversicherung
    long HealthCents,        // Krankenversicherung (already net of Beitragsrückerstattung + employer subsidy)
    long CareCents,          // Pflegeversicherung
    long BeitragsrueckerstattungCents); // Premium refund already netted out of HealthCents above, shown for display

/// <summary>Per-component breakdown of itemized Werbungskosten vs the flat Pauschale.</summary>
public record WerbungskostenBreakdown(
    long EntfernungspauschaleCents,  // Commute allowance
    long TagespauschaleCents,        // Homeoffice day-rate allowance
    long WorkEquipmentCents,         // Arbeitsmittel
    long HomeOfficeRoomCents,        // häusliches Arbeitszimmer
    long FlatPauschaleCents,         // The flat allowance itemized is being compared against
    bool UsedItemized);              // Whether itemized (true) or the flat Pauschale (false) was higher

/// <summary>Per-component breakdown of rental property results.</summary>
public record RentalBreakdown(
    long RentalIncomeCents,      // Sum of all rent credits
    long MortgageInterestCents,  // Interest payment from EMIs
    long AfaCents,                // Depreciation (Abschreibung)
    long MaintenanceCents,       // Maintenance & repairs (from Property tab)
    long PropertyTaxCents);      // Property tax (from Property tab)

/// <summary>Payslip projection embedded in <see cref="TaxCalculationResult"/>.Payslips.</summary>
public record TaxCalculationPayslip(
    long Id,
    int Month,
    long GrossCents,
    long IncomeTaxCents,
    long SolidaritySurchargeCents,
    long PensionCents,
    long UnemploymentCents,
    long HealthCents,
    long CareCents,
    long NetCents,
    long PayoutCents,
    long IsCorrection,
    string SourceFormat);

/// <summary>
/// Full tax calculation for the household in a given year, combining both
/// filers' incomes, deductions, property results, and social contributions.
/// Ported field-for-field from TaxCalculationResult in src/tax/calculation.ts.
/// </summary>
public record TaxCalculationResult(
    long GrossIncomeCents,
    long WerbungskostenCents,
    long FreelanceRevenueCents,
    long FreelanceExpensesCents,
    long RentalResultCents,
    /// <summary>Sonderausgaben-Pauschbetrag (§10c EStG): €36 single / €72 joint flat allowance.</summary>
    long SonderausgabenPauschbetragCents,
    long VorsorgeaufwendungenCents,
    /// <summary>Breakdown of Vorsorgeaufwendungen for display</summary>
    VorsorgeBreakdown VorsorgeBreakdown,
    /// <summary>Breakdown of rental property result for display</summary>
    RentalBreakdown RentalBreakdown,
    /// <summary>Breakdown of itemized Werbungskosten vs the flat Pauschale for display</summary>
    WerbungskostenBreakdown WerbungskostenBreakdown,
    /// <summary>
    /// Gesamtbetrag der Einkünfte (§2 Abs.3 EStG): sum of each income type,
    /// each already net of its own costs — the subtotal ELSTER prints before
    /// Sonderausgaben are applied.
    /// </summary>
    long GesamtbetragDerEinkuenfteCents,
    /// <summary>
    /// Härteausgleich (§46 Abs.3/5 EStG): sliding relief on minor side income
    /// below €820, subtracted between "Einkommen" and "zu versteuerndes
    /// Einkommen" in ELSTER's own presentation order.
    /// </summary>
    long HaerteausgleichCents,
    long TaxableIncomeCents,
    long IncomeTaxCents,
    long SolidaritySurchargeCents,
    /// <summary>
    /// Payroll-deducted pension + unemployment contributions, plus the
    /// employee's net out-of-pocket medical insurance cost (private Kranken-/
    /// Pflegeversicherung premium after the employer's tax-free subsidy).
    /// </summary>
    long SocialContributionsCents,
    long AlreadyWithheldCents,
    long RefundOrOwedCents,
    long NetInHandCents,
    /// <summary>
    /// Employer's tax-free Arbeitgeberzuschuss to private Kranken-/Pflegeversicherung
    /// (§3 Nr. 62 EStG). Lands in the bank payout alongside net pay but is excluded
    /// from NetInHandCents — it's earmarked to cover part of the HALLESCHE premium
    /// (already netted against it in VorsorgeBreakdown.HealthCents), not disposable
    /// income. Shown here so dashboards can explain why bank-statement income looks
    /// higher than NetInHandCents.
    /// </summary>
    long EmployerHealthCareSubsidyCents,
    int BracketZone,
    /// <summary>Whether Splitting (§§26/26b EStG) was applied (both filers present).</summary>
    bool SplittingApplied,
    /// <summary>
    /// The income the §32a EStG brackets are actually evaluated against: under
    /// Splitting this is floor(zvE / 2) (one half, taxed once then doubled);
    /// otherwise it's the full zvE. In cents.
    /// </summary>
    long RateDeterminingIncomeCents,
    /// <summary>Durchschnittssteuersatz: income_tax_cents / taxable_income_cents.</summary>
    double AverageTaxRate,
    /// <summary>Grenzsteuersatz: tax rate on the next euro of taxable income.</summary>
    double MarginalTaxRate,
    long InsuranceTransactionsTotalCents,
    /// <summary>
    /// Set (to the certified Basis premium) when the employee filer's
    /// Vorsorgeaufwendungen were derived from an uploaded annual health
    /// insurance certificate rather than the bank-transaction fallback. Null
    /// when no certificate has been uploaded for this filer/year.
    /// </summary>
    long? HealthInsuranceCertificateCents,
    List<int> MonthsImported,
    List<TaxCalculationPayslip> Payslips);
