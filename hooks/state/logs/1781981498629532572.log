   185	test('computeMortgageAmortization: splits sequential EMI payments into interest/principal by hand-computed amortization schedule', () => {
   186	  // Mortgage: 200,000.00 EUR outstanding, 3.6% annual interest -> 0.3%/mo = 0.003 monthly rate.
   187	  const mortgage = {
   188	    interest_rate: 3.6,
   189	    outstanding_balance_cents: 20_000_000,
   190	  };
   191	
   192	  // Three monthly EMI payments of 1,000.00 EUR each, provided out of order to verify date-sort.
   193	  const emiLinks = [
   194	    { transaction_id: 3, date: '2023-03-01', amount_cents: -100_000 },
   195	    { transaction_id: 1, date: '2023-01-01', amount_cents: -100_000 },
   196	    { transaction_id: 2, date: '2023-02-01', amount_cents: -100_000 },
   197	  ];
   198	
   199	  // Hand-computed schedule (monthlyRate = 0.003):
   200	  // Month 1: balance=20,000,000 -> interest = round(20,000,000*0.003) = 60,000
   201	  //          principal = min(100,000 - 60,000, 20,000,000) = 40,000
   202	  //          new balance = 19,960,000
   203	  // Month 2: balance=19,960,000 -> interest = round(19,960,000*0.003) = round(59,880) = 59,880
   204	  //          principal = min(100,000 - 59,880, 19,960,000) = 40,120
   205	  //          new balance = 19,919,880
   206	  // Month 3: balance=19,919,880 -> interest = round(19,919,880*0.003) = round(59,759.64) = 59,760
   207	  //          principal = min(100,000 - 59,760, 19,919,880) = 40,240
   208	  //          new balance = 19,879,640
   209	  const expectedAmortized = [
   210	    { transaction_id: 1, interest_cents: 60_000, principal_cents: 40_000 },
   211	    { transaction_id: 2, interest_cents: 59_880, principal_cents: 40_120 },
   212	    { transaction_id: 3, interest_cents: 59_760, principal_cents: 40_240 },
   213	  ];
   214	  const expectedTotalPrincipal = 40_000 + 40_120 + 40_240; // 120,360
   215	  const expectedTotalInterest = 60_000 + 59_880 + 59_760; // 179,640
   216	
   217	  const result = computeMortgageAmortization(mortgage, emiLinks);
   218	
   219	  assert.strictEqual(result.total_principal_paid_cents, expectedTotalPrincipal);
   220	  assert.strictEqual(result.total_interest_paid_cents, expectedTotalInterest);
   221	  assert.deepStrictEqual(result.amortizedTransactions, expectedAmortized);
   222	});
   223	
   224	test('computeMortgageAmortization: stops once currentBalance reaches 0 (break condition), ignoring remaining EMIs', () => {
   225	  // Small mortgage that gets paid off by the second EMI.
   226	  const mortgage = {
   227	    interest_rate: 0, // 0% interest simplifies hand calc: principal = full EMI amount each time
   228	    outstanding_balance_cents: 150_000, // 1,500.00 EUR
   229	  };
   230	
   231	  const emiLinks = [
   232	    { transaction_id: 1, date: '2023-01-01', amount_cents: -100_000 }, // pays down to 50,000
   233	    { transaction_id: 2, date: '2023-02-01', amount_cents: -100_000 }, // principal capped at remaining 50,000 -> balance hits 0
   234	    { transaction_id: 3, date: '2023-03-01', amount_cents: -100_000 }, // should be skipped: currentBalance <= 0 before this iteration
   235	  ];
   236	
   237	  const result = computeMortgageAmortization(mortgage, emiLinks);
   238	
   239	  assert.strictEqual(result.total_principal_paid_cents, 150_000);
   240	  assert.strictEqual(result.total_interest_paid_cents, 0);
   241	  assert.strictEqual(result.amortizedTransactions.length, 2);
   242	  assert.deepStrictEqual(result.amortizedTransactions, [
   243	    { transaction_id: 1, interest_cents: 0, principal_cents: 100_000 },
   244	    { transaction_id: 2, interest_cents: 0, principal_cents: 50_000 },
   245	  ]);
   246	});
