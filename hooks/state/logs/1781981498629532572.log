   152	test('propertyTotalCost: missing manual fields default to 0 via `manualMap[ct] || 0`', () => {
   153	  const db = createTempDb();
   154	
   155	  // Property object missing all the *_cents fields (simulates p.grunderwerbsteuer_cents etc. being undefined).
   156	  const property = { id: 1, purchase_price_cents: 10_000_000 };
   157	  db.prepare(`
   158	    INSERT INTO properties (id, name, purchase_price_cents, purchase_date)
   159	    VALUES (1, 'Bare Property', 10000000, '2023-06-01')
   160	  `).run();
   161	
   162	  const total = propertyTotalCost(property, db);
   163	  assert.strictEqual(total, 10_000_000);
   164	});
