    43	test('ACQUISITION_COST_TYPES exports the same 5 cost types used in the original inline const', () => {
    44	  assert.deepStrictEqual(ACQUISITION_COST_TYPES, [
    45	    'purchase_price',
    46	    'grunderwerbsteuer',
    47	    'notarkosten',
    48	    'maklergebuehr',
    49	    'grundbuchkosten',
    50	  ]);
    51	});
