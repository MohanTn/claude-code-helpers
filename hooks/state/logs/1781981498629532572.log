   167	  const result = computeMortgageAmortization(null, [{ transaction_id: 1, date: '2023-01-01', amount_cents: -100000 }]);
   168	  assert.deepStrictEqual(result, {
   169	    total_principal_paid_cents: 0,
   170	    total_interest_paid_cents: 0,
