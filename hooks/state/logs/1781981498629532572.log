     1	// Regression tests for src/property/amortization.ts.
     2	//
     3	// These functions were extracted verbatim from src/api/server.ts (formerly
     4	// inline closures inside createApp()). The assertions here use expected
     5	// values computed by hand from the same logic that existed pre-extraction,
     6	// to confirm the extraction is behavior-identical.
     7	
     8	import { test } from 'node:test';
     9	import * as assert from 'node:assert';
    10	import { mkdtempSync, readFileSync } from 'node:fs';
    11	import { tmpdir } from 'node:os';
    12	import path from 'node:path';
    13	import Database from 'better-sqlite3';
    14	import { propertyTotalCost, computeMortgageAmortization, ACQUISITION_COST_TYPES } from './amortization.js';
    15	
    16	const SCHEMA_PATH = path.resolve(import.meta.dirname, '../db/schema.sql');
    17	
    18	function createTempDb(): Database.Database {
    19	  const dir = mkdtempSync(path.join(tmpdir(), 'finance-amortization-test-'));
    20	  const file = path.join(dir, 'finance.db');
    21	  const db = new Database(file);
    22	  db.exec(readFileSync(SCHEMA_PATH, 'utf-8'));
    23	  return db;
    24	}
    25	
    26	function seedAccount(db: Database.Database): number {
    27	  const result = db
    28	    .prepare(`INSERT INTO accounts (name, institution, type, currency, is_credit_card) VALUES (?, ?, ?, 'EUR', 0)`)
    29	    .run('Test Account', 'TestBank', 'asset');
    30	  return result.lastInsertRowid as number;
    31	}
    32	
    33	function insertTransaction(db: Database.Database, accountId: number, date: string, description: string, amountCents: number): number {
    34	  const result = db
    35	    .prepare(`
    36	      INSERT INTO transactions (account_id, date, description, amount_cents, currency, category, raw_text, source_pdf, source_hash)
    37	      VALUES (?, ?, ?, ?, 'EUR', 'Other', ?, 'test.pdf', ?)
    38	    `)
    39	    .run(accountId, date, description, amountCents, description, `${date}-${description}-${amountCents}`);
    40	  return result.lastInsertRowid as number;
    41	}
