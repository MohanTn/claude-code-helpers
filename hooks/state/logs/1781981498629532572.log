    53	test('propertyTotalCost: sums manual cost fields when no linked transactions exist', () => {
    54	  const db = createTempDb();
    55	
    56	  const property = {
    57	    id: 1,
    58	    purchase_price_cents: 30_000_000, // 300,000.00 EUR
    59	    grunderwerbsteuer_cents: 1_500_000, // 15,000.00 EUR (5%)
    60	    notarkosten_cents: 450_000, // 4,500.00 EUR
    61	    maklergebuehr_cents: 900_000, // 9,000.00 EUR
    62	    grundbuchkosten_cents: 150_000, // 1,500.00 EUR
    63	  };
    64	  db.prepare(`
    65	    INSERT INTO properties (id, name, purchase_price_cents, purchase_date, grunderwerbsteuer_cents, notarkosten_cents, maklergebuehr_cents, grundbuchkosten_cents)
    66	    VALUES (1, 'Test Property', ?, '2023-01-15', ?, ?, ?, ?)
    67	  `).run(
    68	    property.purchase_price_cents,
    69	    property.grunderwerbsteuer_cents,
    70	    property.notarkosten_cents,
    71	    property.maklergebuehr_cents,
    72	    property.grundbuchkosten_cents,
    73	  );
    74	
    75	  // Expected: pure sum of manual fields, no linked transactions, no property_transactions rows.
    76	  const expected =
    77	    property.purchase_price_cents +
    78	    property.grunderwerbsteuer_cents +
    79	    property.notarkosten_cents +
    80	    property.maklergebuehr_cents +
    81	    property.grundbuchkosten_cents; // = 33,000,000
    82	
    83	  const total = propertyTotalCost(property, db);
    84	  assert.strictEqual(total, 33_000_000);
    85	  assert.strictEqual(total, expected);
    86	});
    87	
    88	test('propertyTotalCost: linked transactions override manual fields per cost_type, plus acquisition property_transactions are added on top', () => {
    89	  const db = createTempDb();
    90	  const accountId = seedAccount(db);
    91	
    92	  const property = {
    93	    id: 1,
    94	    purchase_price_cents: 30_000_000,
    95	    grunderwerbsteuer_cents: 1_500_000,
    96	    notarkosten_cents: 450_000,
    97	    maklergebuehr_cents: 900_000,
    98	    grundbuchkosten_cents: 150_000,
    99	  };
   100	  db.prepare(`
   101	    INSERT INTO properties (id, name, purchase_price_cents, purchase_date, grunderwerbsteuer_cents, notarkosten_cents, maklergebuehr_cents, grundbuchkosten_cents)
   102	    VALUES (1, 'Test Property', ?, '2023-01-15', ?, ?, ?, ?)
   103	  `).run(
   104	    property.purchase_price_cents,
   105	    property.grunderwerbsteuer_cents,
   106	    property.notarkosten_cents,
   107	    property.maklergebuehr_cents,
   108	    property.grundbuchkosten_cents,
   109	  );
   110	
   111	  // Link an actual transaction for purchase_price (-305,000.00 EUR, abs = 30,500,000 cents)
   112	  // which should override the manual purchase_price_cents (30,000,000).
   113	  const purchaseTxnId = insertTransaction(db, accountId, '2023-01-15', 'Notary purchase payment', -30_500_000);
   114	  db.prepare(`INSERT INTO property_cost_links (property_id, cost_type, transaction_id) VALUES (1, 'purchase_price', ?)`).run(purchaseTxnId);
   115	
   116	  // Link a second transaction for the SAME cost_type to verify SUM(ABS(...)) aggregation
   117	  // (e.g. a partial follow-up payment of 500.00 EUR).
   118	  const purchaseTxnId2 = insertTransaction(db, accountId, '2023-01-20', 'Notary purchase follow-up', -50_000);
   119	  db.prepare(`INSERT INTO property_cost_links (property_id, cost_type, transaction_id) VALUES (1, 'purchase_price', ?)`).run(purchaseTxnId2);
   120	
   121	  // Link grunderwerbsteuer transaction overriding the manual field too.
   122	  const taxTxnId = insertTransaction(db, accountId, '2023-02-01', 'Grunderwerbsteuer', -1_600_000);
   123	  db.prepare(`INSERT INTO property_cost_links (property_id, cost_type, transaction_id) VALUES (1, 'grunderwerbsteuer', ?)`).run(taxTxnId);
   124	
   125	  // notarkosten, maklergebuehr, grundbuchkosten remain unlinked -> fall back to manual fields.
   126	
   127	  // Also add an acquisition-type property_transactions row (separate accounting path, summed unconditionally).
   128	  db.prepare(`
   129	    INSERT INTO property_transactions (property_id, date, type, amount_cents, description)
   130	    VALUES (1, '2023-01-10', 'acquisition_agent_fee', 200000, 'Extra agent fee')
   131	  `).run();
   132	
   133	  // Add a non-acquisition property_transactions row that must NOT be counted (e.g. mortgage_payment type).
   134	  db.prepare(`
   135	    INSERT INTO property_transactions (property_id, date, type, amount_cents, description)
   136	    VALUES (1, '2023-03-01', 'mortgage_payment', -50000, 'Should not be counted')
   137	  `).run();
   138	
   139	  const expectedLinkedPurchasePrice = 30_500_000 + 50_000; // SUM(ABS(...)) across both linked txns = 30,550,000
   140	  const expectedLinkedTax = 1_600_000;
   141	  const expectedFallback = property.notarkosten_cents + property.maklergebuehr_cents + property.grundbuchkosten_cents; // 1,500,000
   142	  const expectedAcquisitionPropertyTxns = 200_000;
   143	
   144	  const expectedTotal = expectedLinkedPurchasePrice + expectedLinkedTax + expectedFallback + expectedAcquisitionPropertyTxns;
   145	  // = 30,550,000 + 1,600,000 + 1,500,000 + 200,000 = 33,850,000
   146	
   147	  const total = propertyTotalCost(property, db);
   148	  assert.strictEqual(total, 33_850_000);
   149	  assert.strictEqual(total, expectedTotal);
   150	});
