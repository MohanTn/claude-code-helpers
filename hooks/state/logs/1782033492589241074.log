using System.Text.RegularExpressions;
using FinanceAnalyser.Core.Models;

namespace FinanceAnalyser.Parsers;

/// <summary>
/// Trade Republic Cashkonto statement parser (German, chronological).
/// Ported from src/parsers/traderepublic.ts.
///
/// The UMSATZÜBERSICHT table renders each transaction as a 3-line group
/// (separated by blank lines), with somewhat irregular column alignment from
/// `pdftotext -layout`:
///
///   Line A: "DD Mon." [+ description continuation]   (or just "DD" if the
///           month wraps onto line B, e.g. "01" / "Sept.     Zinsen ...")
///   Line B: "          TYP   &lt;description&gt;   &lt;ZAHLUNGSEINGANG|ZAHLUNGSAUSGANG&gt;€   SALDO€"
///   Line C: "YYYY" [+ description continuation]
///
/// TYP is one of: Zinsen, Handel, Steuern, Ertrag, Überweisung.
/// The last €-amount on line B is always SALDO (running balance), excluded
/// from the transaction amount. Sign of the remaining amount is determined by
/// comparing this row's SALDO to the previous row's SALDO (delta-based
/// inference, robust against ambiguous column positions).
/// </summary>
public static partial class TradeRepublicParser
{
    private const string SourcePdf = "trade-republic-account-statement-2025.pdf";

    [GeneratedRegex(@"(Zinsen|Handel|Steuern|Ertrag|Überweisung)")]
    private static partial Regex TypRegex();

    // All "€"-suffixed amounts on a line, e.g. "1.152,54 €" or "-0,42 €".
    [GeneratedRegex(@"-?[\d.]+,\d{2}\s*€")]
    private static partial Regex EurAmountRegex();

    [GeneratedRegex(@"^DATUM\s+TYP\s+BESCHREIBUNG")]
    private static partial Regex SectionStartRegex();

    [GeneratedRegex(@"^BARMITTELÜBERSICHT")]
    private static partial Regex SectionEndRegex();

    [GeneratedRegex(@"^(\d{1,2})\b")]
    private static partial Regex DayMatchRegex();

    [GeneratedRegex(@"^([A-Za-zä]+\.?)")]
    private static partial Regex MonthOnARegex();

    [GeneratedRegex(@"^([A-Za-zä]+\.?)\s*")]
    private static partial Regex MonthOnBRegex();

    [GeneratedRegex(@"^\s*[A-Za-zä]+\.?\s*")]
    private static partial Regex MonthStripRegex();

    [GeneratedRegex(@"(\d{4})")]
    private static partial Regex YearRegex();

    [GeneratedRegex(@"^(\d{4})")]
    private static partial Regex YearLeadingRegex();

    [GeneratedRegex(@"Zum (\d{1,2}) ([A-Za-zä]+\.?) (\d{4})")]
    private static partial Regex ZumRegex();

    [GeneratedRegex(@"Deutsche Bank\s+([\d.,]+)\s*€")]
    private static partial Regex DeutscheBankRegex();

    /// <summary>
    /// Parses the Trade Republic Cashkonto statement and returns all transactions
    /// from the UMSATZÜBERSICHT table, plus the closing balance snapshot from the
    /// BARMITTELÜBERSICHT section.
    /// </summary>
    public static ParseResult Parse(string pdfPath)
    {
        string text = PdfTextExtractor.ExtractLayoutText(pdfPath);
        var lines = text.Split('\n');

        // Isolate the UMSATZÜBERSICHT section: from the "DATUM TYP BESCHREIBUNG..." header
        // (first occurrence) to "BARMITTELÜBERSICHT".
        int startIdx = Array.FindIndex(lines, l => SectionStartRegex().IsMatch(l));
        int endIdx = Array.FindIndex(lines, l => SectionEndRegex().IsMatch(l));
        if (startIdx == -1 || endIdx == -1)
        {
            throw new InvalidOperationException("parseTradeRepublic: could not locate UMSATZÜBERSICHT section");
        }
        var sectionLines = lines.Skip(startIdx + 1).Take(endIdx - (startIdx + 1)).ToList();

        // Group into records separated by blank lines.
        var records = new List<List<string>>();
        var current = new List<string>();
        foreach (var line in sectionLines)
        {
            if (line.Trim() == "")
            {
                if (current.Count > 0)
                {
                    records.Add(current);
                    current = new List<string>();
                }
            }
            else
            {
                current.Add(line);
            }
        }
        if (current.Count > 0) records.Add(current);

        var transactions = new List<ParsedTransaction>();
        long? previousSaldoCents = null;

        foreach (var record in records)
        {
            if (record.Count != 3) continue; // skip page headers/footers/legal text

            string lineA = record[0];
            string lineB = record[1];
            string lineC = record[2];

            // A transaction record's first line must start with a 1-2 digit day number.
            var dayMatch = DayMatchRegex().Match(lineA);
            if (!dayMatch.Success) continue;
            string day = dayMatch.Groups[1].Value;

            // TYP must appear on line B (or, defensively, line A/C).
            var typMatch = TypRegex().Match(lineB);
            if (!typMatch.Success) typMatch = TypRegex().Match(lineA);
            if (!typMatch.Success) typMatch = TypRegex().Match(lineC);
            if (!typMatch.Success) continue;
            string typ = typMatch.Groups[1].Value;

            // Month: either trailing on line A after the day number, or leading on line B
            // (split case, e.g. lineA="08", lineB="Sept.     Überweisung ...").
            string? monthAbbrev = null;
            string lineBForDesc = lineB;
            string afterDayOnA = lineA[dayMatch.Value.Length..].Trim();
            var monthOnA = MonthOnARegex().Match(afterDayOnA);
            if (monthOnA.Success)
            {
                monthAbbrev = monthOnA.Groups[1].Value;
            }
            else
            {
                // Split case: month wraps onto line B, e.g. lineA="08", lineB="Sept.     Überweisung ...".
                var monthOnB = MonthOnBRegex().Match(lineB.Trim());
                if (monthOnB.Success)
                {
                    monthAbbrev = monthOnB.Groups[1].Value;
                    lineBForDesc = MonthStripRegex().Replace(lineB, "");
                }
            }
            if (monthAbbrev == null)
            {
                throw new InvalidOperationException($"parseTradeRepublic: could not determine month for record: {string.Join(" | ", record)}");
            }

            // Year: first 4-digit number on line C.
            var yearMatch = YearRegex().Match(lineC);
            if (!yearMatch.Success)
            {
                throw new InvalidOperationException($"parseTradeRepublic: could not determine year for record: {string.Join(" | ", record)}");
            }
            string year = yearMatch.Groups[1].Value;

            string date = Normalize.GermanDateToISO(day, monthAbbrev, year);

            // All €-amounts on line B; last one is SALDO (running balance).
            var amounts = EurAmountRegex().Matches(lineB).Select(m => m.Value).ToList();
            if (amounts.Count < 1)
            {
                throw new InvalidOperationException($"parseTradeRepublic: no amounts found on line B: \"{lineB}\"");
            }
            string saldoStr = amounts[^1];
            long saldoCents = Normalize.ParseDecimalToCents(saldoStr.Replace("€", "").Trim(), Normalize.DecimalSeparator.Comma);

            long amountCents;
            if (amounts.Count >= 2)
            {
                // Two amounts present: the first is the transaction amount; sign is
                // determined by delta vs. previous SALDO.
                string amountStr = amounts[0];
                long magnitude = Math.Abs(Normalize.ParseDecimalToCents(amountStr.Replace("€", "").Trim(), Normalize.DecimalSeparator.Comma));
                if (previousSaldoCents != null && saldoCents < previousSaldoCents)
                {
                    amountCents = -magnitude;
                }
                else
                {
                    amountCents = magnitude;
                }
            }
            else
            {
                // Only SALDO present (amount is implicitly the SALDO delta from the previous row).
                if (previousSaldoCents == null)
                {
                    throw new InvalidOperationException($"parseTradeRepublic: cannot infer amount for first record without a prior SALDO: {string.Join(" | ", record)}");
                }
                amountCents = saldoCents - previousSaldoCents.Value;
            }

            previousSaldoCents = saldoCents;

            // Build description: TYP + remaining text from all 3 lines, with the
            // date/amount tokens stripped out.
            string descPartA = MonthOnARegex().Replace(afterDayOnA, "").Trim();
            string descPartB = EurAmountRegex().Replace(TypRegex().Replace(lineBForDesc, ""), "").Trim();
            string descPartC = YearLeadingRegex().Replace(lineC, "").Trim();

            var descParts = new[] { typ, descPartA, descPartB, descPartC }.Where(p => p.Length > 0);
            string description = Regex.Replace(string.Join(" ", descParts), @"\s+", " ").Trim();

            transactions.Add(new ParsedTransaction(
                date,
                description,
                amountCents,
                "EUR",
                string.Join("\n", record),
                SourcePdf));
        }

        // Closing balance snapshot from BARMITTELÜBERSICHT: "Zum 31 Dez. 2025" + Cashkonto's
        // Treuhandkonten "Deutsche Bank ... 3.072,71 €" row.
        BalanceSnapshot? balanceSnapshot = null;
        var zumMatch = ZumRegex().Match(text);
        var deutscheBankMatch = DeutscheBankRegex().Match(text);
        if (zumMatch.Success && deutscheBankMatch.Success)
        {
            string day = zumMatch.Groups[1].Value;
            string monthAbbrev = zumMatch.Groups[2].Value;
            string year = zumMatch.Groups[3].Value;
            balanceSnapshot = new BalanceSnapshot(
                Normalize.GermanDateToISO(day, monthAbbrev, year),
                Normalize.ParseDecimalToCents(deutscheBankMatch.Groups[1].Value, Normalize.DecimalSeparator.Comma));
        }

        return new ParseResult(transactions, balanceSnapshot);
    }
}
