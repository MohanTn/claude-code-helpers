     1	// Infoniqa ONE payslip parser (the vendor's successor format to DATEV,
     2	// used from April 2025 onward).
     3	//
     4	// Sniff: real files carry a footer line containing the literal string
     5	// "Infoniqa ONE", e.g.:
     6	//   253021309: Infoniqa ONE 2025g031 RB:20241211 - 10.04.2025 12:17:48
     7	//
     8	// A single PDF can contain multiple concatenated blocks. Each block is
     9	// delimited by its own header line matching either:
    10	//   "Korrektur Gehaltsabrechnung N/YYYY (für M/YYYY)"   (a correction run)
    11	//   "Gehaltsabrechnung N/YYYY"                          (the current/non-correction run)
    12	//
    13	// IMPORTANT, verified directly against the real 3-block fixture
    14	// docs/payslip/2026/Payslip-2026-03-2026-03-26-366408.pdf: the "(für M/YYYY)"
    15	// suffix on a Korrektur header is the payroll BATCH/RUN month (all blocks in
    16	// one PDF share the same value, since they're all generated in the same
    17	// run) — it is NOT the target month the block's figures cover, and must
    18	// NEVER be used to derive year/month.
    19	//
    20	// The correct target month/year instead comes from a separate line that
    21	// appears later within the SAME block:
    22	//   "Verdienstbescheinigung vom DD.MM. bis DD.MM.YYYY - bitte aufbewahren!"
    23	// The block's target month/year is the month/year of the SECOND (end) date
    24	// in that line (the start date is always a fixed "01.01.<year>"
    25	// year-to-date framing and must be ignored). Verified against the 3-block
    26	// fixture: block 1 ends 31.01.2026 -> Jan 2026; block 2 ends 28.02.2026 ->
    27	// Feb 2026; block 3 ends 31.03.2026 -> Mar 2026 — independently corroborated
    28	// by each block's own (non-cumulative, single-month) Gesamtbrutto figure.
    29	//
    30	// All narrative monetary fields are read from per-block narrative lines
    31	// (never the bottom YTD-cumulative table, which is self-check-only — see
    32	// below). Narrative values are right-aligned on their own line and may
    33	// carry a trailing single-letter code (e.g. " K" = "Korrektur-affected
    34	// line", per the file's own legend) and/or be printed with a leading "-"
    35	// sign for deductions; both are stripped before parsing, since callers want
    36	// a positive cents magnitude for income_tax_cents/pension_cents/etc.
    37	
    38	import { pdfToText } from './pdftotext.js';
    39	import { ddmmyyyyToISO, parseDecimalToCents, splitBlocks } from './normalize.js';
    40	import type { ParsedPayslip, PayslipParseResult } from './payslip-types.js';
    41	
    42	const SOURCE_FORMAT = 'infoniqa' as const;
    43	
    44	const SNIFF_STRING = 'Infoniqa ONE';
    45	
    46	// Block header: either a Korrektur line (with a "(für M/YYYY)" batch-month
    47	// suffix we deliberately ignore) or a plain Gehaltsabrechnung line.
    48	const BLOCK_HEADER_RE = /^(Korrektur Gehaltsabrechnung|Gehaltsabrechnung) \d+\/\d{4}/;
    49	
    50	const VERDIENSTBESCHEINIGUNG_RE =
    51	  /^Verdienstbescheinigung vom \d{2}\.\d{2}\. bis (\d{2})\.(\d{2})\.(\d{4}) - bitte aufbewahren!/;
    52	
    53	// Issue date + time, from the per-block footer line, e.g.:
    54	// "253021309: Infoniqa ONE 2025g031 RB:20241211 - 10.04.2025 12:17:48"
    55	const ISSUE_DATE_RE = /Infoniqa ONE\b.*?-\s*(\d{2}\.\d{2}\.\d{4})\s+\d{2}:\d{2}:\d{2}/;
    56	
    57	const STEUERKLASSE_RE = /^\s*Steuerklasse\s+(\S+)\s*$/;
    58	
    59	// Rightmost properly comma-formatted amount on a narrative line, with an
    60	// optional leading sign and an optional trailing single-letter code (e.g.
    61	// "-989,83 K", "5.416,50 K", "6.745,92", "118,73 K", "-5.810,77 +").
    62	const VALUE_RE = /([+-]?[\d.]+,\d{2})\s*[A-Za-z+-]?\s*$/;
    63	
    64	/** Parses a German-formatted amount, possibly signed and/or with a trailing
    65	 * single-letter code, into an unsigned cents magnitude. */
    66	function parseMagnitudeCents(raw: string): number {
    67	  return Math.abs(parseDecimalToCents(raw, 'comma'));
    68	}
    69	
    70	/** Finds the first line in [fromIndex, toIndex) whose content (after the
    71	 * leading code/label columns) contains `label`, and extracts the rightmost
    72	 * amount on that same line (narrative lines are single-line label+value,
    73	 * unlike DATEV's label-then-value-on-next-line layout). */
    74	function extractNarrativeValueCents(
    75	  lines: string[],
    76	  label: string,
    77	  fromIndex: number,
    78	  toIndex: number
    79	): number | null {
    80	  for (let i = fromIndex; i < toIndex; i++) {
    81	    if (lines[i].includes(label)) {
    82	      const m = lines[i].match(VALUE_RE);
    83	      if (m) {
    84	        return parseMagnitudeCents(m[1]);
    85	      }
    86	      return null;
    87	    }
    88	  }
    89	  return null;
    90	}
    91	
    92	/** Like `extractNarrativeValueCents`, but sums every matching line instead
    93	 * of stopping at the first. Needed for "Lohnsteuer", which splits into two
    94	 * separate lines — "Lohnsteuer lfd. Bezüge" and "Lohnsteuer sonstige
    95	 * Bezüge" — in months with a one-off bonus (taxed separately under the
    96	 * Fünftelregelung-style "sonstige Bezüge" rules); a first-match-only lookup
    97	 * silently drops the second line's tax. Lines containing the label with no
    98	 * parseable trailing amount (e.g. the cumulative table's column header, or
    99	 * the "Lohnsteuerbescheinigung" footer disclaimer) are skipped, not fatal. */
   100	function extractNarrativeValueCentsSum(
   101	  lines: string[],
   102	  label: string,
   103	  fromIndex: number,
   104	  toIndex: number
   105	): number | null {
   106	  let sum = 0;
   107	  let found = false;
   108	  for (let i = fromIndex; i < toIndex; i++) {
   109	    if (lines[i].includes(label)) {
   110	      const m = lines[i].match(VALUE_RE);
   111	      if (m) {
   112	        sum += parseMagnitudeCents(m[1]);
   113	        found = true;
   114	      }
   115	    }
   116	  }
   117	  return found ? sum : null;
   118	}
   119	
   120	/** Extracts the cumulative-table's Lohnsteuer column value (6th
   121	 * whitespace-separated token on the data row that follows the
   122	 * "St.-Brutto ... Lohnsteuer ..." header row), for the self-check only. */
   123	function extractCumulativeLohnsteuerCents(lines: string[], fromIndex: number, toIndex: number): number | null {
   124	  for (let i = fromIndex; i < toIndex - 1; i++) {
   125	    if (lines[i].startsWith('St.-Brutto') && lines[i].includes('Lohnsteuer')) {
   126	      const dataLine = lines[i + 1];
   127	      const tokens = dataLine.trim().split(/\s+/);
   128	      // Columns: St.-Brutto, sonst. Bezüge, Steuertage, KV-Brutto, SV-Brutto, Lohnsteuer, ...
   129	      const lohnsteuerToken = tokens[5];
   130	      if (lohnsteuerToken) {
   131	        return parseMagnitudeCents(lohnsteuerToken);
   132	      }
   133	      return null;
   134	    }
   135	  }
   136	  return null;
   137	}
   138	
   139	interface BlockParseResult {
   140	  payslip: ParsedPayslip;
   141	  cumulativeLohnsteuerCents: number;
   142	}
   143	
   144	function parseBlock(
   145	  headerSectionLines: string[],
   146	  blockLines: string[],
   147	  sourcePdfName: string,
   148	  rawBlockText: string
   149	): BlockParseResult {
   150	  const headerLine = blockLines[0];
   151	  const headerMatch = headerLine.match(BLOCK_HEADER_RE);
   152	  if (!headerMatch) {
   153	    throw new Error(`parsePayslipInfoniqa: could not parse block header line: "${headerLine}"`);
   154	  }
   155	  const is_correction = headerMatch[1] === 'Korrektur Gehaltsabrechnung';
   156	
   157	  // Target month/year: the END date of this block's own
   158	  // "Verdienstbescheinigung vom ... bis DD.MM.YYYY" line — NOT the Korrektur
   159	  // header's "(für M/YYYY)" batch-month suffix (see file header comment).
   160	  const verdienstLineIdx = blockLines.findIndex((l) => VERDIENSTBESCHEINIGUNG_RE.test(l));
   161	  if (verdienstLineIdx === -1) {
   162	    throw new Error(
   163	      `parsePayslipInfoniqa: could not find "Verdienstbescheinigung vom ... bis ..." line in block starting "${headerLine}"`
   164	    );
   165	  }
   166	  const verdienstMatch = blockLines[verdienstLineIdx].match(VERDIENSTBESCHEINIGUNG_RE);
   167	  const [, , endMonthStr, endYearStr] = verdienstMatch as RegExpMatchArray;
   168	  const month = parseInt(endMonthStr, 10);
   169	  const year = parseInt(endYearStr, 10);
   170	
   171	  // Issue date: footer line within this block (falls back to null if absent).
   172	  let issue_date: string | null = null;
   173	  for (let i = 0; i < blockLines.length; i++) {
   174	    const m = blockLines[i].match(ISSUE_DATE_RE);
   175	    if (m) {
   176	      issue_date = ddmmyyyyToISO(m[1]);
   177	      break;
   178	    }
   179	  }
   180	
   181	  // Tax class: "Steuerklasse               3/0.0/A" line. This (and the
   182	  // employer name below) live in the page-header section that PRECEDES this
   183	  // block's own header line in the raw text (each page's "Personalnummer /
   184	  // Steuerklasse / ..." header block is printed just above the
   185	  // Korrektur/Gehaltsabrechnung line it belongs to) — verified directly:
   186	  // in the 3-block fixture, "Steuerklasse" appears once per block, each
   187	  // occurrence sitting a few lines above that block's own header line.
   188	  let tax_class: string | null = null;
   189	  for (const line of headerSectionLines) {
   190	    const m = line.match(STEUERKLASSE_RE);
   191	    if (m) {
   192	      tax_class = m[1];
   193	      break;
   194	    }
   195	  }
   196	
   197	  // Employer name: first line of the page-header section, e.g.
   198	  // "dunnhumby Germany GmbH                ... Personalnummer  211371".
   199	  // Take the text before the large run of whitespace that separates it
   200	  // from the right-hand column.
   201	  let employer_name: string | null = null;
   202	  {
   203	    const firstLine = headerSectionLines[0] ?? '';
   204	    const m = firstLine.match(/^(\S.*?)\s{2,}/);
   205	    employer_name = m ? m[1].trim() : firstLine.trim() || null;
   206	  }
   207	
   208	  // Narrative lines: search the whole block (each label appears once per
   209	  // block in the narrative section, well before the cumulative table).
   210	  const gross_cents = extractNarrativeValueCents(blockLines, 'Gesamtbrutto', 0, blockLines.length) ?? 0;
   211	  const income_tax_cents = extractNarrativeValueCentsSum(blockLines, 'Lohnsteuer', 0, blockLines.length) ?? 0;
   212	  // In bonus months, the one-off ("sonstige"/EGA) portion of pay gets its own
   213	  // "Rentenversicherung EGA"/"Arbeitslosenversicherung EGA" line alongside
   214	  // the regular "... lfd." line (same split as Lohnsteuer above) — sum both
   215	  // rather than matching "lfd." only, which silently dropped the EGA share.
   216	  const pension_cents =
   217	    extractNarrativeValueCentsSum(blockLines, 'Rentenversicherung', 0, blockLines.length) ?? 0;
   218	  const unemployment_cents =
   219	    extractNarrativeValueCentsSum(blockLines, 'Arbeitslosenversicherung', 0, blockLines.length) ?? 0;
   220	  const net_cents = extractNarrativeValueCents(blockLines, 'Nettoverdienst', 0, blockLines.length) ?? 0;
   221	
   222	  // Church tax / solidarity surcharge: no narrative line is printed at all
   223	  // when the amount is zero in these real files (household has no church
   224	  // tax membership, and Soli is 0 at this income level) — default to 0.
   225	  const church_tax_cents =
   226	    extractNarrativeValueCents(blockLines, 'Kirchensteuer', 0, blockLines.length) ?? 0;
   227	  const solidarity_surcharge_cents =
   228	    extractNarrativeValueCents(blockLines, 'Solidaritätszuschlag', 0, blockLines.length) ?? 0;
   229	
   230	  // Employer subsidy lines for private health/care insurance (present in
   231	  // real 2025/2026 files for this household). Absent => 0.
   232	  const health_cents =
   233	    extractNarrativeValueCents(blockLines, 'AG-Zuschuss private Krankenvers.', 0, blockLines.length) ?? 0;
   234	  const care_cents =
   235	    extractNarrativeValueCents(blockLines, 'AG-Zuschuss private Pflegevers.', 0, blockLines.length) ?? 0;
   236	
   237	  // Payout: "the amount actually paid out for this block". This is the
   238	  // least standardized line across block types in the real files:
   239	  //  - Plain single-block months: a line containing "IBAN ... EUR <amount>"
   240	  //    (sometimes prefixed with the bank/branch name, e.g.
   241	  //    "Commerzbank, Filiale Berlin 1 IBAN ... EUR <amount>").
   242	  //  - The final (non-correction) block of a multi-block run also ends in
   243	  //    an "IBAN ... EUR <amount>" line (e.g. "Saldo lfd. Monat" / "Differenz
   244	  //    aus Vormonat" lines precede it, but the IBAN line is still the actual
   245	  //    bank transfer amount for that run).
   246	  //  - Earlier correction blocks within a multi-block run do NOT have a bank
   247	  //    transfer of their own (no money moves until the final, current-month
   248	  //    block) — instead they print a "Verbindlichkeit MM/YYYY ... <amount> +"
   249	  //    line representing the liability/entitlement re-computed for that
   250	  //    corrected month. We use that line as the payout-equivalent figure for
   251	  //    such blocks, since it's the closest analog to "amount this block
   252	  //    says is owed for that month" and no real money-movement line exists.
   253	  // Preference order: IBAN line (real bank transfer) first; else
   254	  // Verbindlichkeit line (correction-only liability figure).
   255	  let payout_cents = extractNarrativeValueCents(blockLines, 'IBAN', 0, blockLines.length);
   256	  if (payout_cents === null) {
   257	    payout_cents = extractNarrativeValueCents(blockLines, 'Verbindlichkeit', 0, blockLines.length);
   258	  }
   259	  payout_cents = payout_cents ?? 0;
   260	
   261	  // Self-check input only — NOT used to populate income_tax_cents.
   262	  const cumulativeLohnsteuerCents =
   263	    extractCumulativeLohnsteuerCents(blockLines, verdienstLineIdx, blockLines.length) ?? 0;
   264	
   265	  const payslip: ParsedPayslip = {
   266	    year,
   267	    month,
   268	    tax_class,
   269	    employer_name,
   270	    gross_cents,
   271	    income_tax_cents,
   272	    church_tax_cents,
   273	    solidarity_surcharge_cents,
   274	    pension_cents,
   275	    unemployment_cents,
   276	    health_cents,
   277	    care_cents,
   278	    net_cents,
   279	    payout_cents,
   280	    is_correction,
   281	    source_format: SOURCE_FORMAT,
   282	    source_pdf: sourcePdfName,
   283	    issue_date,
   284	    raw_text: rawBlockText,
   285	  };
   286	
   287	  return { payslip, cumulativeLohnsteuerCents };
   288	}
   289	
   290	/**
   291	 * Parses an Infoniqa ONE payslip PDF and returns all payslips found in it.
   292	 *
   293	 * A single PDF may contain multiple blocks (e.g. one or more corrections
   294	 * plus a final current-month run); each block becomes one ParsedPayslip.
   295	 * Each block's target year/month is derived from its own
   296	 * "Verdienstbescheinigung vom ... bis DD.MM.YYYY" end date, NOT from the
   297	 * Korrektur header's "(für M/YYYY)" batch-run-month suffix.
   298	 *
   299	 * After parsing, runs a self-check using the YTD-cumulative "Lohnsteuer"
   300	 * column in each block's trailing summary table: for blocks sorted by
   301	 * target month ascending, the cumulative delta between consecutive blocks
   302	 * must match that later block's own narrative income_tax_cents (within 1
   303	 * cent). This catches parsing bugs (e.g. picking up the wrong line) before
   304	 * they reach the database — it throws rather than silently swallowing a
   305	 * mismatch.
   306	 *
   307	 * Returns `{ payslips: [], skipped_reason }` for non-Infoniqa documents
   308	 * (sniffed via the absence of the "Infoniqa ONE" footer marker).
   309	 */
   310	export function parsePayslipInfoniqa(pdfPath: string, preReadText?: string): PayslipParseResult {
   311	  const text = preReadText ?? pdfToText(pdfPath);
   312	
   313	  if (!text.includes(SNIFF_STRING)) {
   314	    return {
   315	      payslips: [],
   316	      skipped_reason: `"${SNIFF_STRING}" marker not found — not an Infoniqa ONE payslip`,
   317	    };
   318	  }
   319	
   320	  const sourcePdfName = pdfPath.split('/').pop() ?? pdfPath;
   321	  const lines = text.split('\n');
   322	
   323	  const blocks = splitBlocks(lines, BLOCK_HEADER_RE);
   324	  if (blocks.length === 0) {
   325	    return { payslips: [] };
   326	  }
   327	
   328	  // The document-top header section (lines 0..first header) contains the
   329	  // employer name and tax class, which are the same for every block in a
   330	  // multi-block concatenated PDF. Reusing this single header section for
   331	  // all blocks avoids the bug where blocks 2+ would pick up the previous
   332	  // block's own header line as their "employer name".
   333	  const firstHeaderIdx = lines.findIndex((l) => BLOCK_HEADER_RE.test(l));
   334	  const headerSectionLines = lines.slice(0, firstHeaderIdx);
   335	
   336	  const blockResults: BlockParseResult[] = [];
   337	  for (const blockLines of blocks) {
   338	    const rawBlockText = blockLines.join('\n');
   339	    blockResults.push(parseBlock(headerSectionLines, blockLines, sourcePdfName, rawBlockText));
   340	  }
   341	
   342	  // Self-check: sort by target month ascending, verify cumulative Lohnsteuer
   343	  // deltas reconcile with each block's own narrative income_tax_cents.
   344	  const sorted = [...blockResults].sort((a, b) => {
   345	    if (a.payslip.year !== b.payslip.year) return a.payslip.year - b.payslip.year;
   346	    return a.payslip.month - b.payslip.month;
   347	  });
   348	  for (let i = 1; i < sorted.length; i++) {
   349	    const prev = sorted[i - 1];
   350	    const curr = sorted[i];
   351	    const delta = curr.cumulativeLohnsteuerCents - prev.cumulativeLohnsteuerCents;
   352	    const diff = Math.abs(delta - curr.payslip.income_tax_cents);
   353	    if (diff > 1) {
   354	      throw new Error(
   355	        `parsePayslipInfoniqa: self-check failed for ${sourcePdfName} block ${curr.payslip.month}/${curr.payslip.year}: ` +
   356	          `cumulative Lohnsteuer delta (${delta} cents) does not match narrative income_tax_cents (${curr.payslip.income_tax_cents} cents)`
   357	      );
   358	    }
   359	  }
   360	
   361	  return { payslips: blockResults.map((r) => r.payslip) };
   362	}
