     1	namespace FinanceAnalyser.Core.Tax;
     2	
     3	// German §32a EStG progressive income-tax formula, Splitting procedure
     4	// (§§26/26b), and Solidaritätszuschlag with Milderungszone cap.
     5	//
     6	// All figures in cents. Tax class only affects monthly withholding — it
     7	// has zero impact on the final assessed liability computed here (the
     8	// final liability under joint assessment always uses Splitting).
     9	//
    10	// Ported from src/tax/income-tax.ts. Keep numerically identical to the TS source.
    11	
    12	/// <summary>Filing status for Solidaritätszuschlag exemption lookup.</summary>
    13	public enum FilingStatus
    14	{
    15	    Single,
    16	    Joint,
    17	}
    18	
    19	/// <summary>
    20	/// Pure-math German income tax (§32a EStG), Splitting (§§26/26b), and
    21	/// Solidaritätszuschlag calculations. Ported from src/tax/income-tax.ts.
    22	/// </summary>
    23	public static class IncomeTax
    24	{
    25	    /// <summary>
    26	    /// Computes the assessed income tax (Einkommensteuer) for a single filer
    27	    /// under the §32a EStG piecewise formula for <paramref name="year"/>.
    28	    ///
    29	    /// Per the official BMF procedure, only the taxable income itself (zvE) is
    30	    /// floored to whole euros up front, and the final tax-in-euros is floored
    31	    /// before returning. The intermediate "y"/"z" multipliers are decimal
    32	    /// fractions ("ein Zehntausendstel...") and must NOT be floored to integers
    33	    /// — doing so would make tax flat across most of every 10,000-euro window
    34	    /// in zones 2 and 3 instead of rising smoothly euro by euro.
    35	    ///
    36	    /// Returns the result in cents.
    37	    /// </summary>
    38	    public static long CalculateIncomeTax(long zveCents, int year)
    39	    {
    40	        if (!TaxConstants.TaxBracketsByYear.TryGetValue(year, out var bracket))
    41	        {
    42	            throw new ArgumentException($"CalculateIncomeTax: no bracket data for year {year}");
    43	        }
    44	
    45	        // Floor taxable income to whole euros (BMF procedure step 1).
    46	        var x = FloorDiv100(zveCents);
    47	
    48	        // Zone 1: 0 .. Grundfreibetrag — tax = 0.
    49	        var zone1Upper = FloorDiv100(bracket.GrundfreibetragCents);
    50	        if (x <= zone1Upper) return 0;
    51	
    52	        // Zone 2: (grundfreibetrag+1) .. zone2Upper
    53	        // "y" is one ten-thousandth of the income above Grundfreibetrag — a
    54	        // decimal fraction (§32a EStG: "y ist ein Zehntausendstel des den
    55	        // Grundfreibetrag übersteigenden Teils..."), NOT floored to an integer.
    56	        // Only x (the income itself) is floored to whole euros; the final tax
    57	        // is floored to whole euros below.
    58	        var zone2Upper = FloorDiv100(bracket.Zone2UpperCents);
    59	        if (x <= zone2Upper)
    60	        {
    61	            var y = (x - zone1Upper) / 10000.0;
    62	            var taxEur = (bracket.Zone2YCoefficientCents / 100.0) * y + bracket.Zone2LinearConstant;
    63	            return (long)Math.Floor(taxEur * y) * 100;
    64	        }
    65	
    66	        // Zone 3: zone3Lower .. zone3Upper — "z" is likewise a decimal fraction.
    67	        var zone3Upper = FloorDiv100(bracket.Zone3UpperCents);
    68	        if (x <= zone3Upper)
    69	        {
    70	            var z = (x - (FloorDiv100(bracket.Zone3LowerCents) - 1)) / 10000.0;
    71	            var taxEur = (bracket.Zone3ZCoefficientCents / 100.0) * z + bracket.Zone3LinearConstant;
    72	            return (long)Math.Floor(taxEur * z + bracket.Zone3ZAddendCents / 100.0) * 100;
    73	        }
    74	
    75	        // Zone 4: (zone3Upper+1) .. zone5Lower-1 — 42% marginal.
    76	        var zone5Lower = FloorDiv100(bracket.Zone5LowerCents);
    77	        if (x < zone5Lower)
    78	        {
    79	            var taxEur = 0.42 * x - bracket.Zone4SubtrahendCents / 100.0;
    80	            return (long)Math.Floor(taxEur) * 100;
    81	        }
    82	
    83	        // Zone 5: zone5Lower .. infinity — 45% marginal (top rate / Reichensteuer).
    84	        {
    85	            var taxEur = 0.45 * x - bracket.Zone5SubtrahendCents / 100.0;
    86	            return (long)Math.Floor(taxEur) * 100;
    87	        }
    88	    }
    89	
    90	    /// <summary>
    91	    /// Computes the Grenzsteuersatz (marginal tax rate) at <paramref name="zveCents"/>:
    92	    /// the rate applied to the next euro of taxable income, as a fraction (e.g. 0.32 for
    93	    /// 32%). Derived analytically from the d(tax)/dx of each zone's formula
    94	    /// rather than a finite difference on <see cref="CalculateIncomeTax"/>, because that
    95	    /// function only returns whole-euro multiples — a 1-euro finite difference
    96	    /// would mostly read 0 inside zones 2/3 due to floor-rounding noise.
    97	    /// </summary>
    98	    public static double MarginalTaxRate(long zveCents, int year)
    99	    {
   100	        if (!TaxConstants.TaxBracketsByYear.TryGetValue(year, out var bracket))
   101	        {
   102	            throw new ArgumentException($"MarginalTaxRate: no bracket data for year {year}");
   103	        }
   104	
   105	        var x = FloorDiv100(zveCents);
   106	
   107	        var zone1Upper = FloorDiv100(bracket.GrundfreibetragCents);
   108	        if (x <= zone1Upper) return 0;
   109	
   110	        var zone2Upper = FloorDiv100(bracket.Zone2UpperCents);
   111	        if (x <= zone2Upper)
   112	        {
   113	            var y = (x - zone1Upper) / 10000.0;
   114	            return (2 * (bracket.Zone2YCoefficientCents / 100.0) * y + bracket.Zone2LinearConstant) / 10000.0;
   115	        }
   116	
   117	        var zone3Upper = FloorDiv100(bracket.Zone3UpperCents);
   118	        if (x <= zone3Upper)
   119	        {
   120	            var z = (x - (FloorDiv100(bracket.Zone3LowerCents) - 1)) / 10000.0;
   121	            return (2 * (bracket.Zone3ZCoefficientCents / 100.0) * z + bracket.Zone3LinearConstant) / 10000.0;
   122	        }
   123	
   124	        var zone5Lower = FloorDiv100(bracket.Zone5LowerCents);
   125	        if (x < zone5Lower) return 0.42;
   126	
   127	        return 0.45;
   128	    }
   129	
   130	    /// <summary>
   131	    /// Computes the assessed tax under joint filing (Zusammenveranlagung /
   132	    /// Splittingtarif, §§26/26b EStG):
   133	    ///
   134	    ///   tax = 2 × CalculateIncomeTax(floor((zvEA + zvEB) / 2), year)
   135	    ///
   136	    /// Returns the result in cents.
   137	    /// </summary>
   138	    public static long CalculateSplittingTax(long zveACents, long zveBCents, int year)
   139	    {
   140	        var combined = zveACents + zveBCents;
   141	        var half = FloorDivBy2(combined);
   142	        return 2 * CalculateIncomeTax(half, year);
   143	    }
   144	
   145	    /// <summary>
   146	    /// Computes the Solidaritätszuschlag for a given assessed income tax.
   147	    ///
   148	    /// Soli = 5.5% of assessed tax, but:
   149	    ///   - Zero if assessedTaxCents &lt;= FreigrenzeCents (exemption threshold).
   150	    ///   - Capped by the Milderungszone: Soli must not exceed
   151	    ///     11.9% of (assessedTaxCents − FreigrenzeCents), i.e. the excess
   152	    ///     over the exemption. This creates a smooth phase-in (no cliff).
   153	    ///
   154	    /// Returns the result in cents. Note: despite cent-denominated inputs, the
   155	    /// flooring here operates directly on the cents value (assessedTaxCents * 0.055,
   156	    /// then floored) — i.e. the result is floored to whole cents, not whole euros.
   157	    /// This matches the TS source exactly (no /100 or *100 rescaling occurs).
   158	    /// </summary>
   159	    public static long CalculateSolidaritySurcharge(long assessedTaxCents, int year, FilingStatus filingStatus)
   160	    {
   161	        if (!TaxConstants.SoliExemptionByYear.TryGetValue(year, out var soli))
   162	        {
   163	            throw new ArgumentException($"CalculateSolidaritySurcharge: no Soli data for year {year}");
   164	        }
   165	
   166	        var exemptionCents = filingStatus == FilingStatus.Joint ? soli.JointCents : soli.SingleCents;
   167	
   168	        if (assessedTaxCents <= exemptionCents) return 0;
   169	
   170	        var baseSoliCents = (long)Math.Floor(assessedTaxCents * 0.055);
   171	        var capCents = (long)Math.Floor((assessedTaxCents - exemptionCents) * 0.119);
   172	
   173	        return Math.Min(baseSoliCents, capCents);
   174	    }
   175	
   176	    /// <summary>
   177	    /// Floors a cents value down to whole euros, returned as whole euros
   178	    /// (matches JS <c>Math.floor(cents / 100)</c>, including for negative inputs
   179	    /// where C#'s integer division truncates toward zero instead of flooring).
   180	    /// </summary>
   181	    private static long FloorDiv100(long cents) =>
   182	        (long)Math.Floor(cents / 100.0);
   183	
   184	    /// <summary>
   185	    /// Floors a value divided by 2 (matches JS <c>Math.floor(combined / 2)</c>,
   186	    /// including for negative inputs).
   187	    /// </summary>
   188	    private static long FloorDivBy2(long value) =>
   189	        (long)Math.Floor(value / 2.0);
   190	}
