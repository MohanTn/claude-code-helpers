     1	// Phase 2: Seed categorization rules (PRD Section 8.7, Section 4 M2/M3).
     2	//
     3	// Rules are evaluated in ascending `priority` order, first match wins.
     4	// Priority bands (gaps left intentionally for future insertion):
     5	//   10-99   Internal Transfer detection (HIGHEST priority — must win over
     6	//           generic merchant rules, e.g. a Trade Republic "Handel" sell-trade
     7	//           transfer must not be caught by an Investments keyword rule first).
     8	//   100-799 Category-specific merchant/keyword rules.
     9	//   999     Terminal default -> Other.
    10	//
    11	// `contains` patterns are matched case-insensitively against `description`.
    12	// `regex` patterns are compiled with the `i` flag.
    13	
    14	import type { CategoryRule } from './types.js';
