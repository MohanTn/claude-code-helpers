// Phase 3: End-to-end import pipeline (PRD 8.2, Section 9 Phase 3).
//
// parse (Phase 1) -> categorize (Phase 2) -> dedup-check via source_hash ->
// insert -> extract+store balance snapshot -> cross-account Internal
// Transfer matching pass (Phase 2) over all DB rows.

import path from 'node:path';
import { readdirSync } from 'node:fs';
import type Database from 'better-sqlite3';
import { sha256 } from '../parsers/normalize.js';
import {
  parseCommerzbank,
  parseWise,
  parseTradeRepublic,
  parseTfBank,
  type ParseResult,
} from '../parsers/index.js';
import {
  categorize,
  categorizeAll,
  matchInternalTransfers,
  SEED_RULES,
  type CategoryRule,
  type AccountTaggedTransaction,
} from '../rules/index.js';
import {
  getAccountByName,
  getAllCategoryRules,
  seedCategoryRulesIfEmpty,
  insertTransaction,
  upsertBalanceSnapshot,
  updateTransactionCategory,
} from '../db/index.js';

/** Normalize raw text (trim, collapse whitespace) then SHA256 it for dedup. */
export function computeSourceHash(rawText: string): string {
  const normalized = rawText.trim().replace(/\s+/g, ' ');
  return sha256(normalized);
}

export interface ImportSummary {
  imported: number;
  duplicates: number;
}

/**
 * Imports a single parsed statement (`parseResult`) for the account named
 * `accountName` into `db`. The account must already exist (seeded by
 * `migrate`).
 *
 * For each transaction: categorize, compute `source_hash` from `raw_text`,
 * and insert (deduped via `UNIQUE(source_pdf, source_hash)`). If
 * `parseResult.balanceSnapshot` is present, upsert it.
 */
export function importStatement(
  db: Database.Database,
  accountName: string,
  pdfPath: string,
  parseResult: ParseResult,
  rules: CategoryRule[]
): ImportSummary {
  const account = getAccountByName(db, accountName);
  if (!account) {
    throw new Error(`importStatement: account "${accountName}" not found (run migration first)`);
  }

  const categorized = categorizeAll(parseResult.transactions, rules);

  let imported = 0;
  let duplicates = 0;

  for (const txn of categorized) {
    const sourceHash = computeSourceHash(txn.raw_text);
    const { inserted } = insertTransaction(db, account.id, txn, sourceHash);
    if (inserted) {
      imported++;
    } else {
      duplicates++;
    }
  }

  if (parseResult.balanceSnapshot) {
    upsertBalanceSnapshot(db, account.id, parseResult.balanceSnapshot, path.basename(pdfPath));
  }

  return { imported, duplicates };
}

export interface FullImportSummary {
  perAccount: Record<string, ImportSummary>;
  crossAccountMatches: number;
}

interface TaggedRow extends AccountTaggedTransaction {
  id: number;
}

/** All transactions in `db` not under manual override, tagged with `id` and `account_id`. */
function getAllTransactionsTagged(db: Database.Database): TaggedRow[] {
  return db.prepare(`
    SELECT id, account_id, date, description, amount_cents, currency, category, raw_text, source_pdf
    FROM transactions
    WHERE is_manual_override = 0
  `).all() as TaggedRow[];
}

/**
 * Orchestrates importing all 4 real statement types from `docs/` (resolved
 * relative to `process.cwd()`, i.e. the repo root), then runs the
 * cross-account Internal Transfer matching pass over all non-manual-override
 * transactions currently in the DB.
 *
 * Seeds `category_rules` with `SEED_RULES` (Phase 2) if the table is empty.
 */
export function runFullImport(db: Database.Database): FullImportSummary {
  seedCategoryRulesIfEmpty(db, SEED_RULES);
  const rules = getAllCategoryRules(db);

  const docsDir = path.resolve(process.cwd(), 'docs');
  const perAccount: Record<string, ImportSummary> = {};

  const commerzbankPath = path.join(docsDir, 'bank-transaction.pdf');
  perAccount['Commerzbank GiroKonto'] = importStatement(
    db,
    'Commerzbank GiroKonto',
    commerzbankPath,
    parseCommerzbank(commerzbankPath),
    rules
  );

  const wisePath = path.join(docsDir, 'wise-bank-statement-2025.pdf');
  perAccount['Wise EUR'] = importStatement(
    db,
    'Wise EUR',
    wisePath,
    parseWise(wisePath),
    rules
  );

  const trPath = path.join(docsDir, 'trade-republic-account-statement-2025.pdf');
  perAccount['Trade Republic Cashkonto'] = importStatement(
    db,
    'Trade Republic Cashkonto',
    trPath,
    parseTradeRepublic(trPath),
    rules
  );

  const ccDir = path.join(docsDir, 'credit_card');
  const ccFiles = readdirSync(ccDir).filter((f) => f.endsWith('.pdf')).sort();

  let tfBankImported = 0;
  let tfBankDuplicates = 0;
  for (const file of ccFiles) {
    const ccPath = path.join(ccDir, file);
    const result = importStatement(db, 'TF Bank Mastercard Gold', ccPath, parseTfBank(ccPath), rules);
    tfBankImported += result.imported;
    tfBankDuplicates += result.duplicates;
  }
  perAccount['TF Bank Mastercard Gold'] = { imported: tfBankImported, duplicates: tfBankDuplicates };

  // Cross-account Internal Transfer matching pass over all non-manual-override
  // transactions currently in the DB.
  const tagged = getAllTransactionsTagged(db);
  const matched = matchInternalTransfers(tagged);

  let crossAccountMatches = 0;
  for (let i = 0; i < tagged.length; i++) {
    if (tagged[i].category !== 'Internal Transfer' && matched[i].category === 'Internal Transfer') {
      updateTransactionCategory(db, tagged[i].id, 'Internal Transfer');
      crossAccountMatches++;
    }
  }

  return { perAccount, crossAccountMatches };
}

/**
 * Re-runs `categorize()` for every transaction WHERE `is_manual_override = 0`
 * and updates the row if the category changed. Transactions with
 * `is_manual_override = 1` are skipped entirely (PRD S1).
 */
export function recategorizeAll(db: Database.Database, rules: CategoryRule[]): number {
  const rows = db.prepare(`
    SELECT id, description, category, is_manual_override
    FROM transactions
    WHERE is_manual_override = 0
  `).all() as Array<{ id: number; description: string; category: string; is_manual_override: number }>;

  let updated = 0;
  for (const row of rows) {
    // `categorize()` only reads `match_field` ('description' in v1), so a
    // minimal stand-in object is sufficient here.
    const newCategory = categorize({ description: row.description } as Parameters<typeof categorize>[0], rules);
    if (newCategory !== row.category) {
      updateTransactionCategory(db, row.id, newCategory);
      updated++;
    }
  }
  return updated;
}
