     1	import Database from 'better-sqlite3';
     2	import { resolve } from 'path';
     3	import { mkdirSync } from 'fs';
     4	import { SEED_RULES } from '../rules/index.js';
     5	
     6	const DB_PATH = resolve(process.cwd(), 'data', 'finance.db');
     7	
     8	const SCHEMA = `
     9	CREATE TABLE IF NOT EXISTS accounts (
    10	  id INTEGER PRIMARY KEY,
    11	  name TEXT NOT NULL,
    12	  institution TEXT NOT NULL,
    13	  type TEXT NOT NULL,
    14	  currency TEXT NOT NULL DEFAULT 'EUR',
    15	  is_credit_card INTEGER NOT NULL DEFAULT 0,
    16	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    17	  UNIQUE(name, institution)
    18	);
    19	
    20	CREATE TABLE IF NOT EXISTS transactions (
    21	  id INTEGER PRIMARY KEY,
    22	  account_id INTEGER NOT NULL REFERENCES accounts(id),
    23	  date TEXT NOT NULL,
    24	  description TEXT NOT NULL,
    25	  amount_cents INTEGER NOT NULL,
    26	  currency TEXT NOT NULL DEFAULT 'EUR',
    27	  category TEXT NOT NULL DEFAULT 'Other',
    28	  is_manual_override INTEGER NOT NULL DEFAULT 0,
    29	  raw_text TEXT NOT NULL,
    30	  source_pdf TEXT NOT NULL,
    31	  source_hash TEXT NOT NULL,
    32	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    33	  UNIQUE(source_pdf, source_hash)
    34	);
    35	
    36	CREATE INDEX IF NOT EXISTS idx_transactions_account_date ON transactions(account_id, date);
    37	CREATE INDEX IF NOT EXISTS idx_transactions_category ON transactions(category);
    38	
    39	CREATE TABLE IF NOT EXISTS balance_snapshots (
    40	  id INTEGER PRIMARY KEY,
    41	  account_id INTEGER NOT NULL REFERENCES accounts(id),
    42	  date TEXT NOT NULL,
    43	  balance_cents INTEGER NOT NULL,
    44	  currency TEXT NOT NULL DEFAULT 'EUR',
    45	  fx_rate_to_eur REAL,
    46	  source_pdf TEXT NOT NULL,
    47	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    48	  UNIQUE(account_id, date)
    49	);
    50	
    51	CREATE TABLE IF NOT EXISTS category_rules (
    52	  id INTEGER PRIMARY KEY,
    53	  priority INTEGER NOT NULL UNIQUE,
    54	  match_field TEXT NOT NULL DEFAULT 'description',
    55	  match_type TEXT NOT NULL,
    56	  match_pattern TEXT,
    57	  target_category TEXT NOT NULL,
    58	  created_at TEXT DEFAULT CURRENT_TIMESTAMP
    59	);
    60	
    61	CREATE TABLE IF NOT EXISTS properties (
    62	  id INTEGER PRIMARY KEY,
    63	  name TEXT NOT NULL,
    64	  address TEXT,
    65	  purchase_price_cents INTEGER NOT NULL,
    66	  purchase_date TEXT NOT NULL,
    67	  grunderwerbsteuer_cents INTEGER NOT NULL DEFAULT 0,
    68	  notarkosten_cents INTEGER NOT NULL DEFAULT 0,
    69	  maklergebuehr_cents INTEGER NOT NULL DEFAULT 0,
    70	  grundbuchkosten_cents INTEGER NOT NULL DEFAULT 0,
    71	  estimated_value_cents INTEGER,
    72	  estimated_value_date TEXT,
    73	  created_at TEXT DEFAULT CURRENT_TIMESTAMP
    74	);
    75	
    76	CREATE TABLE IF NOT EXISTS mortgages (
    77	  id INTEGER PRIMARY KEY,
    78	  property_id INTEGER NOT NULL REFERENCES properties(id),
    79	  bank_name TEXT NOT NULL,
    80	  loan_amount_cents INTEGER NOT NULL,
    81	  start_date TEXT NOT NULL,
    82	  interest_rate REAL NOT NULL,
    83	  monthly_payment_cents INTEGER NOT NULL,
    84	  outstanding_balance_cents INTEGER NOT NULL,
    85	  balance_as_of TEXT,
    86	  created_at TEXT DEFAULT CURRENT_TIMESTAMP
    87	);
    88	
    89	CREATE TABLE IF NOT EXISTS property_transactions (
    90	  id INTEGER PRIMARY KEY,
    91	  property_id INTEGER NOT NULL REFERENCES properties(id),
    92	  date TEXT NOT NULL,
    93	  type TEXT NOT NULL,
    94	  amount_cents INTEGER NOT NULL,
    95	  description TEXT,
    96	  created_at TEXT DEFAULT CURRENT_TIMESTAMP
    97	);
    98	CREATE INDEX IF NOT EXISTS idx_property_txn_property_date ON property_transactions(property_id, date);
    99	
   100	CREATE TABLE IF NOT EXISTS holdings (
   101	  id INTEGER PRIMARY KEY,
   102	  symbol TEXT NOT NULL,
   103	  isin TEXT,
   104	  name TEXT,
   105	  shares REAL NOT NULL,
   106	  avg_cost_per_share_cents INTEGER NOT NULL,
   107	  currency TEXT NOT NULL DEFAULT 'EUR',
   108	  last_price_cents INTEGER,
   109	  last_price_date TEXT,
   110	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
   111	  UNIQUE(symbol)
   112	);
   113	
   114	CREATE TABLE IF NOT EXISTS property_cost_links (
   115	  id INTEGER PRIMARY KEY,
   116	  property_id INTEGER NOT NULL REFERENCES properties(id),
   117	  cost_type TEXT NOT NULL,
   118	  transaction_id INTEGER NOT NULL REFERENCES transactions(id),
   119	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
   120	  UNIQUE(property_id, cost_type, transaction_id)
   121	);
   122	
   123	CREATE TABLE IF NOT EXISTS tax_filers (
   124	  id INTEGER PRIMARY KEY,
   125	  name TEXT NOT NULL,
   126	  role TEXT NOT NULL,                 -- 'employee' | 'freelancer'
   127	  tax_id TEXT,                        -- 11-digit Steuerliche Identifikationsnummer
   128	  employer_name TEXT,
   129	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
   130	  UNIQUE(name)
   131	);
   132	
   133	CREATE TABLE IF NOT EXISTS payslips (
   134	  id INTEGER PRIMARY KEY,
   135	  filer_id INTEGER NOT NULL REFERENCES tax_filers(id),
   136	  year INTEGER NOT NULL,
   137	  month INTEGER NOT NULL,
   138	  tax_class TEXT,                     -- raw string e.g. '3' or '3/0.0/A'
   139	  employer_name TEXT,
   140	  gross_cents INTEGER NOT NULL,
   141	  income_tax_cents INTEGER NOT NULL DEFAULT 0,
   142	  church_tax_cents INTEGER NOT NULL DEFAULT 0,
   143	  solidarity_surcharge_cents INTEGER NOT NULL DEFAULT 0,
   144	  pension_cents INTEGER NOT NULL DEFAULT 0,
   145	  unemployment_cents INTEGER NOT NULL DEFAULT 0,
   146	  health_cents INTEGER NOT NULL DEFAULT 0,
   147	  care_cents INTEGER NOT NULL DEFAULT 0,
   148	  net_cents INTEGER NOT NULL,
   149	  payout_cents INTEGER NOT NULL,
   150	  is_correction INTEGER NOT NULL DEFAULT 0,
   151	  source_format TEXT NOT NULL,        -- 'datev' | 'infoniqa'
   152	  source_pdf TEXT NOT NULL,
   153	  issue_date TEXT,
   154	  raw_text TEXT NOT NULL,
   155	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
   156	  UNIQUE(filer_id, year, month)
   157	);
   158	CREATE INDEX IF NOT EXISTS idx_payslips_filer_year ON payslips(filer_id, year);
   159	
   160	CREATE TABLE IF NOT EXISTS freelance_income (
   161	  id INTEGER PRIMARY KEY,
   162	  filer_id INTEGER NOT NULL REFERENCES tax_filers(id),
   163	  year INTEGER NOT NULL,
   164	  revenue_cents INTEGER NOT NULL DEFAULT 0,
   165	  business_expenses_cents INTEGER NOT NULL DEFAULT 0,
   166	  advance_tax_paid_cents INTEGER NOT NULL DEFAULT 0,
   167	  health_insurance_cents INTEGER NOT NULL DEFAULT 0,
   168	  pension_insurance_cents INTEGER NOT NULL DEFAULT 0,
   169	  notes TEXT,
   170	  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
   171	  UNIQUE(filer_id, year)
   172	);
   173	
   174	CREATE TABLE IF NOT EXISTS tax_filing_settings (
   175	  year INTEGER PRIMARY KEY,
   176	  filing_status TEXT NOT NULL DEFAULT 'joint',  -- 'joint' | 'single'
   177	  bundesland TEXT,
   178	  church_tax_member_filer_ids TEXT,             -- JSON array, e.g. '[1]'
   179	  created_at TEXT DEFAULT CURRENT_TIMESTAMP
   180	);
   181	`;
   182	
   183	interface Account {
   184	  name: string;
   185	  institution: string;
   186	  type: string;
   187	}
   188	
   189	const SEED_ACCOUNTS: Account[] = [
   190	  { name: 'Commerzbank GiroKonto', institution: 'Commerzbank', type: 'asset' },
   191	  { name: 'Wise EUR', institution: 'Wise', type: 'asset' },
   192	  { name: 'Trade Republic Cashkonto', institution: 'Trade Republic', type: 'asset' },
   193	  { name: 'TF Bank Mastercard Gold', institution: 'TF Bank', type: 'liability' },
   194	];
   195	
   196	async function migrate() {
   197	  try {
   198	    // Ensure data directory exists
   199	    const dataDir = resolve(process.cwd(), 'data');
   200	    mkdirSync(dataDir, { recursive: true });
   201	
   202	    // Create or open database
   203	    const db = new Database(DB_PATH);
   204	
   205	    // Execute schema
   206	    db.exec(SCHEMA);
   207	
   208	    // ── Migration: fix property_cost_links UNIQUE constraint ──────────
   209	    // The original table had UNIQUE(property_id, cost_type) which prevents
   210	    // multiple transactions per cost type.  The correct constraint is
   211	    // UNIQUE(property_id, cost_type, transaction_id).  SQLite cannot ALTER
   212	    // constraints, so we recreate the table (idempotent — safe to re-run).
   213	    const pclExists = db.prepare(
   214	      "SELECT count(*) as c FROM sqlite_master WHERE type='table' AND name='property_cost_links'"
   215	    ).get() as any;
   216	    if (pclExists?.c > 0) {
   217	      // Check how many columns are in the table's UNIQUE constraint by
   218	      // counting unique-index columns.  Old: 2 (property_id, cost_type).  New: 3 (+transaction_id).
   219	      const autoIndex = db.prepare(
   220	        "SELECT name FROM sqlite_master WHERE type='index' AND tbl_name='property_cost_links' AND sql IS NULL"
   221	      ).get() as any;
   222	      if (autoIndex) {
   223	        const colCount = (db.prepare(
   224	          'SELECT count(*) as c FROM pragma_index_info(?)'
   225	        ).get(autoIndex.name) as any)?.c ?? 0;
   226	        if (colCount === 2) {
   227	          // Still has the old 2-column constraint — recreate with 3-column
   228	          db.exec(`
   229	            CREATE TABLE property_cost_links_new (
   230	              id INTEGER PRIMARY KEY,
   231	              property_id INTEGER NOT NULL REFERENCES properties(id),
   232	              cost_type TEXT NOT NULL,
   233	              transaction_id INTEGER NOT NULL REFERENCES transactions(id),
   234	              created_at TEXT DEFAULT CURRENT_TIMESTAMP,
   235	              UNIQUE(property_id, cost_type, transaction_id)
   236	            );
   237	            INSERT INTO property_cost_links_new (id, property_id, cost_type, transaction_id, created_at)
   238	              SELECT id, property_id, cost_type, transaction_id, created_at FROM property_cost_links;
   239	            DROP TABLE property_cost_links;
   240	            ALTER TABLE property_cost_links_new RENAME TO property_cost_links;
   241	          `);
   242	          console.log('✓ Migrated property_cost_links: UNIQUE(property_id, cost_type) → UNIQUE(property_id, cost_type, transaction_id)');
   243	        }
   244	      }
   245	    }
   246	
   247	    // ── Migration: add properties table columns for Income Tax feature ────
   248	    // schema.sql includes building_completion_year and land_value_cents in
   249	    // the fresh CREATE TABLE, but the embedded SCHEMA string's CREATE TABLE
   250	    // IF NOT EXISTS is a no-op against the real existing data/finance.db.
   251	    // Instead, we must use runtime ALTER TABLE to add missing columns.
   252	    const propExists = db.prepare(
   253	      "SELECT count(*) as c FROM sqlite_master WHERE type='table' AND name='properties'"
   254	    ).get() as any;
   255	    if (propExists?.c > 0) {
   256	      const propColumns = db.prepare('PRAGMA table_info(properties)').all() as Array<any>;
   257	      const propColumnNames = new Set(propColumns.map((col: any) => col.name));
   258	      const columnsToAdd = [];
   259	
   260	      if (!propColumnNames.has('building_completion_year')) {
   261	        db.prepare('ALTER TABLE properties ADD COLUMN building_completion_year INTEGER').run();
   262	        columnsToAdd.push('building_completion_year');
   263	      }
   264	      if (!propColumnNames.has('land_value_cents')) {
   265	        db.prepare('ALTER TABLE properties ADD COLUMN land_value_cents INTEGER NOT NULL DEFAULT 0').run();
   266	        columnsToAdd.push('land_value_cents');
   267	      }
   268	
   269	      if (columnsToAdd.length > 0) {
   270	        console.log(`✓ Migrated properties: added ${columnsToAdd.join(', ')} column(s)`);
   271	      }
   272	    }
   273	
   274	    // Seed accounts (idempotent via INSERT OR IGNORE)
   275	    const insertAccount = db.prepare(`
   276	      INSERT OR IGNORE INTO accounts (name, institution, type, currency, is_credit_card)
   277	      VALUES (?, ?, ?, 'EUR', ?)
   278	    `);
   279	
   280	    for (const account of SEED_ACCOUNTS) {
   281	      const isLiability = account.type === 'liability' ? 1 : 0;
   282	      insertAccount.run(account.name, account.institution, account.type, isLiability);
   283	    }
   284	
   285	    // Seed default category rule (idempotent via INSERT OR IGNORE on UNIQUE(priority))
   286	    const ruleCount = db.prepare('SELECT COUNT(*) as count FROM category_rules').get() as { count: number };
   287	
   288	    if (ruleCount.count === 0) {
   289	      const insertRule = db.prepare(`
   290	        INSERT OR IGNORE INTO category_rules (priority, match_field, match_type, match_pattern, target_category)
   291	        VALUES (?, ?, ?, ?, ?)
   292	      `);
   293	
   294	      for (const rule of SEED_RULES) {
   295	        insertRule.run(rule.priority, rule.match_field, rule.match_type, rule.match_pattern, rule.target_category);
   296	      }
   297	    }
   298	
   299	    db.close();
   300	
   301	    console.log(`✓ Migration complete. Database: ${DB_PATH}`);
   302	    console.log(`✓ Tables created: accounts, transactions, balance_snapshots, category_rules, properties, mortgages, property_transactions, holdings, property_cost_links, tax_filers, payslips, freelance_income, tax_filing_settings`);
   303	    console.log(`✓ Seeded ${SEED_ACCOUNTS.length} accounts`);
   304	    console.log(`✓ Seeded ${SEED_RULES.length} category rule(s)`);
   305	
   306	  } catch (error) {
   307	    console.error('Migration failed:', error);
   308	    process.exit(1);
   309	  }
   310	}
   311	
   312	migrate();
