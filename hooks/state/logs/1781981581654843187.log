     1	namespace FinanceAnalyser.Core.Models;
     2	
     3	/// <summary>A single normalized transaction extracted from a statement PDF. Ported from src/parsers/types.ts.</summary>
     4	public record ParsedTransaction(
     5	    string Date,
     6	    string Description,
     7	    long AmountCents,
     8	    string Currency,
     9	    string RawText,
    10	    string SourcePdf);
    11	
    12	/// <summary>A balance snapshot derived from a statement's printed closing balance.</summary>
    13	public record BalanceSnapshot(string Date, long BalanceCents);
    14	
    15	/// <summary>Result of parsing a single statement PDF.</summary>
    16	public record ParseResult(List<ParsedTransaction> Transactions, BalanceSnapshot? BalanceSnapshot);
    17	
    18	/// <summary>A categorization rule, matching the category_rules table schema. Ported from src/rules/types.ts.</summary>
    19	public record CategoryRule(
    20	    int? Id,
    21	    int Priority,
    22	    string MatchField,
    23	    string MatchType,
    24	    string? MatchPattern,
    25	    string TargetCategory);
    26	
    27	/// <summary>A transaction after the rule engine has assigned a category.</summary>
    28	public record CategorizedTransaction(
    29	    string Date,
    30	    string Description,
    31	    long AmountCents,
    32	    string Currency,
    33	    string RawText,
    34	    string SourcePdf,
    35	    string Category) : ParsedTransaction(Date, Description, AmountCents, Currency, RawText, SourcePdf);
    36	
    37	/// <summary>A categorized transaction tagged with the account it was imported from. Ported from internal-transfer-matcher.ts.</summary>
    38	public record AccountTaggedTransaction(
    39	    string Date,
    40	    string Description,
    41	    long AmountCents,
    42	    string Currency,
    43	    string RawText,
    44	    string SourcePdf,
    45	    string Category,
    46	    long AccountId) : CategorizedTransaction(Date, Description, AmountCents, Currency, RawText, SourcePdf, Category);
---PAYSLIPS---
