---SEEDRULES---
     1	using FinanceAnalyser.Core.Models;
     2	
     3	namespace FinanceAnalyser.Core.Rules;
     4	
     5	/// <summary>
     6	/// Seed categorization rules. Ported verbatim from src/rules/seed-rules.ts.
     7	///
     8	/// Rules are evaluated in ascending Priority order, first match wins.
     9	/// Priority bands (gaps left intentionally for future insertion):
    10	///   10-99   Internal Transfer detection (HIGHEST priority — must win over
    11	///           generic merchant rules, e.g. a Trade Republic "Handel" sell-trade
    12	///           transfer must not be caught by an Investments keyword rule first).
    13	///   100-799 Category-specific merchant/keyword rules.
    14	///   999     Terminal default -> Other.
    15	///
    16	/// 'contains' patterns are matched case-insensitively against Description.
    17	/// 'regex' patterns are compiled with case-insensitive matching.
    18	/// </summary>
    19	public static class SeedRules
    20	{
    21	    public static readonly List<CategoryRule> All = new()
    22	    {
    23	        // ===========================================================================
    24	        // 10-99: Internal Transfer detection (PRD Section 4 M3 confirmed pairs)
    25	        // ===========================================================================
    26	
    27	        // Commerzbank <-> Wise (Mohan's own Wise account, "Mohan Wise TRWIBEB1XXX ...")
    28	        new CategoryRule(null, 10, "description", "regex", "mohan wise", "Internal Transfer"),
    29	
    30	        // Commerzbank <-> Trade Republic (Mohan's own Trade Republic account)
    31	        new CategoryRule(null, 11, "description", "regex", "traderepublic mohan", "Internal Transfer"),
    32	
    33	        // Commerzbank <-> TF Bank credit card repayments
    34	        new CategoryRule(null, 12, "description", "regex", "tf bank (credit card|ab)", "Internal Transfer"),
    35	
    36	        // Commerzbank: Mohan sending money from Wise back to Commerzbank
    37	        new CategoryRule(null, 13, "description", "regex", "mohan talkad nagaraju moving money to commerzbank", "Internal Transfer"),
    38	
    39	        // Commerzbank: bare self-transfer with no other distinguishing transfer keyword
    40	        // (e.g. "Mohan Talkad Nagaraju End-To-End Reference: 2885fddced...")
    41	        new CategoryRule(null, 14, "description", "regex", "^mohan talkad nagaraju end-to-end", "Internal Transfer"),
    42	
    43	        // Wise: incoming top-ups / transfers from Mohan's own Commerzbank account
    44	        new CategoryRule(null, 15, "description", "regex", "received money from mohan talkad nagaraju", "Internal Transfer"),
    45	
    46	        // Wise: outgoing transfers to Mohan's own Commerzbank account
    47	        new CategoryRule(null, 16, "description", "regex", "sent money to mohan talkad nagaraju", "Internal Transfer"),
    48	
    49	        // Wise: Mohan paying his own TF Bank credit card
    50	        new CategoryRule(null, 17, "description", "regex", "sent money to tf bank credit card", "Internal Transfer"),
    51	
    52	        // Wise: account top-ups (funding from Mohan's own Commerzbank account)
    53	        new CategoryRule(null, 18, "description", "regex", "topped up account", "Internal Transfer"),
    54	
    55	        // Wise: currency conversion of Mohan's own balance (still his own money, just FX)
    56	        new CategoryRule(null, 19, "description", "regex", "converted .* eur to .* (inr|usd)", "Internal Transfer"),
    57	
    58	        // Trade Republic: outgoing transfers to Mohan's own accounts
    59	        new CategoryRule(null, 20, "description", "regex", "überweisung outgoing transfer for mohan talkad nagaraju", "Internal Transfer"),
    60	
    61	        // Trade Republic: incoming transfers from Mohan's own accounts
    62	        new CategoryRule(null, 21, "description", "regex", "überweisung incoming transfer from mohan talkad nagaraju", "Internal Transfer"),
    63	
    64	        // TF Bank: credit card repayments funded from Wise ("Bezahlung Zahlung ...")
    65	        new CategoryRule(null, 22, "description", "regex", "bezahlung zahlung", "Internal Transfer"),
    66	
    67	        // ===========================================================================
    68	        // 100-199: Income
    69	        // ===========================================================================
    70	
    71	        // Salary (Commerzbank: "LOHN / GEHALT", "Lohn/Gehalt")
    72	        new CategoryRule(null, 100, "description", "regex", @"lohn\s*/\s*gehalt", "Income"),
    73	
    74	        // DUNNHUMBY small recurring credits (employer entity reimbursements)
    75	        new CategoryRule(null, 101, "description", "contains", "DUNNHUMBY", "Income"),
    76	
    77	        // CHECK24 cashback
    78	        new CategoryRule(null, 102, "description", "contains", "CHECK24", "Income"),
    79	
    80	        // Incoming PayPal instant transfer (Commerzbank)
    81	        new CategoryRule(null, 103, "description", "regex", "paypal instant transfer", "Income"),
    82	
    83	        // Wise card cashback rewards
    84	        new CategoryRule(null, 104, "description", "regex", "balance_cashback", "Income"),
    85	
    86	        // ===========================================================================
    87	        // 105-109: Property acquisition (higher than Rent/Housing so purchase-contract
    88	        //          payments beat generic "Poppe Immobilien" rule at 112)
    89	        // ===========================================================================
    90	
    91	        // Purchase contract / notary fees — "Kaufvertrag" in description
    92	        new CategoryRule(null, 105, "description", "contains", "Kaufvertrag", "Investments"),
    93	
    94	        // Property purchase price instalments — "Restkaufpreis" or "UVZ-Nr"
    95	        // (UVZ = Urkundenverzeichnisnummer, the German notarial deed reference)
    96	        new CategoryRule(null, 106, "description", "regex", @"restkaufpreis|uvz-nr\.", "Investments"),
    97	
    98	        // Mortgage loan-service charges and interest (Commerzbank direct-debit):
    99	        // "Rechnung Darl.-Leistung … Zinsen" and similar
   100	        new CategoryRule(null, 107, "description", "regex", @"darl\.?-?leistung|darlehenspreis|sicherheitentausch", "Investments"),
   101	
   102	        // ===========================================================================
   103	        // 110-199: Rent/Housing
   104	        // ===========================================================================
   105	
   106	        // Rent payments (Commerzbank: "Leda GmbH ... wohnunh/wohnung miete ...")
   107	        new CategoryRule(null, 110, "description", "regex", "leda gmbh.*wohnun", "Rent/Housing"),
   108	
   109	        // degewo housing-related refund
   110	        new CategoryRule(null, 111, "description", "contains", "degewo", "Rent/Housing"),
   111	
   112	        // Property management (ongoing fees — Kaufvertrag overridden at priority 108 below)
   113	        new CategoryRule(null, 112, "description", "contains", "Poppe Immobilien", "Rent/Housing"),
   114	
   115	        // ===========================================================================
   116	        // 120-199: Utilities
   117	        // ===========================================================================
   118	
   119	        // Electricity (SWK Energie - Strom)
   120	        new CategoryRule(null, 120, "description", "contains", "SWK ENERGIE", "Utilities"),
   121	
   122	        // Gas / electricity refunds (Vattenfall)
   123	        new CategoryRule(null, 121, "description", "contains", "VATTENFALL", "Utilities"),
   124	
   125	        // Internet/cable (PYUR)
   126	        new CategoryRule(null, 122, "description", "contains", "PYUR", "Utilities"),
   127	
   128	        // Public broadcasting fee (Rundfunk ARD, ZDF, DRadio)
   129	        new CategoryRule(null, 123, "description", "contains", "Rundfunk", "Utilities"),
   130	
   131	        // ===========================================================================
   132	        // 130-199: Insurance
   133	        // ===========================================================================
   134	
   135	        // Hallesche health insurance (premium and bonus payments)
   136	        new CategoryRule(null, 130, "description", "contains", "HALLESCHE", "Insurance"),
   137	
   138	        // Bayern-Versicherung life insurance
   139	        new CategoryRule(null, 131, "description", "contains", "Bayern-Versicherung", "Insurance"),
   140	
   141	        // Neodigital Versicherung (Wise)
   142	        new CategoryRule(null, 132, "description", "contains", "Neodigital Versicherung", "Insurance"),
   143	
   144	        // ===========================================================================
   145	        // 140-199: Fitness/Health
   146	        // ===========================================================================
   147	
   148	        // Gym membership (East Bank Club / The Fitness Factory)
   149	        new CategoryRule(null, 140, "description", "regex", "east bank club|fitness factory", "Fitness/Health"),
   150	
   151	        // Medical billing service
   152	        new CategoryRule(null, 141, "description", "contains", "PVS BERLIN-BRANDENBURG", "Fitness/Health"),
   153	
   154	        // Drugstore / pharmacy (TF Bank)
   155	        new CategoryRule(null, 142, "description", "regex", "dm[ -]drogerie markt|friedrich apotheke", "Fitness/Health"),
   156	
   157	        // Zumba fitness class
   158	        new CategoryRule(null, 143, "description", "contains", "ZUMBA FITNESS", "Fitness/Health"),
   159	
   160	        // ===========================================================================
   161	        // 150-199: Subscriptions
   162	        // ===========================================================================
   163	
   164	        // Mobile phone (Telefonica)
   165	        new CategoryRule(null, 150, "description", "contains", "Telefonica Germany", "Subscriptions"),
   166	
   167	        // Language school (recurring course fee)
   168	        new CategoryRule(null, 151, "description", "contains", "Europa Spracheninstitut", "Subscriptions"),
   169	
   170	        // Lebara mobile/SIM topup (via PayPal/Riverty)
   171	        new CategoryRule(null, 152, "description", "contains", "Lebara", "Subscriptions"),
   172	
   173	        // Amazon Prime subscription (Wise card transactions)
   174	        new CategoryRule(null, 153, "description", "regex", "amazon prim|amznprime", "Subscriptions"),
   175	
   176	        // Google One cloud storage
   177	        new CategoryRule(null, 154, "description", "contains", "Google One", "Subscriptions"),
   178	
   179	        // CyberGhost VPN
   180	        new CategoryRule(null, 155, "description", "contains", "CyberGhost VPN", "Subscriptions"),
   181	
   182	        // OpenRouter AI dev tool subscription
   183	        new CategoryRule(null, 156, "description", "contains", "Openrouter", "Subscriptions"),
   184	
   185	        // ===========================================================================
   186	        // 160-199: Transport
   187	        // ===========================================================================
   188	
   189	        // BVG public transport (via PayPal/Riverty, and direct BVG charges)
