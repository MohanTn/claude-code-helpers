     1	using FinanceAnalyser.Data;
     2	using FinanceAnalyser.Import;
     3	using Microsoft.AspNetCore.Mvc;
     4	using Microsoft.Data.Sqlite;
     5	
     6	namespace FinanceAnalyser.Api.Endpoints;
     7	
     8	/// <summary>
     9	/// Tax Filers, Payslips, Freelance Income, Tax Filing Settings, and Tax
    10	/// Calculation endpoints. Ported 1:1 from server.ts:1369-1645.
    11	/// </summary>
    12	public static class TaxEndpoints
    13	{
    14	    public static void MapTaxEndpoints(this WebApplication app)
    15	    {
    16	        // ─────────────────────────────────────────
    17	        // TAX FILER ENDPOINTS
    18	        // ─────────────────────────────────────────
    19	
    20	        // GET /api/tax/filers
    21	        app.MapGet("/api/tax/filers", (SqliteConnection connection) =>
    22	        {
    23	            var rows = Db.GetAllTaxFilers(connection);
    24	            return Results.Ok(new { filers = rows });
    25	        });
    26	
    27	        // POST /api/tax/filers
    28	        app.MapPost("/api/tax/filers", (SqliteConnection connection, [FromBody] CreateTaxFilerRequest body) =>
    29	        {
    30	            if (string.IsNullOrEmpty(body.Name) || string.IsNullOrEmpty(body.Role))
    31	            {
    32	                return Results.BadRequest(new { error = "Missing required fields: name, role" });
    33	            }
    34	            if (body.Role != "employee" && body.Role != "freelancer")
    35	            {
    36	                return Results.BadRequest(new { error = "role must be 'employee' or 'freelancer'" });
    37	            }
    38	
    39	            try
    40	            {
    41	                var created = Db.InsertTaxFiler(connection, body.Name, body.Role, body.TaxId, body.EmployerName);
    42	                return Results.Json(created, statusCode: 201);
    43	            }
    44	            catch (SqliteException err) when (err.Message.Contains("UNIQUE constraint failed"))
    45	            {
    46	                return Results.BadRequest(new { error = "A filer with that name already exists" });
    47	            }
    48	        });
    49	
    50	        // PATCH /api/tax/filers/:id
    51	        app.MapPatch("/api/tax/filers/{id}", (long id, SqliteConnection connection, [FromBody] UpdateTaxFilerRequest body) =>
    52	        {
    53	            var existing = Db.GetTaxFilerById(connection, id);
    54	            if (existing is null)
    55	            {
    56	                return Results.NotFound(new { error = "not found" });
    57	            }
    58	
    59	            if (body.Role is not null && body.Role != "employee" && body.Role != "freelancer")
    60	            {
    61	                return Results.BadRequest(new { error = "role must be 'employee' or 'freelancer'" });
    62	            }
    63	
    64	            try
    65	            {
    66	                var updated = Db.UpdateTaxFiler(connection, id, body.Name, body.Role, body.TaxId, body.EmployerName);
    67	                return Results.Ok(updated);
    68	            }
    69	            catch (SqliteException err) when (err.Message.Contains("UNIQUE constraint failed"))
    70	            {
    71	                return Results.BadRequest(new { error = "A filer with that name already exists" });
    72	            }
    73	        });
    74	
    75	        // ─────────────────────────────────────────
    76	        // PAYSLIP ENDPOINTS
    77	        // ─────────────────────────────────────────
    78	
    79	        // GET /api/tax/payslips?filer_id=&year=
    80	        app.MapGet("/api/tax/payslips", (SqliteConnection connection, [FromQuery] long? filer_id, [FromQuery] int? year) =>
    81	        {
    82	            var rows = Db.GetPayslips(connection, filer_id, year);
    83	            return Results.Ok(new { payslips = rows });
    84	        });
    85	
    86	        // POST /api/tax/payslips/upload — multipart payslip PDF upload.
    87	        app.MapPost("/api/tax/payslips/upload", async (HttpRequest request, SqliteConnection connection) =>
    88	        {
    89	            var form = await request.ReadFormAsync();
    90	            var file = form.Files.GetFile("file");
    91	            var filerIdRaw = form["filer_id"].ToString();
    92	
    93	            if (string.IsNullOrEmpty(filerIdRaw) || !long.TryParse(filerIdRaw, out var filerId) || file is null)
    94	            {
    95	                return Results.BadRequest(new { error = "Missing filer_id or file" });
    96	            }
    97	
    98	            var filer = Db.GetTaxFilerById(connection, filerId);
    99	            if (filer is null)
   100	            {
   101	                return Results.NotFound(new { error = "Tax filer not found" });
   102	            }
   103	
   104	            var tmpPath = Path.GetTempFileName();
   105	            var ext = Path.GetExtension(file.FileName);
   106	            if (string.IsNullOrEmpty(ext))
   107	            {
   108	                ext = ".pdf";
   109	            }
   110	            var namedPath = tmpPath + ext;
   111	            File.Move(tmpPath, namedPath);
   112	
   113	            try
   114	            {
   115	                await using (var stream = File.Create(namedPath))
   116	                {
   117	                    await file.CopyToAsync(stream);
   118	                }
   119	
   120	                try
   121	                {
   122	                    var summary = PayslipPipeline.ImportPayslipFile(connection, filerId, namedPath);
   123	                    return Results.Ok(new
   124	                    {
   125	                        imported = summary.Imported,
   126	                        updated = summary.Updated,
   127	                        skipped = summary.Skipped,
   128	                        errors = summary.Errors,
   129	                    });
   130	                }
   131	                catch (Exception parseErr)
   132	                {
   133	                    return Results.Ok(new
   134	                    {
   135	                        imported = 0,
   136	                        updated = 0,
   137	                        skipped = Array.Empty<string>(),
   138	                        errors = new[] { parseErr.Message },
   139	                    });
   140	                }
   141	            }
   142	            catch (Exception err)
   143	            {
   144	                return Results.Json(new
   145	                {
   146	                    imported = 0,
   147	                    updated = 0,
   148	                    skipped = Array.Empty<string>(),
   149	                    errors = new[] { err.Message },
   150	                }, statusCode: 500);
   151	            }
   152	            finally
   153	            {
   154	                try { File.Delete(namedPath); } catch { /* ponytail: best-effort cleanup, mirrors TS's bare try/catch */ }
   155	            }
   156	        });
   157	
   158	        // DELETE /api/tax/payslips/:id
   159	        app.MapDelete("/api/tax/payslips/{id}", (long id, SqliteConnection connection) =>
   160	        {
   161	            var deleted = Db.DeletePayslip(connection, id);
   162	            if (!deleted)
   163	            {
   164	                return Results.NotFound(new { error = "not found" });
   165	            }
   166	            return Results.Ok(new { id, deleted = true });
   167	        });
   168	
   169	        // ─────────────────────────────────────────
   170	        // FREELANCE INCOME ENDPOINTS
   171	        // ─────────────────────────────────────────
   172	
   173	        // GET /api/tax/freelance-income?filer_id=&year=
   174	        app.MapGet("/api/tax/freelance-income", (SqliteConnection connection, [FromQuery] long? filer_id, [FromQuery] int? year) =>
   175	        {
   176	            if (filer_id is null || year is null)
   177	            {
   178	                return Results.BadRequest(new { error = "Missing filer_id or year" });
   179	            }
   180	
   181	            var row = Db.GetFreelanceIncome(connection, filer_id.Value, year.Value);
   182	            return Results.Ok(new { income = (object?)row });
   183	        });
   184	
   185	        // POST /api/tax/freelance-income
   186	        app.MapPost("/api/tax/freelance-income", (SqliteConnection connection, [FromBody] CreateFreelanceIncomeRequest body) =>
   187	        {
   188	            if (body.FilerId is null || body.Year is null)
   189	            {
   190	                return Results.BadRequest(new { error = "Missing filer_id or year" });
   191	            }
   192	
   193	            try
   194	            {
   195	                var created = Db.InsertFreelanceIncome(
   196	                    connection,
   197	                    body.FilerId.Value,
   198	                    body.Year.Value,
   199	                    body.RevenueCents ?? 0,
   200	                    body.BusinessExpensesCents ?? 0,
   201	                    body.AdvanceTaxPaidCents ?? 0,
   202	                    body.HealthInsuranceCents ?? 0,
   203	                    body.PensionInsuranceCents ?? 0,
   204	                    body.Notes);
   205	                return Results.Json(created, statusCode: 201);
   206	            }
   207	            catch (SqliteException err) when (err.Message.Contains("UNIQUE constraint failed"))
   208	            {
   209	                return Results.BadRequest(new { error = "Freelance income already exists for this filer/year" });
   210	            }
   211	        });
   212	
   213	        // PATCH /api/tax/freelance-income/:id
   214	        app.MapPatch("/api/tax/freelance-income/{id}", (long id, SqliteConnection connection, [FromBody] UpdateFreelanceIncomeRequest body) =>
   215	        {
   216	            var existing = Db.GetFreelanceIncomeById(connection, id);
   217	            if (existing is null)
   218	            {
   219	                return Results.NotFound(new { error = "not found" });
   220	            }
   221	
   222	            var updated = Db.UpdateFreelanceIncome(
   223	                connection,
   224	                id,
   225	                body.RevenueCents,
   226	                body.BusinessExpensesCents,
   227	                body.AdvanceTaxPaidCents,
   228	                body.HealthInsuranceCents,
   229	                body.PensionInsuranceCents,
   230	                body.Notes);
   231	            return Results.Ok(updated);
   232	        });
   233	
   234	        // DELETE /api/tax/freelance-income/:id
   235	        app.MapDelete("/api/tax/freelance-income/{id}", (long id, SqliteConnection connection) =>
   236	        {
   237	            var deleted = Db.DeleteFreelanceIncome(connection, id);
   238	            if (!deleted)
   239	            {
   240	                return Results.NotFound(new { error = "not found" });
   241	            }
   242	            return Results.Ok(new { id, deleted = true });
   243	        });
   244	
   245	        // ─────────────────────────────────────────
   246	        // TAX FILING SETTINGS ENDPOINTS
   247	        // ─────────────────────────────────────────
   248	
   249	        // GET /api/tax/settings?year=
   250	        app.MapGet("/api/tax/settings", (SqliteConnection connection, [FromQuery] int? year) =>
   251	        {
   252	            var resolvedYear = year ?? DateTime.Now.Year;
   253	            var row = Db.GetTaxFilingSettings(connection, resolvedYear);
   254	            object settings = row ?? (object)new { year = resolvedYear, filing_status = "joint" };
   255	            return Results.Ok(new { settings });
   256	        });
   257	
   258	        // PUT /api/tax/settings
   259	        app.MapPut("/api/tax/settings", (SqliteConnection connection, [FromBody] UpsertTaxFilingSettingsRequest body) =>
   260	        {
   261	            if (body.Year is null)
   262	            {
   263	                return Results.BadRequest(new { error = "Missing year" });
   264	            }
   265	
   266	            var updated = Db.UpsertTaxFilingSettings(
   267	                connection,
   268	                body.Year.Value,
   269	                body.FilingStatus ?? "joint",
   270	                body.Bundesland,
   271	                body.ChurchTaxMemberFilerIds);
   272	
   273	            return Results.Ok(new { settings = updated });
   274	        });
   275	
   276	        // ─────────────────────────────────────────
   277	        // TAX CALCULATION ENDPOINT
   278	        // ─────────────────────────────────────────
   279	
   280	        // GET /api/tax/calculation?year=
   281	        app.MapGet("/api/tax/calculation", (SqliteConnection connection, [FromQuery] int? year) =>
   282	        {
   283	            var resolvedYear = year ?? DateTime.Now.Year;
   284	            try
   285	            {
   286	                var result = TaxCalculator.CalculateTax(connection, resolvedYear);
   287	                return Results.Ok(result);
   288	            }
   289	            catch (Exception err)
   290	            {
   291	                return Results.Json(new { error = err.Message }, statusCode: 500);
   292	            }
   293	        });
   294	    }
   295	}
   296	
   297	public record CreateTaxFilerRequest(string? Name, string? Role, string? TaxId, string? EmployerName);
   298	
   299	public record UpdateTaxFilerRequest(string? Name, string? Role, string? TaxId, string? EmployerName);
   300	
   301	public record CreateFreelanceIncomeRequest(
   302	    long? FilerId,
   303	    int? Year,
   304	    long? RevenueCents,
   305	    long? BusinessExpensesCents,
   306	    long? AdvanceTaxPaidCents,
   307	    long? HealthInsuranceCents,
   308	    long? PensionInsuranceCents,
   309	    string? Notes);
   310	
   311	public record UpdateFreelanceIncomeRequest(
   312	    long? RevenueCents,
   313	    long? BusinessExpensesCents,
   314	    long? AdvanceTaxPaidCents,
   315	    long? HealthInsuranceCents,
   316	    long? PensionInsuranceCents,
   317	    string? Notes);
   318	
   319	public record UpsertTaxFilingSettingsRequest(
   320	    int? Year,
   321	    string? FilingStatus,
   322	    string? Bundesland,
   323	    string? ChurchTaxMemberFilerIds);
