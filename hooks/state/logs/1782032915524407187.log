    const updated = db.prepare('SELECT * FROM mortgages WHERE id = ?').get(mortgageId);
    return res.json(updated);
  });

  // ─────────────────────────────────────────
  // INVESTMENT HOLDINGS ENDPOINTS
  // ─────────────────────────────────────────

  function enrichHolding(h: any): any {
    const currentValueCents = h.last_price_cents != null
      ? Math.round(h.shares * h.last_price_cents)
      : null;
    const costBasisCents = Math.round(h.shares * h.avg_cost_per_share_cents);
    const unrealizedPlCents = currentValueCents != null ? currentValueCents - costBasisCents : null;
    const unrealizedPlPct = currentValueCents != null && costBasisCents > 0
      ? ((currentValueCents - costBasisCents) / costBasisCents) * 100
      : null;

    return {
      ...h,
      current_value_cents: currentValueCents,
      cost_basis_cents: costBasisCents,
      unrealized_pl_cents: unrealizedPlCents,
      unrealized_pl_pct: unrealizedPlPct,
    };
  }

  // GET /api/holdings
  app.get('/api/holdings', (_req: Request, res: Response) => {
    const rows = db.prepare('SELECT * FROM holdings ORDER BY symbol').all() as any[];
    return res.json({ holdings: rows.map(enrichHolding) });
  });

  // POST /api/holdings
  app.post('/api/holdings', (req: Request, res: Response) => {
    const { symbol, isin, name, shares, avg_cost_per_share_cents, currency = 'EUR' } = req.body;

    if (!symbol || shares === undefined || avg_cost_per_share_cents === undefined) {
      return res.status(400).json({ error: 'Missing required fields: symbol, shares, avg_cost_per_share_cents' });
    }

    try {
      const result = db.prepare(`
        INSERT INTO holdings (symbol, isin, name, shares, avg_cost_per_share_cents, currency)
        VALUES (?,?,?,?,?,?)
      `).run(symbol, isin ?? null, name ?? null, shares, avg_cost_per_share_cents, currency);

      const created = db.prepare('SELECT * FROM holdings WHERE id = ?').get(result.lastInsertRowid) as any;
      return res.status(201).json(enrichHolding(created));
    } catch (err) {
      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: `Holding with symbol "${symbol}" already exists. Use PATCH to update.` });
      }
      throw err;
    }
  });

  // PATCH /api/holdings/:id
  app.patch('/api/holdings/:id', (req: Request, res: Response) => {
    const holdingId = parseInt(req.params.id, 10);
    const existing = db.prepare('SELECT * FROM holdings WHERE id = ?').get(holdingId) as any;
    if (!existing) return res.status(404).json({ error: 'not found' });

    const { symbol, isin, name, shares, avg_cost_per_share_cents, currency } = req.body;

    try {
      db.prepare(`
        UPDATE holdings SET symbol=?, isin=?, name=?, shares=?, avg_cost_per_share_cents=?, currency=?
        WHERE id=?
      `).run(
        symbol ?? existing.symbol,
        isin ?? existing.isin,
        name ?? existing.name,
        shares ?? existing.shares,
        avg_cost_per_share_cents ?? existing.avg_cost_per_share_cents,
        currency ?? existing.currency,
        holdingId,
      );
      const updated = db.prepare('SELECT * FROM holdings WHERE id = ?').get(holdingId) as any;
      return res.json(enrichHolding(updated));
    } catch (err) {
      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'A holding with that symbol already exists' });
      }
      throw err;
    }
  });

  // DELETE /api/holdings/:id
  app.delete('/api/holdings/:id', (req: Request, res: Response) => {
    const holdingId = parseInt(req.params.id, 10);
    const result = db.prepare('DELETE FROM holdings WHERE id = ?').run(holdingId);
    if (result.changes === 0) return res.status(404).json({ error: 'not found' });
    return res.json({ id: holdingId, deleted: true });
  });

  // POST /api/holdings/refresh-prices  — fetch latest prices from Yahoo Finance
  app.post('/api/holdings/refresh-prices', async (req: Request, res: Response) => {
    const rows = db.prepare("SELECT * FROM holdings WHERE symbol IS NOT NULL AND symbol != ''").all() as any[];

    if (rows.length === 0) {
      return res.json({ updated: 0, errors: [] });
    }

    let YahooFinance: any;
    try {
      const yf = await import('yahoo-finance2');
      YahooFinance = yf.default;
    } catch {
      return res.status(500).json({ error: 'yahoo-finance2 not available' });
    }

    const yf = new YahooFinance({ suppressNotices: ['yahooSurvey'] });

    // Resolve a raw ISIN or crypto shortcode to a proper Yahoo Finance ticker.
    // Prefers EUR-denominated exchange listings (.DE > .MI > .PA > first result).
    // For crypto shortcodes (BTC, ETH, etc.) tries {SYM}-EUR first.
    // Returns the resolved ticker, or null on failure.
    async function resolveSymbol(sym: string): Promise<string | null> {
      const ISIN = /^[A-Z]{2}[A-Z0-9]{9}[0-9]$/;
      const CRYPTO = /^[A-Z]{2,6}$/;

      if (ISIN.test(sym)) {
        try {
          const res = await yf.search(sym, {}, { validateResult: false });
          const quotes: any[] = (res?.quotes ?? []).filter((q: any) => q.isYahooFinance);
          const pick = quotes.find((q: any) => q.symbol?.endsWith('.DE'))
            ?? quotes.find((q: any) => q.symbol?.endsWith('.MI'))
            ?? quotes.find((q: any) => q.symbol?.endsWith('.PA'))
            ?? quotes.find((q: any) => q.symbol?.endsWith('.AS'))
            ?? quotes[0];
          if (pick?.symbol) return pick.symbol;
        } catch { /* fall through */ }
        // Fallback: direct {ISIN}.DE probe
        try {
          const q = await yf.quote(`${sym}.DE`, {}, { validateResult: false });
          if (q?.regularMarketPrice != null) return `${sym}.DE`;
        } catch { /* ignore */ }
      }

      if (CRYPTO.test(sym)) {
        try {
          const q = await yf.quote(`${sym}-EUR`, {}, { validateResult: false });
          if (q?.regularMarketPrice != null) return `${sym}-EUR`;
        } catch { /* ignore */ }
      }

      return null;
    }

    const errors: string[] = [];
    let updated = 0;
    const today = new Date().toISOString().slice(0, 10);

    for (const holding of rows) {
      try {
        // Auto-resolve placeholder ISINs / crypto codes to real Yahoo tickers
        const needsResolution = /^[A-Z]{2}[A-Z0-9]{9}[0-9]$/.test(holding.symbol)
          || /^[A-Z]{2,6}$/.test(holding.symbol);
        let resolvedSymbol: string = holding.symbol;
        if (needsResolution) {
          const found = await resolveSymbol(holding.symbol);
          if (found) resolvedSymbol = found;
        }

        const quote = await yf.quote(resolvedSymbol, {}, { validateResult: false });
        const price = quote?.regularMarketPrice;
        if (price == null) {
          errors.push(`${holding.symbol}: no price returned`);
          continue;
        }
        const priceCents = Math.round(price * 100);
        // Persist resolved ticker so future refreshes skip re-resolution
        db.prepare('UPDATE holdings SET last_price_cents=?, last_price_date=?, symbol=? WHERE id=?')
          .run(priceCents, today, resolvedSymbol, holding.id);
        updated++;
      } catch (err) {
        errors.push(`${holding.symbol}: ${err instanceof Error ? err.message : String(err)}`);
      }
    }

    return res.json({ updated, errors });
  });

  // DELETE /api/holdings — clear all holdings
  app.delete('/api/holdings', (_req: Request, res: Response) => {
    const result = db.prepare('DELETE FROM holdings').run();
    return res.json({ deleted: result.changes });
  });

  // POST /api/import/holdings-csv — import Trade Republic transaction export CSV
  // Accepts { csv_content: string } (raw CSV text from browser file upload)
  // or legacy { csv_path: string } (server-side file path)
  app.post('/api/import/holdings-csv', (req: Request, res: Response) => {
    const { csv_path, csv_content } = req.body;
    if (!csv_path && !csv_content) {
      return res.status(400).json({ error: 'Missing csv_content or csv_path' });
    }

    let holdings;
    try {
      holdings = csv_content
        ? parseTradeRepublicDepotCsvContent(csv_content)
        : parseTradeRepublicDepotCsv(csv_path);
    } catch (err) {
      return res.status(400).json({ error: err instanceof Error ? err.message : String(err) });
    }

    const upsert = db.prepare(`
      INSERT INTO holdings (symbol, isin, name, shares, avg_cost_per_share_cents, currency)
      VALUES (?, ?, ?, ?, ?, ?)
      ON CONFLICT(symbol) DO UPDATE SET
        shares = excluded.shares,
        avg_cost_per_share_cents = excluded.avg_cost_per_share_cents,
        isin = excluded.isin,
        name = excluded.name
    `);
