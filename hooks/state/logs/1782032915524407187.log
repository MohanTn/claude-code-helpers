    const prop = db.prepare('SELECT id FROM properties WHERE id = ?').get(property_id);
    if (!prop) return res.status(404).json({ error: 'Property not found' });

    const result = db.prepare(`
      INSERT INTO mortgages
        (property_id, bank_name, loan_amount_cents, start_date, interest_rate,
         monthly_payment_cents, outstanding_balance_cents, balance_as_of)
      VALUES (?,?,?,?,?,?,?,?)
    `).run(
      property_id, bank_name, loan_amount_cents, start_date,
      interest_rate, monthly_payment_cents, outstanding_balance_cents,
      balance_as_of ?? null,
