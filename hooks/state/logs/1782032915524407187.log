  // PATCH /api/mortgages/:id
  app.patch('/api/mortgages/:id', (req: Request, res: Response) => {
    const mortgageId = parseInt(req.params.id, 10);
    const existing = db.prepare('SELECT * FROM mortgages WHERE id = ?').get(mortgageId) as any;
    if (!existing) return res.status(404).json({ error: 'not found' });

    const { loan_amount_cents, outstanding_balance_cents, balance_as_of, monthly_payment_cents, interest_rate, bank_name } = req.body;

