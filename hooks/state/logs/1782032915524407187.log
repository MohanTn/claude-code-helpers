        GROUP BY type
      `).all(propId, monthStr) as any[];

      const byType: Record<string, number> = {};
      for (const r of rows) byType[r.type] = r.total;

      // Sum linked bank transactions for this month (recurring types: rental_income, mortgage_payment, maintenance)
      const linkedRows = db.prepare(`
        SELECT pcl.cost_type, SUM(t.amount_cents) as total
        FROM property_cost_links pcl
        JOIN transactions t ON t.id = pcl.transaction_id
        WHERE pcl.property_id = ? AND pcl.cost_type IN ('rental_income','mortgage_payment','maintenance','property_tax')
          AND strftime('%Y-%m', t.date) = ?
        GROUP BY pcl.cost_type
      `).all(propId, monthStr) as any[];

      for (const lr of linkedRows) {
        byType[lr.cost_type] = (byType[lr.cost_type] ?? 0) + lr.total;
      }

      const rental_income = byType['rental_income'] ?? 0;
      const mortgage_payment = byType['mortgage_payment'] ?? 0;
      const property_tax = byType['property_tax'] ?? 0;
      const expenses = Object.entries(byType)
        .filter(([t]) => t !== 'rental_income')
        .reduce((s, [, v]) => s + v, 0);
      const net_cash_flow = rental_income + expenses; // expenses are negative

      months.push({ month: monthStr, rental_income, mortgage_payment, property_tax, expenses, net_cash_flow });
    }

    return res.json({ ...enrichProperty(prop), monthly_cash_flow: months });
  });

  // GET /api/properties/:id/transactions
  app.get('/api/properties/:id/transactions', (req: Request, res: Response) => {
    const propId = parseInt(req.params.id, 10);
    const { month } = req.query;

    let where = 'property_id = ?';
    const params: any[] = [propId];
    if (month) {
      where += " AND strftime('%Y-%m', date) = ?";
      params.push(String(month));
    }

    const rows = db.prepare(`
      SELECT * FROM property_transactions WHERE ${where} ORDER BY date DESC
    `).all(...params);

    return res.json({ transactions: rows });
  });

  // POST /api/properties/:id/transactions
  app.post('/api/properties/:id/transactions', (req: Request, res: Response) => {
    const propId = parseInt(req.params.id, 10);
    const prop = db.prepare('SELECT id FROM properties WHERE id = ?').get(propId);
    if (!prop) return res.status(404).json({ error: 'not found' });

    const { date, type, amount_cents, description } = req.body;
    const VALID_TYPES = [
      'rental_income', 'mortgage_payment', 'maintenance', 'insurance', 'property_tax', 'other',
      'acquisition_purchase', 'acquisition_notary', 'acquisition_transfer_tax',
      'acquisition_agent_fee', 'acquisition_registry',
    ];

    if (!date || !type || amount_cents === undefined) {
      return res.status(400).json({ error: 'Missing required fields: date, type, amount_cents' });
    }
    if (!VALID_TYPES.includes(type)) {
      return res.status(400).json({ error: `Invalid type. Must be one of: ${VALID_TYPES.join(', ')}` });
    }

    const result = db.prepare(`
      INSERT INTO property_transactions (property_id, date, type, amount_cents, description)
      VALUES (?,?,?,?,?)
    `).run(propId, date, type, amount_cents, description ?? null);

    const created = db.prepare('SELECT * FROM property_transactions WHERE id = ?').get(result.lastInsertRowid);
    return res.status(201).json(created);
  });

  // DELETE /api/properties/:id/transactions/:txId
  app.delete('/api/properties/:id/transactions/:txId', (req: Request, res: Response) => {
    const propId = parseInt(req.params.id, 10);
    const txId = parseInt(req.params.txId, 10);

    const result = db.prepare(
      'DELETE FROM property_transactions WHERE id = ? AND property_id = ?'
    ).run(txId, propId);

    if (result.changes === 0) return res.status(404).json({ error: 'not found' });
    return res.json({ id: txId, deleted: true });
  });

  // ── Property Cost Links (link Kaufnebenkosten to bank transactions) ──

  // POST /api/properties/:id/cost-links
  app.post('/api/properties/:id/cost-links', (req: Request, res: Response) => {
    try {
      const propId = parseInt(req.params.id, 10);
      const { cost_type, transaction_id } = req.body;

      if (!cost_type || transaction_id === undefined) {
        return res.status(400).json({ error: 'Missing cost_type or transaction_id' });
      }

      const prop = db.prepare('SELECT id FROM properties WHERE id = ?').get(propId);
      if (!prop) return res.status(404).json({ error: 'Property not found' });

      if (!COST_TYPES.includes(cost_type)) {
        return res.status(400).json({ error: `Invalid cost_type. Must be one of: ${COST_TYPES.join(', ')}` });
      }

      const txn = db.prepare('SELECT id FROM transactions WHERE id = ?').get(transaction_id);
      if (!txn) return res.status(404).json({ error: 'Transaction not found' });

      // Check if link already exists
      const existing = db.prepare(`
        SELECT pcl.*, t.date, t.description, t.amount_cents, t.account_id
        FROM property_cost_links pcl
        JOIN transactions t ON t.id = pcl.transaction_id
        WHERE pcl.property_id = ? AND pcl.cost_type = ? AND pcl.transaction_id = ?
      `).get(propId, cost_type, transaction_id) as any;

      if (existing) {
        return res.status(200).json(existing);
      }

      // Insert new link
      db.prepare(`
        INSERT INTO property_cost_links (property_id, cost_type, transaction_id)
        VALUES (?, ?, ?)
      `).run(propId, cost_type, transaction_id);

      const link = db.prepare(`
        SELECT pcl.*, t.date, t.description, t.amount_cents, t.account_id
        FROM property_cost_links pcl
        JOIN transactions t ON t.id = pcl.transaction_id
        WHERE pcl.property_id = ? AND pcl.cost_type = ? AND pcl.transaction_id = ?
      `).get(propId, cost_type, transaction_id) as any;

      return res.status(201).json(link);
    } catch (error) {
      return res.status(500).json({ error: error instanceof Error ? error.message : String(error) });
    }
  });

  // DELETE /api/properties/:id/cost-links/:costType
  app.delete('/api/properties/:id/cost-links/:costType', (req: Request, res: Response) => {
    const propId = parseInt(req.params.id, 10);
    const { costType } = req.params;
    const transactionId = req.query.transaction_id ? parseInt(String(req.query.transaction_id), 10) : undefined;

    if (!COST_TYPES.includes(costType)) {
      return res.status(400).json({ error: `Invalid cost_type: ${costType}` });
    }

    let result;
    if (transactionId) {
      result = db.prepare(
        'DELETE FROM property_cost_links WHERE property_id = ? AND cost_type = ? AND transaction_id = ?'
      ).run(propId, costType, transactionId);
    } else {
      result = db.prepare(
        'DELETE FROM property_cost_links WHERE property_id = ? AND cost_type = ?'
      ).run(propId, costType);
    }

    if (result.changes === 0) return res.status(404).json({ error: 'not found' });
    return res.json({ property_id: propId, cost_type: costType, transaction_id: transactionId, deleted: true });
  });

  // POST /api/mortgages
  app.post('/api/mortgages', (req: Request, res: Response) => {
    const {
      property_id, bank_name,
      loan_amount_cents, start_date,
      interest_rate, monthly_payment_cents,
