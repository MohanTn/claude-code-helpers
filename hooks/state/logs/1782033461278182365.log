/**
 * Trade Republic depot CSV parser.
 *
 * Trade Republic lets you export your depot transaction history as a CSV.
 * This parser handles that export, computes current net positions per ISIN,
 * and derives the weighted average cost basis for each holding.
 *
 * Supported transaction types (matched case-insensitively):
 *   buy / kauf / sparplan       → add shares, add cost
 *   sell / verkauf              → subtract shares
 *   dividend / dividende / ertrag → ignored for position calculation
 *   split / aktiensplit         → multiplies shares (requires ratio in description)
 *
 * Expected CSV columns (order-insensitive, matched by header name):
 *   date / datum                    → transaction date
 *   type / typ / art                → transaction type
 *   isin                            → ISIN identifier
 *   name / wertpapier / beschreibung → security name
 *   shares / stück / anteile       → number of shares (may use dot or comma decimal)
 *   price / kurs / preis            → price per share (used when amount missing)
 *   amount / betrag / gesamt        → total transaction amount (incl. fees when buying)
 *   currency / währung              → currency code (default EUR)
 *   fees / gebühren / provision     → transaction fees (optional, added to cost basis for buys)
 */

import { readFileSync } from 'node:fs';
import { parseDecimalToCents } from './normalize.js';

export interface DepotHolding {
  isin: string;
  name: string;
  shares: number;
  avg_cost_per_share_cents: number;
  currency: string;
}

interface ParsedRow {
  date: string;
  type: string;
  isin: string;
  name: string;
  shares: number;
  amount_cents: number;
  currency: string;
}

// Maps normalised header tokens → canonical field name
const HEADER_MAP: Record<string, keyof ParsedRow> = {
  date: 'date',
  datum: 'date',
  type: 'type',
  typ: 'type',
  art: 'type',
  isin: 'isin',
  symbol: 'isin',   // TR transaction export uses "symbol" column for ISIN
  name: 'name',
  wertpapier: 'name',
  beschreibung: 'name',
  titel: 'name',
  shares: 'shares',
  stück: 'shares',
  anteile: 'shares',
  menge: 'shares',
  amount: 'amount_cents',
  betrag: 'amount_cents',
  gesamt: 'amount_cents',
  wert: 'amount_cents',
  currency: 'currency',
  währung: 'currency',
};

const BUY_TYPES = new Set(['buy', 'kauf', 'sparplan', 'savingsplan', 'purchase']);
const SELL_TYPES = new Set(['sell', 'verkauf', 'sale']);

function parseCsvRow(line: string, sep: string): string[] {
  const result: string[] = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') {
      if (inQuotes && line[i + 1] === '"') { current += '"'; i++; }
      else { inQuotes = !inQuotes; }
    } else if (ch === sep && !inQuotes) {
      result.push(current.trim());
      current = '';
    } else {
      current += ch;
    }
  }
  result.push(current.trim());
  return result;
}

function guessDecimalSeparator(values: string[]): 'comma' | 'dot' {
  const commaDecimals = values.filter(v => /\d,\d{1,2}$/.test(v)).length;
  const dotDecimals = values.filter(v => /\d\.\d{1,2}$/.test(v)).length;
  return commaDecimals >= dotDecimals ? 'comma' : 'dot';
}

function parseAmount(raw: string, sep: 'comma' | 'dot'): number {
  const cleaned = raw.trim().replace(/[€$£]/g, '');
  if (!cleaned || cleaned === '-' || cleaned === '') return 0;
  return parseDecimalToCents(cleaned.startsWith('-') ? cleaned : cleaned, sep);
}

function parseShares(raw: string, sep: 'comma' | 'dot'): number {
  const cleaned = raw.trim();
  if (!cleaned) return 0;
  if (sep === 'comma') {
    return parseFloat(cleaned.replace(/\./g, '').replace(',', '.'));
  }
  return parseFloat(cleaned.replace(/,/g, ''));
}

function normalizeDate(raw: string): string {
  const s = raw.trim();
  // ISO format: 2025-01-15
  if (/^\d{4}-\d{2}-\d{2}/.test(s)) return s.slice(0, 10);
  // DD.MM.YYYY
  const m = s.match(/^(\d{2})\.(\d{2})\.(\d{4})/);
  if (m) return `${m[3]}-${m[2]}-${m[1]}`;
  // D.M.YYYY
  const m2 = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})/);
  if (m2) return `${m2[3]}-${m2[2].padStart(2, '0')}-${m2[1].padStart(2, '0')}`;
  return s;
}

/**
 * Parses Trade Republic transaction CSV content and returns current holdings with
 * weighted average cost basis. Holdings with zero or negative net shares are omitted.
 */
export function parseTradeRepublicDepotCsvContent(csvContent: string): DepotHolding[] {
  const raw = csvContent;
  const lines = raw.split(/\r?\n/).filter(l => l.trim());

  if (lines.length < 2) {
    throw new Error('CSV appears empty or has no data rows');
  }

  // Detect separator: semicolons are common in German exports
  const firstLine = lines[0];
  const sep = firstLine.includes(';') ? ';' : ',';

  const headers = parseCsvRow(firstLine, sep).map(h => h.toLowerCase());

  // Build column index mapping
  const colIndex: Partial<Record<keyof ParsedRow, number>> = {};
  let priceColIdx = -1;
  let feesColIdx = -1;

  headers.forEach((h, i) => {
    const key = HEADER_MAP[h];
    if (key !== undefined && !(key in colIndex)) {
      (colIndex as Record<string, number>)[key] = i;
    }
    if (h === 'price' || h === 'kurs' || h === 'preis') priceColIdx = i;
    if (h === 'fee' || h === 'fees' || h === 'gebühren' || h === 'provision') feesColIdx = i;
  });

  if (!('isin' in colIndex)) {
    throw new Error('CSV missing required "isin" column. Found headers: ' + headers.join(', '));
  }
  if (!('shares' in colIndex)) {
    throw new Error('CSV missing required shares column (shares/stück/anteile). Found headers: ' + headers.join(', '));
  }

  // Sample numeric values to detect decimal separator
  const sampleNums = lines.slice(1, 20).flatMap(line => {
    const cols = parseCsvRow(line, sep);
    return [
      colIndex.amount_cents !== undefined ? cols[colIndex.amount_cents] : '',
      colIndex.shares !== undefined ? cols[colIndex.shares] : '',
    ].filter(Boolean);
  });
  const decSep = guessDecimalSeparator(sampleNums);

  // Accumulate positions: isin → { totalCostCents, totalShares, name, currency }
  const positions = new Map<string, { totalCostCents: number; totalShares: number; name: string; currency: string }>();

  for (let i = 1; i < lines.length; i++) {
    const cols = parseCsvRow(lines[i], sep);
    if (cols.length < 2 || cols.every(c => !c)) continue;

    const isin = colIndex.isin !== undefined ? (cols[colIndex.isin] ?? '').trim() : '';
    if (!isin) continue;

    const typeRaw = colIndex.type !== undefined ? (cols[colIndex.type] ?? '').toLowerCase().trim() : '';
    const name = colIndex.name !== undefined ? (cols[colIndex.name] ?? '').trim() : isin;
    const currency = colIndex.currency !== undefined ? (cols[colIndex.currency] ?? 'EUR').trim() : 'EUR';

    const sharesRaw = colIndex.shares !== undefined ? cols[colIndex.shares] ?? '0' : '0';
    const shares = parseShares(sharesRaw, decSep);

    let amountCents = 0;
    if (colIndex.amount_cents !== undefined && cols[colIndex.amount_cents]) {
      amountCents = Math.abs(parseAmount(cols[colIndex.amount_cents], decSep));
    } else if (priceColIdx >= 0 && cols[priceColIdx]) {
      // Fall back to price × shares
      const pricePerShare = Math.abs(parseAmount(cols[priceColIdx], decSep));
      amountCents = Math.round(pricePerShare * shares);
    }

    // Add fees to cost basis for buys
    if (feesColIdx >= 0 && cols[feesColIdx]) {
      const fees = Math.abs(parseAmount(cols[feesColIdx], decSep));
      amountCents += fees;
    }

    const pos = positions.get(isin) ?? { totalCostCents: 0, totalShares: 0, name, currency };

    if (BUY_TYPES.has(typeRaw)) {
      pos.totalShares += Math.abs(shares);
      pos.totalCostCents += amountCents;
    } else if (SELL_TYPES.has(typeRaw)) {
      const soldShares = Math.abs(shares);
      if (pos.totalShares > 0) {
        const avgCost = pos.totalCostCents / pos.totalShares;
        pos.totalCostCents = Math.max(0, pos.totalCostCents - Math.round(avgCost * soldShares));
      }
      pos.totalShares = Math.max(0, pos.totalShares - soldShares);
    }
    // Dividends, taxes, etc. → ignored for position tracking

    positions.set(isin, pos);
  }

  const holdings: DepotHolding[] = [];
  for (const [isin, pos] of positions) {
    if (pos.totalShares <= 0.0001) continue; // fully sold or negligible rounding

    const avgCostCents = pos.totalShares > 0
      ? Math.round(pos.totalCostCents / pos.totalShares)
      : 0;

    holdings.push({
      isin,
      name: pos.name,
      shares: Math.round(pos.totalShares * 1e6) / 1e6, // 6 decimal places
      avg_cost_per_share_cents: avgCostCents,
      currency: pos.currency,
    });
  }

  return holdings;
}

/**
 * Parses a Trade Republic depot CSV file by path (wraps the content-based parser).
 */
export function parseTradeRepublicDepotCsv(csvPath: string): DepotHolding[] {
  const content = readFileSync(csvPath, 'utf-8');
  return parseTradeRepublicDepotCsvContent(content);
}
