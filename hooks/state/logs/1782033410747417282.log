  // POST /api/tax/freelance-income
  app.post('/api/tax/freelance-income', (req: Request, res: Response) => {
    const { filer_id, year, revenue_cents, business_expenses_cents, advance_tax_paid_cents, health_insurance_cents, pension_insurance_cents, notes } = req.body;
    if (!filer_id || !year) {
      return res.status(400).json({ error: 'Missing filer_id or year' });
    }

    try {
      const result = db.prepare(`
        INSERT INTO freelance_income
          (filer_id, year, revenue_cents, business_expenses_cents,
           advance_tax_paid_cents, health_insurance_cents, pension_insurance_cents, notes)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
      `).run(
        filer_id, year,
        revenue_cents ?? 0, business_expenses_cents ?? 0,
        advance_tax_paid_cents ?? 0, health_insurance_cents ?? 0,
        pension_insurance_cents ?? 0, notes ?? null,
      );

      const created = db.prepare('SELECT * FROM freelance_income WHERE id = ?').get(result.lastInsertRowid);
      return res.status(201).json(created);
    } catch (err) {
      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'Freelance income already exists for this filer/year' });
      }
      throw err;
    }
  });

  // PATCH /api/tax/freelance-income/:id
  app.patch('/api/tax/freelance-income/:id', (req: Request, res: Response) => {
    const id = parseInt(req.params.id, 10);
    const existing = db.prepare('SELECT * FROM freelance_income WHERE id = ?').get(id) as any;
    if (!existing) return res.status(404).json({ error: 'not found' });

    const { revenue_cents, business_expenses_cents, advance_tax_paid_cents, health_insurance_cents, pension_insurance_cents, notes } = req.body;

    db.prepare(`
      UPDATE freelance_income SET
        revenue_cents = ?, business_expenses_cents = ?,
        advance_tax_paid_cents = ?, health_insurance_cents = ?, pension_insurance_cents = ?,
        notes = ?
      WHERE id = ?
    `).run(
      revenue_cents ?? existing.revenue_cents,
      business_expenses_cents ?? existing.business_expenses_cents,
      advance_tax_paid_cents ?? existing.advance_tax_paid_cents,
      health_insurance_cents ?? existing.health_insurance_cents,
      pension_insurance_cents ?? existing.pension_insurance_cents,
      notes ?? existing.notes,
      id,
    );

    const updated = db.prepare('SELECT * FROM freelance_income WHERE id = ?').get(id);
    return res.json(updated);
  });

  // DELETE /api/tax/freelance-income/:id
  app.delete('/api/tax/freelance-income/:id', (req: Request, res: Response) => {
    const id = parseInt(req.params.id, 10);
    const result = db.prepare('DELETE FROM freelance_income WHERE id = ?').run(id);
