  app.get('/api/tax/filers', (_req: Request, res: Response) => {
    const rows = db.prepare('SELECT * FROM tax_filers ORDER BY id').all();
    return res.json({ filers: rows });
  });

  // POST /api/tax/filers
  app.post('/api/tax/filers', (req: Request, res: Response) => {
    const { name, role, tax_id, employer_name } = req.body;
    if (!name || !role) {
      return res.status(400).json({ error: 'Missing required fields: name, role' });
    }
    if (!['employee', 'freelancer'].includes(role)) {
      return res.status(400).json({ error: "role must be 'employee' or 'freelancer'" });
    }

    try {
      const result = db.prepare(`
        INSERT INTO tax_filers (name, role, tax_id, employer_name)
        VALUES (?, ?, ?, ?)
      `).run(name, role, tax_id ?? null, employer_name ?? null);

      const created = db.prepare('SELECT * FROM tax_filers WHERE id = ?').get(result.lastInsertRowid);
      return res.status(201).json(created);
    } catch (err) {
      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'A filer with that name already exists' });
      }
      throw err;
    }
  });

  // PATCH /api/tax/filers/:id
  app.patch('/api/tax/filers/:id', (req: Request, res: Response) => {
    const filerId = parseInt(req.params.id, 10);
    const existing = db.prepare('SELECT * FROM tax_filers WHERE id = ?').get(filerId) as any;
    if (!existing) return res.status(404).json({ error: 'not found' });

    const { name, role, tax_id, employer_name } = req.body;
    if (role && !['employee', 'freelancer'].includes(role)) {
      return res.status(400).json({ error: "role must be 'employee' or 'freelancer'" });
    }

    try {
      db.prepare(`
        UPDATE tax_filers SET name = ?, role = ?, tax_id = ?, employer_name = ?
        WHERE id = ?
      `).run(
        name ?? existing.name,
        role ?? existing.role,
        tax_id ?? existing.tax_id,
        employer_name ?? existing.employer_name,
        filerId,
      );
      const updated = db.prepare('SELECT * FROM tax_filers WHERE id = ?').get(filerId);
      return res.json(updated);
    } catch (err) {
      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'A filer with that name already exists' });
      }
      throw err;
    }
  });

  // ─────────────────────────────────────────
  // PAYSLIP ENDPOINTS
  // ─────────────────────────────────────────

  // GET /api/tax/payslips?filer_id=&year=
  app.get('/api/tax/payslips', (req: Request, res: Response) => {
    const { filer_id, year } = req.query;

    let where = '1=1';
    const params: any[] = [];
    if (filer_id) { where += ' AND filer_id = ?'; params.push(parseInt(String(filer_id), 10)); }
    if (year) { where += ' AND year = ?'; params.push(parseInt(String(year), 10)); }

    const rows = db.prepare(`
      SELECT * FROM payslips WHERE ${where} ORDER BY year, month
    `).all(...params);

    return res.json({ payslips: rows });
  });

  // POST /api/tax/payslips/upload — multipart payslip PDF upload
  // Reuses the same multer instance as /api/import/upload.

  app.post('/api/tax/payslips/upload', upload.single('file'), (req: Request, res: Response) => {
    const tmpPath = req.file?.path;
    try {
      const filerId = parseInt(String(req.body.filer_id ?? ''), 10);
      if (!filerId || !req.file) {
        if (tmpPath) fs.unlinkSync(tmpPath);
        return res.status(400).json({ error: 'Missing filer_id or file' });
      }

      const filer = db.prepare('SELECT id FROM tax_filers WHERE id = ?').get(filerId);
      if (!filer) {
        if (tmpPath) fs.unlinkSync(tmpPath);
        return res.status(404).json({ error: 'Tax filer not found' });
      }

      const origName = req.file.originalname ?? 'upload.pdf';
      const ext = path.extname(origName).toLowerCase() || '.pdf';
      const namedPath = tmpPath! + ext;
      fs.renameSync(tmpPath!, namedPath);

      try {
        const summary = importPayslipFile(db, filerId, namedPath);
        try { fs.unlinkSync(namedPath); } catch {}
        return res.json({
          imported: summary.imported,
          updated: summary.updated,
          skipped: summary.skipped,
          errors: summary.errors,
        });
      } catch (parseErr) {
        try { fs.unlinkSync(namedPath); } catch {}
        return res.json({
          imported: 0, updated: 0, skipped: [],
          errors: [parseErr instanceof Error ? parseErr.message : String(parseErr)],
        });
      }
    } catch (err) {
      try { if (tmpPath) fs.unlinkSync(tmpPath); } catch {}
      return res.status(500).json({
        imported: 0, updated: 0, skipped: [],
        errors: [err instanceof Error ? err.message : String(err)],
      });
    }
  });

  // DELETE /api/tax/payslips/:id
  app.delete('/api/tax/payslips/:id', (req: Request, res: Response) => {
    const id = parseInt(req.params.id, 10);
    const result = db.prepare('DELETE FROM payslips WHERE id = ?').run(id);
    if (result.changes === 0) return res.status(404).json({ error: 'not found' });
    return res.json({ id, deleted: true });
  });

