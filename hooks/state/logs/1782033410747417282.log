  // GET /api/tax/settings?year=
  app.get('/api/tax/settings', (req: Request, res: Response) => {
    const year = parseInt(String(req.query.year ?? new Date().getFullYear()), 10);
    const row = db.prepare('SELECT * FROM tax_filing_settings WHERE year = ?').get(year);
    return res.json({ settings: row ?? { year, filing_status: 'joint' } });
  });

  // PUT /api/tax/settings
  app.put('/api/tax/settings', (req: Request, res: Response) => {
    const { year, filing_status, bundesland, church_tax_member_filer_ids } = req.body;
    if (!year) return res.status(400).json({ error: 'Missing year' });

    db.prepare(`
      INSERT INTO tax_filing_settings (year, filing_status, bundesland, church_tax_member_filer_ids)
      VALUES (?, ?, ?, ?)
      ON CONFLICT(year) DO UPDATE SET
        filing_status = excluded.filing_status,
        bundesland = excluded.bundesland,
        church_tax_member_filer_ids = excluded.church_tax_member_filer_ids
    `).run(
      year,
      filing_status ?? 'joint',
      bundesland ?? null,
      church_tax_member_filer_ids ?? null,
    );

    const updated = db.prepare('SELECT * FROM tax_filing_settings WHERE year = ?').get(year);
    return res.json({ settings: updated });
  });

