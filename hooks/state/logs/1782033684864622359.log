   162	    private static IResult GetProperties(SqliteConnection connection)
   163	    {
   164	        var rows = Db.GetAllProperties(connection);
   165	        return Results.Ok(new { Properties = rows.Select(p => EnrichProperty(connection, p)).ToList() });
