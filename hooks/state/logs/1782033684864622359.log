   252	    // ── GET /api/properties/:id/summary (server.ts:884-933) ─────────────
   253	
   254	    private static IResult GetPropertySummary(SqliteConnection connection, long id)
   255	    {
   256	        var property = Db.GetPropertyById(connection, id);
   257	        if (property is null) return Results.NotFound(new { error = "not found" });
   258	
   259	        // Monthly cash flow for the last 13 months
   260	        var months = new List<object>();
   261	        var now = DateTime.Now;
   262	        for (var i = 12; i >= 0; i--)
   263	        {
   264	            var d = new DateTime(now.Year, now.Month, 1).AddMonths(-i);
   265	            var monthStr = $"{d.Year}-{d.Month:D2}";
   266	
   267	            var byType = new Dictionary<string, long>();
   268	            foreach (var row in Db.GetMonthlyPropertyTransactionTotals(connection, id, monthStr))
   269	            {
   270	                byType[row.Type] = row.Total;
   271	            }
   272	
   273	            foreach (var lr in Db.GetMonthlyLinkedCostTotals(connection, id, monthStr))
   274	            {
   275	                byType[lr.CostType] = byType.GetValueOrDefault(lr.CostType, 0) + lr.Total;
   276	            }
   277	
   278	            var rentalIncome = byType.GetValueOrDefault("rental_income", 0);
   279	            var mortgagePayment = byType.GetValueOrDefault("mortgage_payment", 0);
   280	            var propertyTax = byType.GetValueOrDefault("property_tax", 0);
   281	            var expenses = byType.Where(kv => kv.Key != "rental_income").Sum(kv => kv.Value);
   282	            var netCashFlow = rentalIncome + expenses; // expenses are negative
   283	
   284	            months.Add(new
   285	            {
   286	                Month = monthStr,
   287	                RentalIncome = rentalIncome,
   288	                MortgagePayment = mortgagePayment,
   289	                PropertyTax = propertyTax,
   290	                Expenses = expenses,
   291	                NetCashFlow = netCashFlow,
   292	            });
   293	        }
   294	
   295	        // Mirrors the TS object-spread `{ ...enrichProperty(prop), monthly_cash_flow: months }`.
   296	        var enriched = EnrichProperty(connection, property);
   297	        enriched["monthly_cash_flow"] = months;
   298	        return Results.Ok(enriched);
   299	    }
