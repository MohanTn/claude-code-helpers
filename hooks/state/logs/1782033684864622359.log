   168	    // ── POST /api/properties (server.ts:797-833) ────────────────────────
   169	
   170	    public record PostPropertyRequest(
   171	        string? Name,
   172	        string? Address,
   173	        long? PurchasePriceCents,
   174	        string? PurchaseDate,
   175	        long? GrunderwerbsteuerCents,
   176	        long? NotarkostenCents,
   177	        long? MaklergebuehrCents,
   178	        long? GrundbuchkostenCents,
   179	        long? EstimatedValueCents,
   180	        string? EstimatedValueDate,
   181	        int? BuildingCompletionYear,
   182	        long? LandValueCents);
   183	
   184	    private static IResult PostProperty(SqliteConnection connection, PostPropertyRequest body)
   185	    {
   186	        if (string.IsNullOrEmpty(body.Name) || body.PurchasePriceCents is null || string.IsNullOrEmpty(body.PurchaseDate))
   187	        {
   188	            return Results.BadRequest(new { error = "Missing required fields: name, purchase_price_cents, purchase_date" });
   189	        }
   190	
   191	        var id = Db.InsertProperty(
   192	            connection,
   193	            body.Name,
   194	            body.Address,
   195	            body.PurchasePriceCents.Value,
   196	            body.PurchaseDate,
   197	            body.GrunderwerbsteuerCents ?? 0,
   198	            body.NotarkostenCents ?? 0,
   199	            body.MaklergebuehrCents ?? 0,
   200	            body.GrundbuchkostenCents ?? 0,
   201	            body.EstimatedValueCents,
   202	            body.EstimatedValueDate,
   203	            body.BuildingCompletionYear,
   204	            body.LandValueCents ?? 0);
   205	
   206	        var created = Db.GetPropertyById(connection, id)!;
   207	        return Results.Json(EnrichProperty(connection, created), statusCode: 201);
   208	    }
