   333	    // ── DELETE /api/properties/:id/transactions/:txId (server.ts:984-994) ─
   334	
   335	    private static IResult DeletePropertyTransaction(SqliteConnection connection, long id, long txId)
   336	    {
   337	        var deleted = Db.DeletePropertyTransaction(connection, txId, id);
   338	        if (!deleted) return Results.NotFound(new { error = "not found" });
   339	        return Results.Ok(new { Id = txId, Deleted = true });
   340	    }
