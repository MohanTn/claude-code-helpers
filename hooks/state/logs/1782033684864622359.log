    46	    // ── enrichProperty (server.ts:723-788) ──────────────────────────────
    47	
    48	    /// <summary>
    49	    /// Wraps a <see cref="PropertyRecord"/> with computed fields: total
    50	    /// acquisition cost, latest mortgage, own_capital/tenant_deposit totals,
    51	    /// current equity, LTV ratio, and cost_links enriched with the
    52	    /// amortization split for EMI payments. Ported 1:1 from server.ts:723-788
    53	    /// (`enrichProperty`). Returns a <see cref="Dictionary{TKey, TValue}"/>
    54	    /// (rather than an anonymous type) so that GET /api/properties/:id/summary
    55	    /// can merge in a `monthly_cash_flow` key, mirroring the TS object-spread
    56	    /// `{ ...enrichProperty(prop), monthly_cash_flow: months }`.
    57	    /// </summary>
    58	    private static Dictionary<string, object?> EnrichProperty(SqliteConnection connection, PropertyRecord property)
    59	    {
    60	        var mortgage = Db.GetLatestMortgageForProperty(connection, property.Id);
    61	        var costLinks = Db.GetCostLinksForProperty(connection, property.Id);
    62	
    63	        var totalAcquisitionCostCents = Db.GetPropertyTotalCostCents(connection, property);
    64	
    65	        // Sum linked own_capital transactions (money put in from own pocket)
    66	        var ownCapitalCents = costLinks
    67	            .Where(l => l.CostType == "own_capital")
    68	            .Sum(l => Math.Abs(l.AmountCents));
    69	
    70	        // Sum linked tenant_deposit transactions (Mietkaution received — a
    71	        // liability to be returned, not rental income; documentation only).
    72	        var tenantDepositCents = costLinks
    73	            .Where(l => l.CostType == "tenant_deposit")
    74	            .Sum(l => Math.Abs(l.AmountCents));
    75	
    76	        // Compute mortgage amortization from linked EMI transactions
    77	        var emiLinks = costLinks
    78	            .Where(l => l.CostType == "mortgage_payment")
    79	            .Select(l => new MortgageAmortization.EmiLink(l.TransactionId, l.Date, l.AmountCents))
    80	            .ToList();
    81	
    82	        var mortgageInfo = mortgage is null
    83	            ? null
    84	            : new MortgageAmortization.MortgageInfo((decimal)mortgage.InterestRate, mortgage.OutstandingBalanceCents);
    85	
    86	        var amortization = MortgageAmortization.ComputeMortgageAmortization(mortgageInfo, emiLinks);
    87	
    88	        // Enrich cost_links with amortization split for EMI payments
    89	        var amortByTxnId = amortization.AmortizedTransactions.ToDictionary(a => a.TransactionId, a => a);
    90	
    91	        var enrichedCostLinks = costLinks.Select(l =>
    92	        {
    93	            if (amortByTxnId.TryGetValue(l.TransactionId, out var am))
    94	            {
    95	                return (object)new
    96	                {
    97	                    l.Id,
    98	                    l.PropertyId,
    99	                    l.CostType,
   100	                    l.TransactionId,
   101	                    l.CreatedAt,
   102	                    l.Date,
   103	                    l.Description,
   104	                    l.AmountCents,
   105	                    l.AccountId,
   106	                    InterestCents = am.InterestCents,
   107	                    PrincipalCents = am.PrincipalCents,
   108	                };
   109	            }
   110	            return l;
   111	        }).ToList();
   112	
   113	        var outstandingBalanceCents = mortgage?.OutstandingBalanceCents ?? 0;
   114	        var effectiveOutstandingBalanceCents = outstandingBalanceCents - amortization.TotalPrincipalPaidCents;
   115	
   116	        // Equity = estimated_value - total_acquisition_cost + principal paid (equity built through EMI)
   117	        long? currentEquityCents = property.EstimatedValueCents is { } estimatedValue
   118	            ? estimatedValue - totalAcquisitionCostCents + amortization.TotalPrincipalPaidCents
   119	            : null;
   120	
   121	        double? ltvRatio = property.EstimatedValueCents is { } estimatedValueForLtv && estimatedValueForLtv > 0
   122	            ? (double)effectiveOutstandingBalanceCents / estimatedValueForLtv
   123	            : totalAcquisitionCostCents > 0
   124	                ? (double)effectiveOutstandingBalanceCents / totalAcquisitionCostCents
   125	                : (double?)null;
   126	
   127	        // Keys are snake_case literals (not PascalCase) because
   128	        // Dictionary<string, object?> keys bypass ASP.NET Core's
   129	        // PropertyNamingPolicy (which only rewrites POCO/record property
   130	        // names) — these must match server.ts's JSON output verbatim.
   131	        return new Dictionary<string, object?>
   132	        {
   133	            ["id"] = property.Id,
   134	            ["name"] = property.Name,
   135	            ["address"] = property.Address,
   136	            ["purchase_price_cents"] = property.PurchasePriceCents,
   137	            ["purchase_date"] = property.PurchaseDate,
   138	            ["grunderwerbsteuer_cents"] = property.GrunderwerbsteuerCents,
   139	            ["notarkosten_cents"] = property.NotarkostenCents,
   140	            ["maklergebuehr_cents"] = property.MaklergebuehrCents,
   141	            ["grundbuchkosten_cents"] = property.GrundbuchkostenCents,
   142	            ["estimated_value_cents"] = property.EstimatedValueCents,
   143	            ["estimated_value_date"] = property.EstimatedValueDate,
   144	            ["building_completion_year"] = property.BuildingCompletionYear,
   145	            ["land_value_cents"] = property.LandValueCents,
   146	            ["created_at"] = property.CreatedAt,
   147	            ["total_acquisition_cost_cents"] = totalAcquisitionCostCents,
   148	            ["mortgage"] = mortgage,
   149	            ["own_capital_cents"] = ownCapitalCents,
   150	            ["tenant_deposit_cents"] = tenantDepositCents,
   151	            ["current_equity_cents"] = currentEquityCents,
   152	            ["ltv_ratio"] = ltvRatio,
   153	            ["cost_links"] = enrichedCostLinks,
   154	            ["total_principal_paid_cents"] = amortization.TotalPrincipalPaidCents,
   155	            ["total_interest_paid_cents"] = amortization.TotalInterestPaidCents,
   156	            ["effective_outstanding_balance_cents"] = effectiveOutstandingBalanceCents,
   157	        };
   158	    }
