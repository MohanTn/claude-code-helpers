   400	    // ── GET /api/properties/annual-result?year= (server.ts:1648-1660) ───
   401	
   402	    private static IResult GetPropertiesAnnualResult(SqliteConnection connection, int? year)
   403	    {
   404	        var targetYear = year ?? DateTime.Now.Year;
   405	        try
   406	        {
   407	            var result = PropertyAnnualResultCalculator.CalculatePropertiesAnnualResult(connection, targetYear);
   408	            return Results.Ok(result);
   409	        }
   410	        catch (Exception err)
   411	        {
   412	            return Results.Json(new { error = err.Message }, statusCode: 500);
   413	        }
   414	    }
