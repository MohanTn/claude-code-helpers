     9	public static class PropertiesEndpoints
    10	{
    11	    // Documentation-only property cost types: linking a transaction here records
    12	    // it against a property but must never feed P&L/cash-flow (own_capital, the
    13	    // purchase down payment) or income (tenant_deposit, a Mietkaution liability
    14	    // to be returned, not rent earned). Ported from server.ts:80.
    15	    private static readonly string[] DocumentationCostTypes = { "own_capital", "tenant_deposit" };
    16	
    17	    // Ported from server.ts:720.
    18	    private static readonly string[] RecurringCostTypes = { "rental_income", "mortgage_payment", "maintenance", "property_tax" };
    19	
    20	    // Ported from server.ts:721: ACQUISITION_COST_TYPES + RECURRING_COST_TYPES + DOCUMENTATION_COST_TYPES.
    21	    private static readonly string[] CostTypes =
    22	        Db.AcquisitionCostTypes.Concat(RecurringCostTypes).Concat(DocumentationCostTypes).ToArray();
    23	
    24	    // Ported from server.ts:961-965.
    25	    private static readonly string[] ValidTransactionTypes =
    26	    {
    27	        "rental_income", "mortgage_payment", "maintenance", "insurance", "property_tax", "other",
    28	        "acquisition_purchase", "acquisition_notary", "acquisition_transfer_tax",
    29	        "acquisition_agent_fee", "acquisition_registry",
    30	    };
    31	
    32	    public static void MapPropertiesEndpoints(this WebApplication app)
    33	    {
    34	        app.MapGet("/api/properties", GetProperties);
    35	        app.MapPost("/api/properties", PostProperty);
    36	        app.MapPatch("/api/properties/{id}", PatchProperty);
    37	        app.MapGet("/api/properties/{id}/summary", GetPropertySummary);
    38	        app.MapGet("/api/properties/{id}/transactions", GetPropertyTransactions);
    39	        app.MapPost("/api/properties/{id}/transactions", PostPropertyTransaction);
    40	        app.MapDelete("/api/properties/{id}/transactions/{txId}", DeletePropertyTransaction);
    41	        app.MapPost("/api/properties/{id}/cost-links", PostCostLink);
    42	        app.MapDelete("/api/properties/{id}/cost-links/{costType}", DeleteCostLink);
    43	        app.MapGet("/api/properties/annual-result", GetPropertiesAnnualResult);
    44	    }
