    let whereClause = `category != 'Internal Transfer' AND ${DOCUMENTATION_LINK_EXCLUSION_SQL}`;
    if (start_date) {
      whereClause += ` AND date >= '${start_date}'`;
    }
    if (end_date) {
      whereClause += ` AND date <= '${end_date}'`;
    }

    const rows = db
      .prepare(
        `SELECT strftime('%Y-%m', date) as month,
                SUM(CASE WHEN amount_cents > 0 THEN amount_cents ELSE 0 END) as income_cents,
                SUM(CASE WHEN amount_cents < 0 THEN amount_cents ELSE 0 END) as expense_cents
       FROM transactions
       WHERE ${whereClause}
       GROUP BY strftime('%Y-%m', date)
       ORDER BY month`
      )
      .all() as any[];

    const months = rows.map((row) => ({
      month: row.month,
      income_cents: row.income_cents || 0,
      expense_cents: row.expense_cents || 0,
    }));

    return res.json({ months });
  });

  // ===== GET /api/summary/monthly-buckets =====
  // Returns per-month totals split into Income, Saving, Living Cost, Investment, Enjoyment.
  // Income = only positive amounts from the 'Income' category (salary, tax refunds, etc.)
  // Living/Enjoy = net of all amounts in those categories, so refunds/bonuses reduce the outflow
  // Investment = outflow only (money sent TO investments) — treated like spend, it reduces
  // Saving. Investment inflows (sell-trades, dividends) are excluded, never added back.
  // Saving = Income - Living - Enjoyment - Investment outflow
  // Query: ?year=2025
  app.get('/api/summary/monthly-buckets', (req: Request, res: Response) => {
    const year = String(req.query.year ?? new Date().getFullYear());

    const rows = db.prepare(`
      SELECT
        substr(date, 1, 7) AS month,
        COALESCE(SUM(CASE WHEN amount_cents > 0 AND category = 'Income' THEN amount_cents END), 0) AS income_cents,
        COALESCE(SUM(CASE WHEN category IN (${LIVING_CATEGORIES_SQL}) THEN -amount_cents END), 0) AS living_cents,
        COALESCE(SUM(CASE WHEN category = 'Investments' THEN amount_cents END), 0) AS invest_net_cents,
        COALESCE(SUM(CASE WHEN category IN (${ENJOY_CATEGORIES_SQL}) THEN -amount_cents END), 0) AS enjoy_cents
      FROM transactions
      WHERE substr(date, 1, 4) = ?
        AND category != 'Internal Transfer'
        AND ${DOCUMENTATION_LINK_EXCLUSION_SQL}
      GROUP BY month
      ORDER BY month
    `).all(year) as any[];

    return res.json({
      months: rows.map(r => {
        // invest_cents = outflow only (money sent TO investments); reduces Saving below.
        const investBar = r.invest_net_cents < 0 ? -r.invest_net_cents : 0;
        const savingCents = computeSaving(r.income_cents, r.living_cents, r.enjoy_cents, investBar);
        return {
          month:         r.month,
          income_cents:  r.income_cents,
          living_cents:  r.living_cents,
          invest_cents:  investBar,
          enjoy_cents:   r.enjoy_cents,
          saving_cents:  savingCents,
        };
      }),
    });
  });

  // ===== GET /api/summary/cumulative-savings =====
  // All months across all time; returns per-month net saving + running cumulative.
  // net_saving = Income - net_living - net_enjoy - Investment outflow.
  // living/enjoy use SUM(-amount_cents) so refunds/bonuses in expense categories
  // naturally reduce the outflow (e.g. tax refunds, insurance bonuses, utility credits).
  // Investment outflow (money sent TO investments) is treated like spend, reducing
  // Saving; investment inflows (sell-trades, dividends) are excluded, never added back.
  app.get('/api/summary/cumulative-savings', (_req: Request, res: Response) => {
    const rows = db.prepare(`
      SELECT
        substr(date, 1, 7) AS month,
        COALESCE(SUM(CASE WHEN amount_cents > 0 AND category = 'Income' THEN amount_cents END), 0)   AS income_cents,
        COALESCE(SUM(CASE WHEN category IN (${LIVING_CATEGORIES_SQL}) THEN -amount_cents END), 0)    AS living_cents,
        COALESCE(SUM(CASE WHEN category = 'Investments' THEN amount_cents END), 0)                   AS invest_net_cents,
        COALESCE(SUM(CASE WHEN category IN (${ENJOY_CATEGORIES_SQL}) THEN -amount_cents END), 0)     AS enjoy_cents
      FROM transactions
      WHERE category != 'Internal Transfer'
        AND ${DOCUMENTATION_LINK_EXCLUSION_SQL}
      GROUP BY month
      ORDER BY month
    `).all() as any[];

    let cumulative = 0;
    const months = rows.map(r => {
      const investOutflow = r.invest_net_cents < 0 ? -r.invest_net_cents : 0;
      const net = computeSaving(r.income_cents, r.living_cents, r.enjoy_cents, investOutflow);
      cumulative += net;
      return {
        month:            r.month,
        income_cents:     r.income_cents,
        living_cents:     r.living_cents,
        invest_cents:     investOutflow,
        enjoy_cents:      r.enjoy_cents,
        net_saving_cents: net,
        cumulative_cents: cumulative,
      };
    });

    return res.json({ months });
  });

  // ===== GET /api/summary/net-worth =====
  app.get('/api/summary/net-worth', (req: Request, res: Response) => {
    // Get all distinct dates from balance_snapshots
    const distinctDates = db
      .prepare(`SELECT DISTINCT date FROM balance_snapshots ORDER BY date`)
      .all() as any[];

    const points: any[] = [];

    for (const { date } of distinctDates) {
      // For each account, get the most recent balance snapshot at or before this date
      const snapshots = db
        .prepare(
          `SELECT account_id, balance_cents
         FROM balance_snapshots
         WHERE date <= ? AND id IN (
           SELECT MAX(id) FROM balance_snapshots
           WHERE account_id = account_id AND date <= ?
           GROUP BY account_id
         )
         ORDER BY account_id`
        )
        .all(date, date) as any[];

      // Build by_account map
      const by_account: Record<number, number> = {};
      let net_worth_cents = 0;

      // More efficient approach: for each account, find its most recent snapshot at or before date
      const accounts = db.prepare('SELECT id FROM accounts ORDER BY id').all() as any[];
      for (const { id: account_id } of accounts) {
        const snapshot = db
          .prepare(
            `SELECT balance_cents FROM balance_snapshots
           WHERE account_id = ? AND date <= ?
           ORDER BY date DESC
           LIMIT 1`
          )
          .get(account_id, date) as any;

        if (snapshot) {
          by_account[account_id] = snapshot.balance_cents;
          net_worth_cents += snapshot.balance_cents;
        }
      }

      points.push({ date, net_worth_cents, by_account });
    }

    return res.json({ points });
  });

  // ===== GET /api/rules =====
  app.get('/api/rules', (req: Request, res: Response) => {
    const rules = db.prepare('SELECT * FROM category_rules ORDER BY priority ASC').all() as any[];
    return res.json({ rules });
  });

  // ===== POST /api/rules =====
  app.post('/api/rules', (req: Request, res: Response) => {
    let { priority, match_field, match_type, match_pattern, target_category } = req.body;

    if (!CANONICAL_CATEGORIES.includes(target_category)) {
      return res.status(400).json({ error: `Invalid target_category: ${target_category}` });
    }
    if (!MATCH_TYPES.includes(match_type)) {
      return res.status(400).json({ error: `Invalid match_type: ${match_type}` });
    }

    // Auto-assign priority: max non-default priority + 10, avoiding 999
    if (!priority) {
      const row = db.prepare(
        `SELECT MAX(priority) AS m FROM category_rules WHERE priority < 999`
      ).get() as any;
      priority = (row?.m ?? 400) + 10;
      // Ensure uniqueness
      while (db.prepare('SELECT 1 FROM category_rules WHERE priority = ?').get(priority)) {
        priority++;
      }
    }

    try {
      const result = db.prepare(
        `INSERT INTO category_rules (priority, match_field, match_type, match_pattern, target_category)
         VALUES (?, ?, ?, ?, ?)`
      ).run(priority, match_field || 'description', match_type, match_pattern, target_category);

      return res.status(201).json({
        id: result.lastInsertRowid, priority,
        match_field: match_field || 'description', match_type, match_pattern, target_category,
      });
    } catch (error) {
      if (error instanceof Error && error.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'priority already exists' });
      }
      throw error;
    }
  });

  // ===== PATCH /api/rules/:id =====
  app.patch('/api/rules/:id', (req: Request, res: Response) => {
    const ruleId = parseInt(req.params.id, 10);
    const { priority, match_type, match_pattern, target_category } = req.body;

    if (target_category && !CANONICAL_CATEGORIES.includes(target_category)) {
      return res.status(400).json({ error: `Invalid target_category: ${target_category}` });
    }
    if (match_type && !MATCH_TYPES.includes(match_type)) {
      return res.status(400).json({ error: `Invalid match_type: ${match_type}` });
    }

    const existing = db.prepare('SELECT * FROM category_rules WHERE id = ?').get(ruleId) as any;
    if (!existing) return res.status(404).json({ error: 'not found' });

    try {
      db.prepare(
        `UPDATE category_rules
         SET priority = ?, match_type = ?, match_pattern = ?, target_category = ?
         WHERE id = ?`
      ).run(
        priority         ?? existing.priority,
        match_type       ?? existing.match_type,
        match_pattern    ?? existing.match_pattern,
        target_category  ?? existing.target_category,
        ruleId
      );
      return res.json(db.prepare('SELECT * FROM category_rules WHERE id = ?').get(ruleId));
    } catch (error) {
      if (error instanceof Error && error.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'priority already used by another rule' });
      }
      throw error;
    }
  });

  // ===== DELETE /api/rules/:id =====
  app.delete('/api/rules/:id', (req: Request, res: Response) => {
    const ruleId = parseInt(req.params.id, 10);
    const result = db.prepare('DELETE FROM category_rules WHERE id = ?').run(ruleId);
    if (result.changes === 0) return res.status(404).json({ error: 'not found' });
    return res.json({ id: ruleId, deleted: true });
  });

  // ===== POST /api/rules/run =====
  // Re-runs all rules against every non-manually-overridden transaction.
  // Returns { updated: N } — count of transactions whose category changed.
  app.post('/api/rules/run', (_req: Request, res: Response) => {
    const rules = dbGetAllCategoryRules(db);
    const updated = recategorizeAll(db, rules);
    return res.json({ updated });
  });

  // ─────────────────────────────────────────
  // PROPERTY & MORTGAGE ENDPOINTS
  // ─────────────────────────────────────────

  const RECURRING_COST_TYPES = ['rental_income', 'mortgage_payment', 'maintenance', 'property_tax'];
  const COST_TYPES = [...ACQUISITION_COST_TYPES, ...RECURRING_COST_TYPES, ...DOCUMENTATION_COST_TYPES];

  function enrichProperty(p: any): any {
    const mortgage = db
      .prepare('SELECT * FROM mortgages WHERE property_id = ? ORDER BY id DESC LIMIT 1')
      .get(p.id) as any;

    const costLinks = db.prepare(`
      SELECT pcl.cost_type, pcl.transaction_id, t.date, t.description, t.amount_cents, t.account_id
      FROM property_cost_links pcl
      JOIN transactions t ON t.id = pcl.transaction_id
      WHERE pcl.property_id = ?
    `).all(p.id) as any[];

    const total_acquisition_cost_cents = propertyTotalCost(p, db);

    // Sum linked own_capital transactions (money put in from own pocket)
    const ownCapitalLinks = costLinks.filter((l: any) => l.cost_type === 'own_capital');
    const own_capital_cents = ownCapitalLinks.reduce((s: number, l: any) => s + Math.abs(l.amount_cents), 0);

    // Sum linked tenant_deposit transactions (Mietkaution received — a
    // liability to be returned, not rental income; documentation only).
    const tenantDepositLinks = costLinks.filter((l: any) => l.cost_type === 'tenant_deposit');
    const tenant_deposit_cents = tenantDepositLinks.reduce((s: number, l: any) => s + Math.abs(l.amount_cents), 0);

    // Compute mortgage amortization from linked EMI transactions
    const emiLinks = costLinks.filter((l: any) => l.cost_type === 'mortgage_payment');
    const amortization = computeMortgageAmortization(mortgage, emiLinks);

    // Enrich cost_links with amortization split for EMI payments
    const amortMap = new Map<number, { interest_cents: number; principal_cents: number }>();
    for (const a of amortization.amortizedTransactions) {
      amortMap.set(a.transaction_id, { interest_cents: a.interest_cents, principal_cents: a.principal_cents });
    }

    const enrichedCostLinks = costLinks.map((l: any) => {
      const am = amortMap.get(l.transaction_id);
      return am ? { ...l, interest_cents: am.interest_cents, principal_cents: am.principal_cents } : l;
    });

    const outstanding_balance_cents = mortgage?.outstanding_balance_cents ?? 0;
    const effective_outstanding_balance_cents = outstanding_balance_cents - amortization.total_principal_paid_cents;

    // Equity = estimated_value - total_acquisition_cost + principal paid (equity built through EMI)
    const current_equity_cents = p.estimated_value_cents
      ? p.estimated_value_cents - total_acquisition_cost_cents + amortization.total_principal_paid_cents
      : null;
    const ltv =
      p.estimated_value_cents && p.estimated_value_cents > 0
        ? effective_outstanding_balance_cents / p.estimated_value_cents
        : total_acquisition_cost_cents > 0
          ? effective_outstanding_balance_cents / total_acquisition_cost_cents
          : null;

    return {
      ...p,
      total_acquisition_cost_cents,
      mortgage: mortgage ?? null,
      own_capital_cents,
      tenant_deposit_cents,
      current_equity_cents,
      ltv_ratio: ltv,
      cost_links: enrichedCostLinks,
      total_principal_paid_cents: amortization.total_principal_paid_cents,
      total_interest_paid_cents: amortization.total_interest_paid_cents,
      effective_outstanding_balance_cents,
    };
  }

  // GET /api/properties
  app.get('/api/properties', (_req: Request, res: Response) => {
    const rows = db.prepare('SELECT * FROM properties ORDER BY id').all() as any[];
    return res.json({ properties: rows.map(enrichProperty) });
  });

  // POST /api/properties
  app.post('/api/properties', (req: Request, res: Response) => {
    const {
      name, address,
      purchase_price_cents, purchase_date,
      grunderwerbsteuer_cents = 0,
      notarkosten_cents = 0,
      maklergebuehr_cents = 0,
      grundbuchkosten_cents = 0,
      estimated_value_cents,
      estimated_value_date,
      building_completion_year,
      land_value_cents = 0,
    } = req.body;

    if (!name || !purchase_price_cents || !purchase_date) {
      return res.status(400).json({ error: 'Missing required fields: name, purchase_price_cents, purchase_date' });
    }

    const result = db.prepare(`
      INSERT INTO properties
        (name, address, purchase_price_cents, purchase_date,
         grunderwerbsteuer_cents, notarkosten_cents, maklergebuehr_cents, grundbuchkosten_cents,
         estimated_value_cents, estimated_value_date,
         building_completion_year, land_value_cents)
      VALUES (?,?,?,?,?,?,?,?,?,?,?,?)
    `).run(
      name, address ?? null,
      purchase_price_cents, purchase_date,
      grunderwerbsteuer_cents, notarkosten_cents, maklergebuehr_cents, grundbuchkosten_cents,
      estimated_value_cents ?? null, estimated_value_date ?? null,
      building_completion_year ?? null, land_value_cents,
    );

    const created = db.prepare('SELECT * FROM properties WHERE id = ?').get(result.lastInsertRowid) as any;
    return res.status(201).json(enrichProperty(created));
  });

  // PATCH /api/properties/:id
  app.patch('/api/properties/:id', (req: Request, res: Response) => {
    const propId = parseInt(req.params.id, 10);
    const existing = db.prepare('SELECT * FROM properties WHERE id = ?').get(propId) as any;
    if (!existing) return res.status(404).json({ error: 'not found' });

    const {
      name, address,
      purchase_price_cents, purchase_date,
      grunderwerbsteuer_cents, notarkosten_cents, maklergebuehr_cents, grundbuchkosten_cents,
      estimated_value_cents, estimated_value_date,
      building_completion_year, land_value_cents,
    } = req.body;

    db.prepare(`
      UPDATE properties SET
        name = ?,
        address = ?,
        purchase_price_cents = ?,
        purchase_date = ?,
        grunderwerbsteuer_cents = ?,
        notarkosten_cents = ?,
        maklergebuehr_cents = ?,
        grundbuchkosten_cents = ?,
        estimated_value_cents = ?,
        estimated_value_date = ?,
        building_completion_year = ?,
        land_value_cents = ?
      WHERE id = ?
    `).run(
      name                    ?? existing.name,
      address                 ?? existing.address,
      purchase_price_cents    ?? existing.purchase_price_cents,
      purchase_date           ?? existing.purchase_date,
      grunderwerbsteuer_cents ?? existing.grunderwerbsteuer_cents,
      notarkosten_cents       ?? existing.notarkosten_cents,
      maklergebuehr_cents     ?? existing.maklergebuehr_cents,
      grundbuchkosten_cents   ?? existing.grundbuchkosten_cents,
      estimated_value_cents   ?? existing.estimated_value_cents,
      estimated_value_date    ?? existing.estimated_value_date,
      building_completion_year ?? existing.building_completion_year,
      land_value_cents        ?? existing.land_value_cents,
      propId,
    );

    const updated = db.prepare('SELECT * FROM properties WHERE id = ?').get(propId) as any;
    return res.json(enrichProperty(updated));
  });

  // GET /api/properties/:id/summary
  app.get('/api/properties/:id/summary', (req: Request, res: Response) => {
    const propId = parseInt(req.params.id, 10);
    const prop = db.prepare('SELECT * FROM properties WHERE id = ?').get(propId) as any;
    if (!prop) return res.status(404).json({ error: 'not found' });

    // Monthly cash flow for the last 13 months
    const months: any[] = [];
    const now = new Date();
    for (let i = 12; i >= 0; i--) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      const monthStr = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;

      // Sum property_transactions for this month
      const rows = db.prepare(`
        SELECT type, SUM(amount_cents) as total
        FROM property_transactions
        WHERE property_id = ? AND strftime('%Y-%m', date) = ?
