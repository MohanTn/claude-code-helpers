using Dapper;
using FinanceAnalyser.Core.Models;
using Microsoft.Data.Sqlite;

namespace FinanceAnalyser.Data;

public static partial class Db
{
    /// <summary>
    /// Raw row shape for `category_rules` SELECTs. SQLite INTEGER columns are
    /// read back as Int64 by Microsoft.Data.Sqlite, which does not match
    /// `CategoryRule`'s `int?`/`int` constructor parameters closely enough
    /// for Dapper's constructor-based record materialization — so we query
    /// into this `long`-typed row first, then map to `CategoryRule`.
    /// </summary>
    private record CategoryRuleRow(
        long Id,
        long Priority,
        string MatchField,
        string MatchType,
        string? MatchPattern,
        string TargetCategory)
    {
        public CategoryRule ToCategoryRule() =>
            new((int)Id, (int)Priority, MatchField, MatchType, MatchPattern, TargetCategory);
    }

    /// <summary>All category rules, ordered by `priority` ASC. Ported from getAllCategoryRules.</summary>
    public static IReadOnlyList<CategoryRule> GetAllCategoryRules(SqliteConnection connection)
    {
        return connection.Query<CategoryRuleRow>(
            "SELECT id AS Id, priority AS Priority, match_field AS MatchField, match_type AS MatchType, match_pattern AS MatchPattern, target_category AS TargetCategory FROM category_rules ORDER BY priority ASC"
        ).Select(row => row.ToCategoryRule()).ToList();
    }

    /// <summary>
    /// If `category_rules` is empty, bulk-insert <paramref name="rules"/>.
    /// Idempotent: a non-empty table is left untouched (re-running with a
    /// different rule set will not conflict with the existing
    /// UNIQUE(priority) constraint). Ported from seedCategoryRulesIfEmpty.
    /// </summary>
    public static void SeedCategoryRulesIfEmpty(SqliteConnection connection, IReadOnlyList<CategoryRule> rules)
    {
        var count = connection.QuerySingle<long>("SELECT COUNT(*) FROM category_rules");
        if (count > 0)
        {
            return;
        }

        using var transaction = connection.BeginTransaction();
        foreach (var rule in rules)
        {
            connection.Execute(
                """
                INSERT OR IGNORE INTO category_rules (priority, match_field, match_type, match_pattern, target_category)
                VALUES (@Priority, @MatchField, @MatchType, @MatchPattern, @TargetCategory)
                """,
                new
                {
                    rule.Priority,
                    rule.MatchField,
                    rule.MatchType,
                    rule.MatchPattern,
                    rule.TargetCategory,
                },
                transaction);
        }
        transaction.Commit();
    }

    /// <summary>Look up a single category rule by `id`. Backs PATCH/DELETE /api/rules/:id's existence checks.</summary>
    public static CategoryRule? GetCategoryRuleById(SqliteConnection connection, long id)
    {
        return connection.QuerySingleOrDefault<CategoryRuleRow>(
            "SELECT id AS Id, priority AS Priority, match_field AS MatchField, match_type AS MatchType, match_pattern AS MatchPattern, target_category AS TargetCategory FROM category_rules WHERE id = @Id",
            new { Id = id })?.ToCategoryRule();
    }

    /// <summary>
    /// Inserts a new category rule. Ported from server.ts:640-645 (POST
    /// /api/rules). Lets a UNIQUE(priority) <see cref="SqliteException"/>
    /// bubble up to the caller, which maps it to 400.
    /// </summary>
    public static CategoryRule InsertCategoryRule(
        SqliteConnection connection,
        int priority,
        string matchField,
        string matchType,
        string? matchPattern,
        string targetCategory)
    {
        var id = connection.ExecuteScalar<long>(
            """
            INSERT INTO category_rules (priority, match_field, match_type, match_pattern, target_category)
            VALUES (@Priority, @MatchField, @MatchType, @MatchPattern, @TargetCategory);
            SELECT last_insert_rowid();
            """,
            new
            {
                Priority = priority,
                MatchField = matchField,
                MatchType = matchType,
                MatchPattern = matchPattern,
                TargetCategory = targetCategory,
            });

        return new CategoryRule((int)id, priority, matchField, matchType, matchPattern, targetCategory);
    }

    /// <summary>
    /// Partially updates a category rule: each `null` parameter falls back to
    /// the existing column value (mirrors server.ts:680-689's `?? existing.*`
    /// behavior — `priority` falls back via `int?`, the others via plain
    /// nullable strings since empty-string is a valid match_pattern value but
    /// "not provided" must still mean "keep existing"). Returns null if `id`
    /// does not exist. Lets a UNIQUE(priority) <see cref="SqliteException"/>
    /// bubble up to the caller, which maps it to 400.
    /// </summary>
    public static CategoryRule? UpdateCategoryRule(
        SqliteConnection connection,
        long id,
        int? priority,
        string? matchType,
        string? matchPattern,
        string? targetCategory)
    {
        var existing = GetCategoryRuleById(connection, id);
        if (existing is null)
        {
            return null;
        }

        var newPriority = priority ?? existing.Priority;
        var newMatchType = matchType ?? existing.MatchType;
        var newMatchPattern = matchPattern ?? existing.MatchPattern;
        var newTargetCategory = targetCategory ?? existing.TargetCategory;

        connection.Execute(
            """
            UPDATE category_rules
            SET priority = @Priority, match_type = @MatchType, match_pattern = @MatchPattern, target_category = @TargetCategory
            WHERE id = @Id
            """,
            new
            {
                Priority = newPriority,
                MatchType = newMatchType,
                MatchPattern = newMatchPattern,
                TargetCategory = newTargetCategory,
                Id = id,
            });

        return GetCategoryRuleById(connection, id);
    }

    /// <summary>Deletes the category rule `id`. Returns true if a row was deleted. Ported from server.ts:702-706.</summary>
    public static bool DeleteCategoryRule(SqliteConnection connection, long id)
    {
        var rowsAffected = connection.Execute(
            "DELETE FROM category_rules WHERE id = @Id",
            new { Id = id });
        return rowsAffected > 0;
    }

    /// <summary>
    /// `SELECT MAX(priority) FROM category_rules WHERE priority &lt; 999`,
    /// as a nullable result (null when no non-default rule exists yet) —
    /// mirrors server.ts:631-633's `row?.m`, leaving the `?? 400` fallback
    /// to the caller (matches the exact contract requested for this method).
    /// </summary>
    public static long? GetMaxNonDefaultPriority(SqliteConnection connection)
    {
        return connection.ExecuteScalar<long?>(
            "SELECT MAX(priority) FROM category_rules WHERE priority < 999");
    }

    /// <summary>Whether any category rule currently has the given `priority`. Used to find a free auto-assigned priority (server.ts:636-638).</summary>
    public static bool CategoryRulePriorityExists(SqliteConnection connection, int priority)
    {
        return connection.ExecuteScalar<long>(
            "SELECT COUNT(*) FROM category_rules WHERE priority = @Priority",
            new { Priority = priority }) > 0;
    }
}
using Dapper;
using FinanceAnalyser.Core.Models;
using FinanceAnalyser.Data.Models;
using Microsoft.Data.Sqlite;

namespace FinanceAnalyser.Data;

public static partial class Db
{
    /// <summary>Result of <see cref="InsertTransaction"/>. Mirrors the TS `{ inserted: boolean; id?: number }` return shape.</summary>
    public record InsertTransactionResult(bool Inserted, long? Id);

    /// <summary>
    /// Inserts a categorized transaction for <paramref name="accountId"/>,
    /// deduping via UNIQUE(source_pdf, source_hash). Returns
    /// `Inserted = false` (without throwing) if the row already exists.
    /// Ported from insertTransaction.
    /// </summary>
    public static InsertTransactionResult InsertTransaction(
        SqliteConnection connection,
        long accountId,
        CategorizedTransaction txn,
        string sourceHash)
    {
        using var command = connection.CreateCommand();
        command.CommandText =
            """
            INSERT OR IGNORE INTO transactions
              (account_id, date, description, amount_cents, currency, category, raw_text, source_pdf, source_hash)
            VALUES (@AccountId, @Date, @Description, @AmountCents, @Currency, @Category, @RawText, @SourcePdf, @SourceHash)
            """;
        command.Parameters.AddWithValue("@AccountId", accountId);
        command.Parameters.AddWithValue("@Date", txn.Date);
        command.Parameters.AddWithValue("@Description", txn.Description);
        command.Parameters.AddWithValue("@AmountCents", txn.AmountCents);
        command.Parameters.AddWithValue("@Currency", txn.Currency);
        command.Parameters.AddWithValue("@Category", txn.Category);
        command.Parameters.AddWithValue("@RawText", txn.RawText);
        command.Parameters.AddWithValue("@SourcePdf", txn.SourcePdf);
        command.Parameters.AddWithValue("@SourceHash", sourceHash);

        command.ExecuteNonQuery();
        var changes = connection.ExecuteScalar<long>("SELECT changes()");

        if (changes == 0)
        {
            return new InsertTransactionResult(false, null);
        }

        var lastRowId = connection.ExecuteScalar<long>("SELECT last_insert_rowid()");
        return new InsertTransactionResult(true, lastRowId);
    }

    /// <summary>
    /// Rows eligible for re-categorization: `{ Id, Description, Category,
    /// IsManualOverride }`, optionally filtered to a single account. Ported
    /// from getTransactionsForRecategorization.
    /// </summary>
    public static IReadOnlyList<RecategorizationRow> GetTransactionsForRecategorization(
        SqliteConnection connection,
        long? accountId = null)
    {
        if (accountId is not null)
        {
            return connection.Query<RecategorizationRow>(
                """
                SELECT id AS Id, description AS Description, category AS Category, is_manual_override AS IsManualOverride
                FROM transactions
                WHERE account_id = @AccountId
                """,
                new { AccountId = accountId.Value }
            ).ToList();
        }

        return connection.Query<RecategorizationRow>(
            """
            SELECT id AS Id, description AS Description, category AS Category, is_manual_override AS IsManualOverride
            FROM transactions
            """
        ).ToList();
    }

    /// <summary>Updates the `category` of transaction `id`. Ported from updateTransactionCategory.</summary>
    public static void UpdateTransactionCategory(SqliteConnection connection, long id, string category)
    {
        connection.Execute(
            "UPDATE transactions SET category = @Category WHERE id = @Id",
            new { Category = category, Id = id });
    }

    private const string TransactionRecordSelectColumns =
        "id AS Id, account_id AS AccountId, date AS Date, description AS Description, amount_cents AS AmountCents, currency AS Currency, category AS Category, is_manual_override AS IsManualOverride, raw_text AS RawText, source_pdf AS SourcePdf, source_hash AS SourceHash, created_at AS CreatedAt";

    /// <summary>
    /// Dynamic, paginated transaction query backing GET /api/transactions.
    /// Ported from server.ts:247-301: builds the same `WHERE 1=1 AND ...`
    /// clause (account_id / category / date range / search-across-description-
    /// and-formatted-amount), counts matches, then fetches a page ordered by
    /// `date DESC`.
    /// </summary>
    public static (IReadOnlyList<TransactionRecord> Transactions, long Total) QueryTransactions(
        SqliteConnection connection,
        long? accountId,
        string? category,
        string? startDate,
        string? endDate,
        string? search,
        int limit,
        int offset)
    {
        var whereClauses = new List<string> { "1=1" };
        var parameters = new DynamicParameters();

        if (accountId is not null)
        {
            whereClauses.Add("account_id = @AccountId");
            parameters.Add("AccountId", accountId.Value);
        }
        if (category is not null)
        {
            whereClauses.Add("category = @Category");
            parameters.Add("Category", category);
        }
        if (startDate is not null)
        {
            whereClauses.Add("date >= @StartDate");
            parameters.Add("StartDate", startDate);
        }
        if (endDate is not null)
        {
            whereClauses.Add("date <= @EndDate");
            parameters.Add("EndDate", endDate);
        }
        if (search is not null && search.Trim() is { Length: > 0 } trimmedSearch)
        {
            var s = $"%{trimmedSearch}%";
            whereClauses.Add(
                "(description LIKE @Search1 OR CAST(ABS(amount_cents) AS TEXT) LIKE @Search2 OR printf('%.2f', ABS(amount_cents)/100.0) LIKE @Search3)");
            parameters.Add("Search1", s);
            parameters.Add("Search2", s);
            parameters.Add("Search3", s);
        }

        var whereClause = string.Join(" AND ", whereClauses);

        var total = connection.ExecuteScalar<long>(
            $"SELECT COUNT(*) FROM transactions WHERE {whereClause}",
            parameters);

        parameters.Add("Limit", limit);
        parameters.Add("Offset", offset);

        var transactions = connection.Query<TransactionRecord>(
            $"""
            SELECT {TransactionRecordSelectColumns}
            FROM transactions
            WHERE {whereClause}
            ORDER BY date DESC
            LIMIT @Limit OFFSET @Offset
            """,
            parameters).ToList();

        return (transactions, total);
    }

    /// <summary>Look up a single transaction by `id`. Backs PATCH /api/transactions/:id's existence check.</summary>
    public static TransactionRecord? GetTransactionById(SqliteConnection connection, long id)
    {
        return connection.QuerySingleOrDefault<TransactionRecord>(
            $"SELECT {TransactionRecordSelectColumns} FROM transactions WHERE id = @Id",
            new { Id = id });
    }

    /// <summary>
    /// Sets `category` AND `is_manual_override = 1` on transaction `id`.
    /// Distinct from <see cref="UpdateTransactionCategory"/> (which leaves
    /// `is_manual_override` untouched, used by the rule-engine re-run path).
    /// Ported from server.ts:316-319 (PATCH /api/transactions/:id).
    /// </summary>
    public static void SetTransactionCategoryManual(SqliteConnection connection, long id, string category)
    {
        connection.Execute(
            "UPDATE transactions SET category = @Category, is_manual_override = 1 WHERE id = @Id",
            new { Category = category, Id = id });
    }
}
