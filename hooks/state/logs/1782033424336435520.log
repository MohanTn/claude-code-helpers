     4	
     5	namespace FinanceAnalyser.Data;
     6	
     7	public static partial class Db
     8	{
     9	    /// <summary>
    10	    /// Inserts or replaces the balance snapshot for <paramref name="accountId"/>
    11	    /// on <paramref name="snapshot"/>.Date (keyed on UNIQUE(account_id, date)).
    12	    /// Ported from upsertBalanceSnapshot. Note the TS implementation
    13	    /// hardcodes currency to 'EUR' in the INSERT statement (it does not take
    14	    /// a currency parameter) — preserved verbatim here.
    15	    /// </summary>
    16	    public static void UpsertBalanceSnapshot(
    17	        SqliteConnection connection,
    18	        long accountId,
    19	        BalanceSnapshot snapshot,
    20	        string sourcePdf)
    21	    {
    22	        connection.Execute(
    23	            """
    24	            INSERT OR REPLACE INTO balance_snapshots (account_id, date, balance_cents, currency, source_pdf)
    25	            VALUES (@AccountId, @Date, @BalanceCents, 'EUR', @SourcePdf)
    26	            """,
    27	            new
    28	            {
    29	                AccountId = accountId,
    30	                snapshot.Date,
    31	                snapshot.BalanceCents,
    32	                SourcePdf = sourcePdf,
    33	            });
    34	    }
    35	}
