     1	import { useState, type ReactNode } from 'react'
     2	import { useQuery, useQueries } from '@tanstack/react-query'
     3	import { FileDown, Printer } from 'lucide-react'
     4	import { Button } from '@/components/ui/button'
     5	import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog'
     6	import { getTaxSettings, getFreelanceIncome, type TaxFiler, type TaxCalculationResponse } from '../../api'
     7	import { queryKeys } from '@/lib/queryKeys'
     8	import { eur } from './helpers'
     9	
    10	function Section({ title, anlage, children }: { title: string; anlage?: string; children: ReactNode }) {
    11	  return (
    12	    <div className="mb-6 break-inside-avoid">
    13	      <h3 className="text-sm font-semibold text-slate-800 border-b border-slate-200 pb-1 mb-2">
    14	        {title}
    15	        {anlage && <span className="text-slate-400 font-normal"> — {anlage}</span>}
    16	      </h3>
    17	      <div className="space-y-1.5">{children}</div>
    18	    </div>
    19	  )
    20	}
    21	
    22	function Row({ label, german, value, note }: { label: string; german: string; value: string; note?: string }) {
    23	  return (
    24	    <div className="flex items-start justify-between gap-4 text-sm">
    25	      <div>
    26	        <div className="text-slate-700">{label}</div>
    27	        <div className="text-xs text-slate-400 italic">{german}</div>
    28	        {note && <div className="text-xs text-slate-400 mt-0.5 max-w-md">{note}</div>}
    29	      </div>
    30	      <div className="font-mono text-slate-900 whitespace-nowrap">{value}</div>
    31	    </div>
    32	  )
    33	}
    34	
    35	export function ElsterGuideDialog({
    36	  year, filers, calc,
    37	}: {
    38	  year: number
    39	  filers: TaxFiler[]
    40	  calc: TaxCalculationResponse
    41	}) {
    42	  const [open, setOpen] = useState(false)
    43	
    44	  const { data: settings } = useQuery({
    45	    queryKey: queryKeys.taxSettings(year),
    46	    queryFn: () => getTaxSettings(year),
    47	    enabled: open,
    48	  })
    49	
    50	  const freelancers = filers.filter(f => f.role === 'freelancer')
    51	  const freelanceQueries = useQueries({
    52	    queries: freelancers.map(f => ({
    53	      queryKey: queryKeys.freelanceIncome(f.id, year),
    54	      queryFn: () => getFreelanceIncome(f.id, year),
    55	      enabled: open,
    56	    })),
    57	  })
    58	
    59	  const payslipsByFiler = new Map<number, typeof calc.payslips>()
    60	  for (const p of calc.payslips) {
    61	    if (p.is_correction) continue
    62	    const list = payslipsByFiler.get(p.filer_id) ?? []
    63	    list.push(p)
    64	    payslipsByFiler.set(p.filer_id, list)
    65	  }
    66	
    67	  const rb = calc.rental_breakdown
    68	  const hasRental = !!rb && (
    69	    rb.rental_income_cents !== 0 || rb.mortgage_interest_cents !== 0 ||
    70	    rb.afa_cents !== 0 || rb.maintenance_cents !== 0 || rb.property_tax_cents !== 0
    71	  )
    72	
    73	  const filingStatusLabel = settings?.filing_status === 'single'
    74	    ? 'Einzelveranlagung (single)'
    75	    : 'Zusammenveranlagung (joint / Splitting)'
    76	
    77	  return (
    78	    <>
    79	      <Button variant="outline" size="sm" onClick={() => setOpen(true)} className="no-print">
    80	        <FileDown className="w-3.5 h-3.5" />
    81	        ELSTER Filing Guide
    82	      </Button>
    83	      <Dialog open={open} onOpenChange={setOpen}>
    84	        <DialogContent className="max-w-3xl max-h-[90vh] overflow-y-auto elster-dialog-content">
    85	          <DialogHeader className="no-print">
    86	            <DialogTitle>ELSTER Filing Guide — {year}</DialogTitle>
    87	          </DialogHeader>
    88	
    89	          <div className="elster-guide-print">
    90	            <div key="cover" className="mb-4">
    91	              <h2 className="text-lg font-semibold text-slate-900">German Income Tax Return ({year}) — Filing Guide</h2>
    92	              <p className="text-xs text-slate-500 mt-1">
    93	                Generated from Finance Analyser. This translates the figures already computed in the Income Tax tab into the
    94	                official German labels used in ELSTER, so you can find the right field and type in the right number.
    95	              </p>
    96	            </div>
    97	
    98	            <div key="disclaimer" className="mb-6 rounded-md border border-amber-200 bg-amber-50 p-3 text-xs text-amber-800 space-y-1">
    99	              <p><strong>This is an estimate, not an official submission.</strong> Match fields by their German label text in
   100	                ELSTER — exact "Zeile" (line) numbers shift between tax years.</p>
   101	              <p>Capital gains / dividends (Anlage KAP) are not covered by this tool — use your broker's annual tax certificate
   102	                (e.g. Trade Republic Steuerbescheinigung) separately.</p>
   103	              <p>Church tax shown below is what was already withheld from payslips; the Finanzamt reconciles it automatically
   104	                as part of your assessment.</p>
   105	            </div>
   106	
   107	            <Section key="filer-details" title="Filer details">
   108	              <Row label="Tax year" german="Steuerjahr" value={String(year)} />
   109	              {filers.map(f => (
   110	                <Row
   111	                  key={f.id}
   112	                  label={f.name}
   113	                  german={f.role === 'employee' ? 'Arbeitnehmer' : 'Selbstständig'}
   114	                  value={f.tax_id ?? '—'}
   115	                  note="Steuerliche Identifikationsnummer"
   116	                />
   117	              ))}
   118	              <Row label="Filing status" german="Veranlagungsart" value={filingStatusLabel} />
   119	              {settings?.bundesland && <Row label="State" german="Bundesland" value={settings.bundesland} />}
   120	            </Section>
   121	
   122	            {[...payslipsByFiler.entries()].map(([filerId, payslips]) => {
   123	              const filer = filers.find(f => f.id === filerId)
   124	              const gross = payslips.reduce((s, p) => s + p.gross_cents, 0)
   125	              const incomeTax = payslips.reduce((s, p) => s + p.income_tax_cents, 0)
   126	              const soli = payslips.reduce((s, p) => s + p.solidarity_surcharge_cents, 0)
   127	              const churchTax = payslips.reduce((s, p) => s + p.church_tax_cents, 0)
   128	              return (
   129	                <Section key={filerId} title={`Employment income — ${filer?.name ?? `Filer ${filerId}`}`} anlage="Anlage N">
   130	                  <Row label="Gross wages" german="Bruttoarbeitslohn" value={eur(gross)} />
   131	                  <Row label="Income tax withheld" german="Einbehaltene Lohnsteuer" value={eur(incomeTax)} />
   132	                  <Row label="Solidarity surcharge withheld" german="Einbehaltener Solidaritätszuschlag" value={eur(soli)} />
   133	                  {churchTax !== 0 && (
   134	                    <Row label="Church tax withheld" german="Einbehaltene Kirchensteuer" value={eur(churchTax)} />
   135	                  )}
   136	                </Section>
   137	              )
   138	            })}
   139	
   140	            <Section key="vorsorge" title="Provident expenses" anlage="Anlage Vorsorgeaufwand">
   141	              <Row label="Pension insurance" german="Rentenversicherungsbeiträge" value={eur(calc.vorsorge_breakdown.pension_cents)} />
   142	              <Row label="Unemployment insurance" german="Beiträge zur Arbeitslosenversicherung" value={eur(calc.vorsorge_breakdown.unemployment_cents)} />
   143	              <Row
   144	                label="Health & care insurance"
   145	                german="Beiträge zur Kranken-/Pflegeversicherung"
   146	                value={eur(calc.vorsorge_breakdown.health_cents + calc.vorsorge_breakdown.care_cents)}
   147	                note={calc.employer_health_care_subsidy_cents > 0
   148	                  ? `Net of ${eur(calc.employer_health_care_subsidy_cents)} tax-free employer subsidy, already excluded.`
   149	                  : undefined}
   150	              />
   151	            </Section>
   152	
   153	            {freelancers.map((f, i) => {
   154	              const fi = freelanceQueries[i]?.data
   155	              if (!fi || (fi.revenue_cents === 0 && fi.business_expenses_cents === 0)) return null
   156	              const profit = fi.revenue_cents - fi.business_expenses_cents
   157	              return (
   158	                <Section key={f.id} title={`Self-employment income — ${f.name}`} anlage="Anlage S">
   159	                  <Row label="Business revenue" german="Betriebseinnahmen" value={eur(fi.revenue_cents)} />
   160	                  <Row label="Business expenses" german="Betriebsausgaben" value={eur(fi.business_expenses_cents)} />
   161	                  <Row label="Profit" german="Gewinn" value={eur(profit)} />
   162	                  {fi.advance_tax_paid_cents > 0 && (
   163	                    <Row
   164	                      label="Advance tax paid"
   165	                      german="Vorauszahlungen"
   166	                      value={eur(fi.advance_tax_paid_cents)}
   167	                      note="Enter this on the main form (Hauptformular), not Anlage S — it offsets your final tax bill."
   168	                    />
   169	                  )}
   170	                </Section>
   171	              )
   172	            })}
   173	
   174	            {hasRental && rb && (
   175	              <Section key="rental" title="Rental income" anlage="Anlage V">
   176	                <Row label="Rental income" german="Mieteinnahmen" value={eur(rb.rental_income_cents)} />
   177	                <Row label="Mortgage interest" german="Schuldzinsen" value={eur(rb.mortgage_interest_cents)} />
   178	                <Row label="Depreciation" german="Abschreibung (AfA)" value={eur(rb.afa_cents)} />
   179	                <Row label="Maintenance & repairs" german="Erhaltungsaufwendungen" value={eur(rb.maintenance_cents)} />
   180	                <Row label="Property tax" german="Grundsteuer" value={eur(rb.property_tax_cents)} />
   181	                <Row label="Net rental result" german="Ergebnis aus Vermietung und Verpachtung" value={eur(calc.rental_result_cents)} />
   182	              </Section>
   183	            )}
   184	
   185	            <Section key="summary" title="Summary" anlage="Hauptformular">
   186	              <Row label="Employee flat-rate deduction" german="Werbungskosten-Pauschbetrag" value={eur(calc.werbungskosten_cents)} />
   187	              <Row label="Special expenses allowance" german="Sonderausgaben-Pauschbetrag" value={eur(calc.sonderausgaben_pauschbetrag_cents)} />
   188	              <Row label="Provident expense deduction" german="Vorsorgeaufwendungen" value={eur(calc.vorsorgeaufwendungen_cents)} />
   189	              <Row label="Taxable income" german="Zu versteuerndes Einkommen (zvE)" value={eur(calc.taxable_income_cents)} />
   190	              <Row label="Income tax" german="Tarifliche Einkommensteuer (§32a EStG)" value={eur(calc.income_tax_cents)} />
   191	              <Row label="Solidarity surcharge" german="Solidaritätszuschlag" value={eur(calc.solidarity_surcharge_cents)} />
   192	              <Row label="Already paid (withheld + advance payments)" german="Bereits gezahlte Steuer" value={eur(calc.already_withheld_cents)} />
   193	              <Row
   194	                label={calc.refund_or_owed_cents >= 0 ? 'Estimated refund' : 'Estimated amount owed'}
   195	                german="Erstattung / Nachzahlung (Schätzung)"
   196	                value={eur(Math.abs(calc.refund_or_owed_cents))}
   197	                note="Estimate only — the Finanzamt's official assessment may differ."
   198	              />
   199	            </Section>
   200	          </div>
   201	
   202	          <div className="flex justify-end gap-2 mt-2 no-print">
   203	            <Button variant="outline" onClick={() => setOpen(false)}>Close</Button>
   204	            <Button onClick={() => window.print()}>
   205	              <Printer className="w-3.5 h-3.5" />
   206	              Print / Save as PDF
   207	            </Button>
   208	          </div>
   209	        </DialogContent>
   210	      </Dialog>
   211	    </>
   212	  )
   213	}
