    94	    /// <summary>
    95	    /// Dynamic, paginated transaction query backing GET /api/transactions.
    96	    /// Ported from server.ts:247-301: builds the same `WHERE 1=1 AND ...`
    97	    /// clause (account_id / category / date range / search-across-description-
    98	    /// and-formatted-amount), counts matches, then fetches a page ordered by
    99	    /// `date DESC`.
   100	    /// </summary>
   101	    public static (IReadOnlyList<TransactionRecord> Transactions, long Total) QueryTransactions(
   102	        SqliteConnection connection,
   103	        long? accountId,
   104	        string? category,
   105	        string? startDate,
   106	        string? endDate,
   107	        string? search,
   108	        int limit,
   109	        int offset)
   110	    {
   111	        var whereClauses = new List<string> { "1=1" };
   112	        var parameters = new DynamicParameters();
   113	
   114	        if (accountId is not null)
   115	        {
   116	            whereClauses.Add("account_id = @AccountId");
   117	            parameters.Add("AccountId", accountId.Value);
   118	        }
   119	        if (category is not null)
   120	        {
   121	            whereClauses.Add("category = @Category");
   122	            parameters.Add("Category", category);
   123	        }
   124	        if (startDate is not null)
   125	        {
   126	            whereClauses.Add("date >= @StartDate");
   127	            parameters.Add("StartDate", startDate);
   128	        }
   129	        if (endDate is not null)
   130	        {
   131	            whereClauses.Add("date <= @EndDate");
   132	            parameters.Add("EndDate", endDate);
   133	        }
   134	        if (search is not null && search.Trim() is { Length: > 0 } trimmedSearch)
   135	        {
   136	            var s = $"%{trimmedSearch}%";
   137	            whereClauses.Add(
   138	                "(description LIKE @Search1 OR CAST(ABS(amount_cents) AS TEXT) LIKE @Search2 OR printf('%.2f', ABS(amount_cents)/100.0) LIKE @Search3)");
   139	            parameters.Add("Search1", s);
   140	            parameters.Add("Search2", s);
   141	            parameters.Add("Search3", s);
   142	        }
   143	
   144	        var whereClause = string.Join(" AND ", whereClauses);
   145	
   146	        var total = connection.ExecuteScalar<long>(
   147	            $"SELECT COUNT(*) FROM transactions WHERE {whereClause}",
   148	            parameters);
   149	
   150	        parameters.Add("Limit", limit);
   151	        parameters.Add("Offset", offset);
   152	
   153	        var transactions = connection.Query<TransactionRecord>(
   154	            $"""
   155	            SELECT {TransactionRecordSelectColumns}
   156	            FROM transactions
   157	            WHERE {whereClause}
   158	            ORDER BY date DESC
   159	            LIMIT @Limit OFFSET @Offset
   160	            """,
   161	            parameters).ToList();
   162	
   163	        return (transactions, total);
   164	    }
