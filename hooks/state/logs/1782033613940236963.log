    68	                FROM transactions
    69	                WHERE account_id = @AccountId
    70	                """,
    71	                new { AccountId = accountId.Value }
    72	            ).ToList();
    73	        }
    74	
    75	        return connection.Query<RecategorizationRow>(
    76	            """
    77	            SELECT id AS Id, description AS Description, category AS Category, is_manual_override AS IsManualOverride
    78	            FROM transactions
    79	            """
    80	        ).ToList();
    81	    }
