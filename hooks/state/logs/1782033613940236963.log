    91	    private const string TransactionRecordSelectColumns =
    92	        "id AS Id, account_id AS AccountId, date AS Date, description AS Description, amount_cents AS AmountCents, currency AS Currency, category AS Category, is_manual_override AS IsManualOverride, raw_text AS RawText, source_pdf AS SourcePdf, source_hash AS SourceHash, created_at AS CreatedAt";
