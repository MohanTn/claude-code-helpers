   165	    /// <summary>
   166	    /// `SELECT MAX(priority) FROM category_rules WHERE priority &lt; 999`,
   167	    /// as a nullable result (null when no non-default rule exists yet) —
   168	    /// mirrors server.ts:631-633's `row?.m`, leaving the `?? 400` fallback
   169	    /// to the caller (matches the exact contract requested for this method).
   170	    /// </summary>
   171	    public static long? GetMaxNonDefaultPriority(SqliteConnection connection)
   172	    {
   173	        return connection.ExecuteScalar<long?>(
   174	            "SELECT MAX(priority) FROM category_rules WHERE priority < 999");
   175	    }
   176	
   177	    /// <summary>Whether any category rule currently has the given `priority`. Used to find a free auto-assigned priority (server.ts:636-638).</summary>
   178	    public static bool CategoryRulePriorityExists(SqliteConnection connection, int priority)
   179	    {
   180	        return connection.ExecuteScalar<long>(
   181	            "SELECT COUNT(*) FROM category_rules WHERE priority = @Priority",
   182	            new { Priority = priority }) > 0;
   183	    }
   184	}
