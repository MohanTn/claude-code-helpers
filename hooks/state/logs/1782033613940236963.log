    10	    /// <summary>Result of <see cref="InsertTransaction"/>. Mirrors the TS `{ inserted: boolean; id?: number }` return shape.</summary>
    11	    public record InsertTransactionResult(bool Inserted, long? Id);
    12	
    13	    /// <summary>
    14	    /// Inserts a categorized transaction for <paramref name="accountId"/>,
    15	    /// deduping via UNIQUE(source_pdf, source_hash). Returns
    16	    /// `Inserted = false` (without throwing) if the row already exists.
    17	    /// Ported from insertTransaction.
    18	    /// </summary>
    19	    public static InsertTransactionResult InsertTransaction(
    20	        SqliteConnection connection,
    21	        long accountId,
    22	        CategorizedTransaction txn,
    23	        string sourceHash)
    24	    {
    25	        using var command = connection.CreateCommand();
    26	        command.CommandText =
    27	            """
    28	            INSERT OR IGNORE INTO transactions
    29	              (account_id, date, description, amount_cents, currency, category, raw_text, source_pdf, source_hash)
    30	            VALUES (@AccountId, @Date, @Description, @AmountCents, @Currency, @Category, @RawText, @SourcePdf, @SourceHash)
    31	            """;
    32	        command.Parameters.AddWithValue("@AccountId", accountId);
    33	        command.Parameters.AddWithValue("@Date", txn.Date);
    34	        command.Parameters.AddWithValue("@Description", txn.Description);
    35	        command.Parameters.AddWithValue("@AmountCents", txn.AmountCents);
    36	        command.Parameters.AddWithValue("@Currency", txn.Currency);
    37	        command.Parameters.AddWithValue("@Category", txn.Category);
    38	        command.Parameters.AddWithValue("@RawText", txn.RawText);
    39	        command.Parameters.AddWithValue("@SourcePdf", txn.SourcePdf);
    40	        command.Parameters.AddWithValue("@SourceHash", sourceHash);
    41	
    42	        command.ExecuteNonQuery();
    43	        var changes = connection.ExecuteScalar<long>("SELECT changes()");
    44	
    45	        if (changes == 0)
    46	        {
    47	            return new InsertTransactionResult(false, null);
    48	        }
    49	
    50	        var lastRowId = connection.ExecuteScalar<long>("SELECT last_insert_rowid()");
    51	        return new InsertTransactionResult(true, lastRowId);
    52	    }
