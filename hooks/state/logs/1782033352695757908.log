   670	    }
   671	    if (match_type && !MATCH_TYPES.includes(match_type)) {
   672	      return res.status(400).json({ error: `Invalid match_type: ${match_type}` });
   673	    }
   674	
   675	    const existing = db.prepare('SELECT * FROM category_rules WHERE id = ?').get(ruleId) as any;
   676	    if (!existing) return res.status(404).json({ error: 'not found' });
   677	
   678	    try {
   679	      db.prepare(
   680	        `UPDATE category_rules
   681	         SET priority = ?, match_type = ?, match_pattern = ?, target_category = ?
   682	         WHERE id = ?`
   683	      ).run(
   684	        priority         ?? existing.priority,
   685	        match_type       ?? existing.match_type,
   686	        match_pattern    ?? existing.match_pattern,
   687	        target_category  ?? existing.target_category,
   688	        ruleId
   689	      );
   690	      return res.json(db.prepare('SELECT * FROM category_rules WHERE id = ?').get(ruleId));
   691	    } catch (error) {
   692	      if (error instanceof Error && error.message.includes('UNIQUE constraint failed')) {
   693	        return res.status(400).json({ error: 'priority already used by another rule' });
   694	      }
   695	      throw error;
   696	    }
   697	  });
