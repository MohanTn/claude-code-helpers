   716	  // ─────────────────────────────────────────
   717	  // PROPERTY & MORTGAGE ENDPOINTS
   718	  // ─────────────────────────────────────────
   719	
   720	  const RECURRING_COST_TYPES = ['rental_income', 'mortgage_payment', 'maintenance', 'property_tax'];
   721	  const COST_TYPES = [...ACQUISITION_COST_TYPES, ...RECURRING_COST_TYPES, ...DOCUMENTATION_COST_TYPES];
   722	
   723	  function enrichProperty(p: any): any {
   724	    const mortgage = db
   725	      .prepare('SELECT * FROM mortgages WHERE property_id = ? ORDER BY id DESC LIMIT 1')
   726	      .get(p.id) as any;
   727	
   728	    const costLinks = db.prepare(`
   729	      SELECT pcl.cost_type, pcl.transaction_id, t.date, t.description, t.amount_cents, t.account_id
   730	      FROM property_cost_links pcl
   731	      JOIN transactions t ON t.id = pcl.transaction_id
   732	      WHERE pcl.property_id = ?
   733	    `).all(p.id) as any[];
   734	
   735	    const total_acquisition_cost_cents = propertyTotalCost(p, db);
   736	
   737	    // Sum linked own_capital transactions (money put in from own pocket)
   738	    const ownCapitalLinks = costLinks.filter((l: any) => l.cost_type === 'own_capital');
   739	    const own_capital_cents = ownCapitalLinks.reduce((s: number, l: any) => s + Math.abs(l.amount_cents), 0);
   740	
   741	    // Sum linked tenant_deposit transactions (Mietkaution received — a
   742	    // liability to be returned, not rental income; documentation only).
   743	    const tenantDepositLinks = costLinks.filter((l: any) => l.cost_type === 'tenant_deposit');
   744	    const tenant_deposit_cents = tenantDepositLinks.reduce((s: number, l: any) => s + Math.abs(l.amount_cents), 0);
   745	
   746	    // Compute mortgage amortization from linked EMI transactions
   747	    const emiLinks = costLinks.filter((l: any) => l.cost_type === 'mortgage_payment');
   748	    const amortization = computeMortgageAmortization(mortgage, emiLinks);
   749	
   750	    // Enrich cost_links with amortization split for EMI payments
   751	    const amortMap = new Map<number, { interest_cents: number; principal_cents: number }>();
   752	    for (const a of amortization.amortizedTransactions) {
   753	      amortMap.set(a.transaction_id, { interest_cents: a.interest_cents, principal_cents: a.principal_cents });
   754	    }
   755	
   756	    const enrichedCostLinks = costLinks.map((l: any) => {
   757	      const am = amortMap.get(l.transaction_id);
   758	      return am ? { ...l, interest_cents: am.interest_cents, principal_cents: am.principal_cents } : l;
   759	    });
   760	
   761	    const outstanding_balance_cents = mortgage?.outstanding_balance_cents ?? 0;
   762	    const effective_outstanding_balance_cents = outstanding_balance_cents - amortization.total_principal_paid_cents;
   763	
   764	    // Equity = estimated_value - total_acquisition_cost + principal paid (equity built through EMI)
   765	    const current_equity_cents = p.estimated_value_cents
   766	      ? p.estimated_value_cents - total_acquisition_cost_cents + amortization.total_principal_paid_cents
   767	      : null;
   768	    const ltv =
   769	      p.estimated_value_cents && p.estimated_value_cents > 0
   770	        ? effective_outstanding_balance_cents / p.estimated_value_cents
   771	        : total_acquisition_cost_cents > 0
   772	          ? effective_outstanding_balance_cents / total_acquisition_cost_cents
   773	          : null;
   774	
   775	    return {
   776	      ...p,
   777	      total_acquisition_cost_cents,
   778	      mortgage: mortgage ?? null,
   779	      own_capital_cents,
   780	      tenant_deposit_cents,
   781	      current_equity_cents,
   782	      ltv_ratio: ltv,
   783	      cost_links: enrichedCostLinks,
   784	      total_principal_paid_cents: amortization.total_principal_paid_cents,
   785	      total_interest_paid_cents: amortization.total_interest_paid_cents,
   786	      effective_outstanding_balance_cents,
   787	    };
   788	  }
