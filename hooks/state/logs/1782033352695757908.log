   883	  // GET /api/properties/:id/summary
   884	  app.get('/api/properties/:id/summary', (req: Request, res: Response) => {
   885	    const propId = parseInt(req.params.id, 10);
   886	    const prop = db.prepare('SELECT * FROM properties WHERE id = ?').get(propId) as any;
   887	    if (!prop) return res.status(404).json({ error: 'not found' });
   888	
   889	    // Monthly cash flow for the last 13 months
   890	    const months: any[] = [];
   891	    const now = new Date();
   892	    for (let i = 12; i >= 0; i--) {
   893	      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
   894	      const monthStr = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
   895	
   896	      // Sum property_transactions for this month
   897	      const rows = db.prepare(`
   898	        SELECT type, SUM(amount_cents) as total
   899	        FROM property_transactions
   900	        WHERE property_id = ? AND strftime('%Y-%m', date) = ?
   901	        GROUP BY type
   902	      `).all(propId, monthStr) as any[];
   903	
   904	      const byType: Record<string, number> = {};
   905	      for (const r of rows) byType[r.type] = r.total;
   906	
   907	      // Sum linked bank transactions for this month (recurring types: rental_income, mortgage_payment, maintenance)
   908	      const linkedRows = db.prepare(`
   909	        SELECT pcl.cost_type, SUM(t.amount_cents) as total
   910	        FROM property_cost_links pcl
   911	        JOIN transactions t ON t.id = pcl.transaction_id
   912	        WHERE pcl.property_id = ? AND pcl.cost_type IN ('rental_income','mortgage_payment','maintenance','property_tax')
   913	          AND strftime('%Y-%m', t.date) = ?
   914	        GROUP BY pcl.cost_type
   915	      `).all(propId, monthStr) as any[];
   916	
   917	      for (const lr of linkedRows) {
   918	        byType[lr.cost_type] = (byType[lr.cost_type] ?? 0) + lr.total;
   919	      }
   920	
   921	      const rental_income = byType['rental_income'] ?? 0;
   922	      const mortgage_payment = byType['mortgage_payment'] ?? 0;
   923	      const property_tax = byType['property_tax'] ?? 0;
   924	      const expenses = Object.entries(byType)
   925	        .filter(([t]) => t !== 'rental_income')
   926	        .reduce((s, [, v]) => s + v, 0);
   927	      const net_cash_flow = rental_income + expenses; // expenses are negative
   928	
   929	      months.push({ month: monthStr, rental_income, mortgage_payment, property_tax, expenses, net_cash_flow });
   930	    }
   931	
   932	    return res.json({ ...enrichProperty(prop), monthly_cash_flow: months });
   933	  });
