     1	using System.Text.RegularExpressions;
     2	using FinanceAnalyser.Core.Models;
     3	
     4	namespace FinanceAnalyser.Parsers;
     5	
     6	/// <summary>
     7	/// DATEV "Brutto-Netto-Abrechnung" payslip parser. Ported from
     8	/// src/parsers/payslip-datev.ts.
     9	///
    10	/// A single DATEV PDF can contain multiple concatenated "blocks" — typically
    11	/// a current-month block plus one or more prior-month correction blocks
    12	/// (each marked "(N. NB)" in its header). Each block is delimited by its own
    13	/// line matching "Abrechnung der Brutto/Netto-Bezüge".
    14	///
    15	/// Within each block, the five headline monetary totals (Gesamt-Brutto,
    16	/// Steuerrechtliche Abzüge, SV-rechtliche Abzüge, Netto-Verdienst,
    17	/// Auszahlungsbetrag) are printed as a label on one line with the value on
    18	/// the line immediately below it, right-aligned (an artifact of
    19	/// `pdftotext -layout` splitting multi-row table cells). The value lines
    20	/// also contain other "squeezed" numbers (comma stripped, e.g. "6.09583")
    21	/// in earlier columns — those are unreliable and must be ignored; only the
    22	/// rightmost properly comma-formatted number (`[\d.]+,\d{2}` with an
    23	/// optional trailing `-`) on the value line is taken.
    24	///
    25	/// "Gesamt-Brutto" additionally appears a second time per block, further
    26	/// down, inside a year-to-date "Verdienstbescheinigung" cumulative
    27	/// mini-table, in an inline label-and-value-on-the-same-line,
    28	/// comma-squeezed format. That occurrence must NOT be used — only the
    29	/// FIRST occurrence of each label (scanning top-to-bottom within the block)
    30	/// is the correct single-month figure.
    31	/// </summary>
    32	public static class PayslipDatevParser
    33	{
    34	    private const string SourceFormat = "datev";
    35	
    36	    private const string SkipSniffString = "Meldebescheinigung zur Sozialversicherung";
    37	
    38	    private static readonly Regex BlockHeaderRe = new(
    39	        @"^Abrechnung der Brutto/Netto-Bezüge.*$",
    40	        RegexOptions.Compiled);
    41	
    42	    // Header line: "... für <Month>[.] <Year>[ (N. NB)] ... <dd.mm.yyyy> Blatt: ..."
    43	    private static readonly Regex HeaderInfoRe = new(
    44	        @"für\s+([A-Za-zÀ-ÖØ-öø-ÿ]+)\.?\s+(\d{4})(?:\s*\((\d+)\.\s*NB\))?.*?(\d{2}\.\d{2}\.\d{4})\s+Blatt:",
    45	        RegexOptions.Compiled);
    46	
    47	    // Rightmost properly comma-formatted amount on a line, e.g. "6.095,83" or "817,65-".
    48	    private static readonly Regex ValueRe = new(@"([\d.]+,\d{2}-?)\s*$", RegexOptions.Compiled);
    49	
    50	    /// <summary>
    51	    /// Finds the first line (after <paramref name="fromIndex"/>) containing
    52	    /// <paramref name="label"/>, then extracts the rightmost
    53	    /// properly-formatted amount from the line immediately below it.
    54	    /// </summary>
    55	    private static long ExtractLabelOnNextLineValue(IReadOnlyList<string> lines, string label, int fromIndex)
    56	    {
    57	        for (var i = fromIndex; i < lines.Count; i++)
    58	        {
    59	            if (lines[i].Contains(label, StringComparison.Ordinal))
    60	            {
    61	                var valueLine = i + 1 < lines.Count ? lines[i + 1] : "";
    62	                var m = ValueRe.Match(valueLine);
    63	                if (m.Success)
    64	                {
    65	                    return ParseSignedGermanAmount(m.Groups[1].Value);
    66	                }
    67	                return 0;
    68	            }
    69	        }
    70	        return 0;
    71	    }
    72	
    73	    /// <summary>
    74	    /// Parses a German-formatted amount with an optional trailing "-"
    75	    /// (DATEV's deduction-sign convention) into signed cents, taking the
    76	    /// magnitude only (trailing "-" is stripped; callers want a positive
    77	    /// cents magnitude).
    78	    /// </summary>
    79	    private static long ParseSignedGermanAmount(string s)
    80	    {
    81	        var negative = s.EndsWith('-');
    82	        var cleaned = negative ? s[..^1] : s;
    83	        return Normalize.ParseDecimalToCents(cleaned, Normalize.DecimalSeparator.Comma);
    84	    }
    85	
    86	    /// <summary>
    87	    /// Extracts year-to-date line-item cents for a 9984/9996-style "Nr.
    88	    /// Bezeichnung ... Betrag" row, e.g. "9984 Gesamtbeitrag zur PV ...
    89	    /// 207,00-". Returns 0 if not found in this block.
    90	    /// </summary>
    91	    private static long ExtractLineItemCents(IReadOnlyList<string> lines, string code, int fromIndex, int toIndex)
    92	    {
    93	        var re = new Regex($@"\b{code}\b.*?([\d.]+,\d{{2}}-?)\s*$");
    94	        for (var i = fromIndex; i < toIndex; i++)
    95	        {
    96	            var m = re.Match(lines[i]);
    97	            if (m.Success)
    98	            {
    99	                return Math.Abs(ParseSignedGermanAmount(m.Groups[1].Value));
   100	            }
   101	        }
   102	        return 0;
   103	    }
   104	
   105	    private static ParsedPayslip ParseBlock(IReadOnlyList<string> blockLines, string sourcePdfName, string rawBlockText)
   106	    {
   107	        var headerLine = blockLines[0];
   108	        var headerMatch = HeaderInfoRe.Match(headerLine);
   109	        if (!headerMatch.Success)
   110	        {
   111	            throw new InvalidOperationException(
   112	                $"PayslipDatevParser: could not parse block header line: \"{headerLine}\"");
   113	        }
   114	
   115	        var monthToken = headerMatch.Groups[1].Value;
   116	        var yearStr = headerMatch.Groups[2].Value;
   117	        var nbLevel = headerMatch.Groups[3].Success ? headerMatch.Groups[3].Value : null;
   118	        var issueDateStr = headerMatch.Groups[4].Value;
   119	
   120	        if (!Normalize.GermanMonths.TryGetValue(monthToken.ToLowerInvariant(), out var month))
   121	        {
   122	            throw new InvalidOperationException(
   123	                $"PayslipDatevParser: unrecognized German month \"{monthToken}\"");
   124	        }
   125	        var year = int.Parse(yearStr);
   126	        var isCorrection = nbLevel is not null;
   127	        var issueDate = Normalize.DdMmYyyyToISO(issueDateStr);
   128	
   129	        // Tax class: line "Personal-Nr. ... StKl ..." header, data on the very
   130	        // next line; 3rd whitespace-separated token (index 2) is the tax class.
   131	        string? taxClass = null;
   132	        var personalNrHeaderIdx = -1;
   133	        for (var i = 0; i < blockLines.Count; i++)
   134	        {
   135	            if (blockLines[i].StartsWith("Personal-Nr.", StringComparison.Ordinal))
   136	            {
   137	                personalNrHeaderIdx = i;
   138	                break;
   139	            }
   140	        }
   141	        if (personalNrHeaderIdx != -1 && personalNrHeaderIdx + 1 < blockLines.Count)
   142	        {
   143	            var dataLine = blockLines[personalNrHeaderIdx + 1];
   144	            var tokens = dataLine.Trim().Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries);
   145	            taxClass = tokens.Length > 2 ? tokens[2] : null;
   146	        }
   147	
   148	        // Steuer-ID header line -> employer name + Steuer-ID on the NEXT line.
   149	        string? employerName = null;
   150	        var steuerIdHeaderIdx = -1;
   151	        for (var i = 0; i < blockLines.Count; i++)
   152	        {
   153	            if (blockLines[i].Contains("Steuer-ID", StringComparison.Ordinal))
   154	            {
   155	                steuerIdHeaderIdx = i;
   156	                break;
   157	            }
   158	        }
   159	        if (steuerIdHeaderIdx != -1)
   160	        {
   161	            var nextLine = steuerIdHeaderIdx + 1 < blockLines.Count ? blockLines[steuerIdHeaderIdx + 1] : "";
   162	            var starIdx = nextLine.IndexOf('*');
   163	            if (starIdx != -1)
   164	            {
   165	                var name = nextLine[..starIdx].Trim();
   166	                employerName = name.Length > 0 ? name : null;
   167	            }
   168	        }
   169	
   170	        var grossCents = ExtractLabelOnNextLineValue(blockLines, "Gesamt-Brutto", 0);
   171	        var incomeTaxCents = ExtractLabelOnNextLineValue(blockLines, "Steuerrechtliche Abzüge", 0);
   172	        var pensionCents = ExtractLabelOnNextLineValue(blockLines, "SV-rechtliche Abzüge", 0);
   173	        var netCents = ExtractLabelOnNextLineValue(blockLines, "Netto-Verdienst", 0);
   174	        var payoutCents = ExtractLabelOnNextLineValue(blockLines, "Auszahlungsbetrag", 0);
   175	
   176	        // 9984 -> Gesamtbeitrag zur PV (Pflegeversicherung = care), 9996 ->
   177	        // Gesamtbeitrag zur KV (Krankenversicherung = health). Present only in
   178	        // pre-2025 DATEV blocks; 0 otherwise.
   179	        var careCents = ExtractLineItemCents(blockLines, "9984", 0, blockLines.Count);
   180	        var healthCents = ExtractLineItemCents(blockLines, "9996", 0, blockLines.Count);
   181	
   182	        return new ParsedPayslip(
   183	            Year: year,
   184	            Month: month,
   185	            TaxClass: taxClass,
   186	            EmployerName: employerName,
   187	            GrossCents: grossCents,
   188	            // "Steuerrechtliche Abzüge" is the combined single-month
   189	            // tax-deduction figure; there's no reliably-extractable separate
   190	            // Lohnsteuer-only value given the comma-squeezed columns above
   191	            // it, so it's stored here as a proxy.
   192	            IncomeTaxCents: incomeTaxCents,
   193	            ChurchTaxCents: 0,
   194	            SolidaritySurchargeCents: 0,
   195	            // "SV-rechtliche Abzüge" is the combined social-insurance total
   196	            // (not RV-only).
   197	            PensionCents: pensionCents,
   198	            UnemploymentCents: 0,
   199	            HealthCents: healthCents,
   200	            CareCents: careCents,
   201	            NetCents: netCents,
   202	            PayoutCents: payoutCents,
   203	            IsCorrection: isCorrection,
   204	            SourceFormat: SourceFormat,
   205	            SourcePdf: sourcePdfName,
   206	            IssueDate: issueDate,
   207	            RawText: rawBlockText);
   208	    }
   209	
   210	    /// <summary>
   211	    /// Parses a DATEV "Brutto-Netto-Abrechnung" payslip PDF and returns all
   212	    /// payslips found in it. A single PDF may contain multiple blocks
   213	    /// (current month plus one or more prior-month corrections); each block
   214	    /// becomes one <see cref="ParsedPayslip"/>.
   215	    ///
   216	    /// Returns a result with an empty payslip list and a populated
   217	    /// SkippedReason for non-payslip DATEV documents (e.g.
   218	    /// "Meldebescheinigung zur Sozialversicherung").
   219	    /// </summary>
   220	    public static PayslipParseResult Parse(string pdfPath, string text)
   221	    {
   222	        if (text.Contains(SkipSniffString, StringComparison.Ordinal))
   223	        {
   224	            return new PayslipParseResult(new List<ParsedPayslip>(), $"{SkipSniffString} — not a payslip");
   225	        }
   226	
   227	        var sourcePdfName = Path.GetFileName(pdfPath);
   228	        var lines = text.Split('\n').ToList();
   229	
   230	        var blocks = Normalize.SplitBlocks(lines, BlockHeaderRe);
   231	        var payslips = new List<ParsedPayslip>();
   232	        foreach (var blockLines in blocks)
   233	        {
   234	            var rawBlockText = string.Join('\n', blockLines);
   235	            payslips.Add(ParseBlock(blockLines, sourcePdfName, rawBlockText));
   236	        }
   237	
   238	        return new PayslipParseResult(payslips, null);
   239	    }
   240	}
