    17	    /// <summary>All properties, ordered by `id`. Ported from server.ts:792 (GET /api/properties).</summary>
    18	    public static IReadOnlyList<PropertyRecord> GetAllProperties(SqliteConnection connection)
    19	    {
    20	        return connection.Query<PropertyRecord>(
    21	            $"SELECT {PropertyRecordSelectColumns} FROM properties ORDER BY id"
    22	        ).ToList();
    23	    }
    24	
    25	    /// <summary>Look up a property by `id`. Backs the existence checks throughout the property/mortgage routes.</summary>
    26	    public static PropertyRecord? GetPropertyById(SqliteConnection connection, long id)
    27	    {
    28	        return connection.QuerySingleOrDefault<PropertyRecord>(
    29	            $"SELECT {PropertyRecordSelectColumns} FROM properties WHERE id = @Id",
    30	            new { Id = id });
    31	    }
