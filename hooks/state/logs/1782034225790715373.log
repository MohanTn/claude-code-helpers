   139	    /// <summary>
   140	    /// The 5 acquisition cost types, in the exact order accumulated by
   141	    /// <see cref="GetPropertyTotalCostCents"/>. Ported from
   142	    /// src/property/amortization.ts's `ACQUISITION_COST_TYPES` (also
   143	    /// referenced as `ACQUISITION_COST_TYPES` at server.ts:678/33).
   144	    /// </summary>
   145	    public static readonly string[] AcquisitionCostTypes =
   146	    {
   147	        "purchase_price", "grunderwerbsteuer", "notarkosten", "maklergebuehr", "grundbuchkosten",
   148	    };
   149	
   150	    private static readonly string[] AcquisitionPropertyTransactionTypes =
   151	    {
   152	        "acquisition_purchase", "acquisition_notary", "acquisition_transfer_tax",
   153	        "acquisition_agent_fee", "acquisition_registry",
   154	    };
   155	
   156	    /// <summary>Row shape for the per-cost_type SUM(ABS(...)) query inside <see cref="GetPropertyTotalCostCents"/>.</summary>
   157	    private record LinkedCostTypeTotal(string CostType, long TotalCents);
   158	
   159	    /// <summary>
   160	    /// Total acquisition cost for a property in cents. Ported 1:1 from
   161	    /// src/property/amortization.ts:10-45 (`propertyTotalCost`).
   162	    ///
   163	    /// For each of <see cref="AcquisitionCostTypes"/>: uses the SUM of
   164	    /// linked `property_cost_links` transactions for that cost_type if any
   165	    /// exist, else falls back to the property's manual `*_cents` column.
   166	    /// Then adds the sum of `property_transactions` rows whose `type` is one
   167	    /// of <see cref="AcquisitionPropertyTransactionTypes"/>.
   168	    /// </summary>
   169	    public static long GetPropertyTotalCostCents(SqliteConnection connection, PropertyRecord property)
   170	    {
   171	        var manualMap = new Dictionary<string, long>
   172	        {
   173	            ["purchase_price"] = property.PurchasePriceCents,
   174	            ["grunderwerbsteuer"] = property.GrunderwerbsteuerCents,
   175	            ["notarkosten"] = property.NotarkostenCents,
   176	            ["maklergebuehr"] = property.MaklergebuehrCents,
   177	            ["grundbuchkosten"] = property.GrundbuchkostenCents,
   178	        };
   179	
   180	        var links = connection.Query<LinkedCostTypeTotal>(
   181	            """
   182	            SELECT pcl.cost_type AS CostType, SUM(ABS(t.amount_cents)) as TotalCents
   183	            FROM property_cost_links pcl
   184	            JOIN transactions t ON t.id = pcl.transaction_id
   185	            WHERE pcl.property_id = @PropertyId AND pcl.cost_type IN ('purchase_price','grunderwerbsteuer','notarkosten','maklergebuehr','grundbuchkosten')
   186	            GROUP BY pcl.cost_type
   187	            """,
   188	            new { PropertyId = property.Id });
   189	
   190	        var linkedByType = links.ToDictionary(l => l.CostType, l => l.TotalCents);
   191	
   192	        long total = 0;
   193	        foreach (var costType in AcquisitionCostTypes)
   194	        {
   195	            total += linkedByType.TryGetValue(costType, out var linkedTotal)
   196	                ? linkedTotal
   197	                : manualMap.GetValueOrDefault(costType, 0);
   198	        }
   199	
   200	        var acquisitionTxnTotal = connection.ExecuteScalar<long?>(
   201	            """
   202	            SELECT COALESCE(SUM(amount_cents), 0) as total
   203	            FROM property_transactions
   204	            WHERE property_id = @PropertyId AND type IN ('acquisition_purchase', 'acquisition_notary',
   205	              'acquisition_transfer_tax', 'acquisition_agent_fee', 'acquisition_registry')
   206	            """,
   207	            new { PropertyId = property.Id }) ?? 0;
   208	
   209	        return total + acquisitionTxnTotal;
   210	    }
   211	}
