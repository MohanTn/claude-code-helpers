    33	    /// <summary>Inserts a new property row. Ported from server.ts:797-833 (POST /api/properties).</summary>
    34	    public static long InsertProperty(
    35	        SqliteConnection connection,
    36	        string name,
    37	        string? address,
    38	        long purchasePriceCents,
    39	        string purchaseDate,
    40	        long grunderwerbsteuerCents,
    41	        long notarkostenCents,
    42	        long maklergebuehrCents,
    43	        long grundbuchkostenCents,
    44	        long? estimatedValueCents,
    45	        string? estimatedValueDate,
    46	        int? buildingCompletionYear,
    47	        long landValueCents)
    48	    {
    49	        connection.Execute(
    50	            """
    51	            INSERT INTO properties
    52	              (name, address, purchase_price_cents, purchase_date,
    53	               grunderwerbsteuer_cents, notarkosten_cents, maklergebuehr_cents, grundbuchkosten_cents,
    54	               estimated_value_cents, estimated_value_date,
    55	               building_completion_year, land_value_cents)
    56	            VALUES (@Name, @Address, @PurchasePriceCents, @PurchaseDate,
    57	                    @GrunderwerbsteuerCents, @NotarkostenCents, @MaklergebuehrCents, @GrundbuchkostenCents,
    58	                    @EstimatedValueCents, @EstimatedValueDate,
    59	                    @BuildingCompletionYear, @LandValueCents)
    60	            """,
    61	            new
    62	            {
    63	                Name = name,
    64	                Address = address,
    65	                PurchasePriceCents = purchasePriceCents,
    66	                PurchaseDate = purchaseDate,
    67	                GrunderwerbsteuerCents = grunderwerbsteuerCents,
    68	                NotarkostenCents = notarkostenCents,
    69	                MaklergebuehrCents = maklergebuehrCents,
    70	                GrundbuchkostenCents = grundbuchkostenCents,
    71	                EstimatedValueCents = estimatedValueCents,
    72	                EstimatedValueDate = estimatedValueDate,
    73	                BuildingCompletionYear = buildingCompletionYear,
    74	                LandValueCents = landValueCents,
    75	            });
    76	
    77	        return connection.ExecuteScalar<long>("SELECT last_insert_rowid()");
    78	    }
