    80	    /// <summary>
    81	    /// Updates a property row, defaulting any null argument to the existing
    82	    /// row's value (mirrors the TS `field ?? existing.field` pattern).
    83	    /// Ported from server.ts:835-882 (PATCH /api/properties/:id). Caller is
    84	    /// expected to have already loaded <paramref name="existing"/> for the
    85	    /// 404 check.
    86	    /// </summary>
    87	    public static void UpdateProperty(
    88	        SqliteConnection connection,
    89	        long id,
    90	        PropertyRecord existing,
    91	        string? name,
    92	        string? address,
    93	        long? purchasePriceCents,
    94	        string? purchaseDate,
    95	        long? grunderwerbsteuerCents,
    96	        long? notarkostenCents,
    97	        long? maklergebuehrCents,
    98	        long? grundbuchkostenCents,
    99	        long? estimatedValueCents,
   100	        string? estimatedValueDate,
   101	        int? buildingCompletionYear,
   102	        long? landValueCents)
   103	    {
   104	        connection.Execute(
   105	            """
   106	            UPDATE properties SET
   107	              name = @Name,
   108	              address = @Address,
   109	              purchase_price_cents = @PurchasePriceCents,
   110	              purchase_date = @PurchaseDate,
   111	              grunderwerbsteuer_cents = @GrunderwerbsteuerCents,
   112	              notarkosten_cents = @NotarkostenCents,
   113	              maklergebuehr_cents = @MaklergebuehrCents,
   114	              grundbuchkosten_cents = @GrundbuchkostenCents,
   115	              estimated_value_cents = @EstimatedValueCents,
   116	              estimated_value_date = @EstimatedValueDate,
   117	              building_completion_year = @BuildingCompletionYear,
   118	              land_value_cents = @LandValueCents
   119	            WHERE id = @Id
   120	            """,
   121	            new
   122	            {
   123	                Name = name ?? existing.Name,
   124	                Address = address ?? existing.Address,
   125	                PurchasePriceCents = purchasePriceCents ?? existing.PurchasePriceCents,
   126	                PurchaseDate = purchaseDate ?? existing.PurchaseDate,
   127	                GrunderwerbsteuerCents = grunderwerbsteuerCents ?? existing.GrunderwerbsteuerCents,
   128	                NotarkostenCents = notarkostenCents ?? existing.NotarkostenCents,
   129	                MaklergebuehrCents = maklergebuehrCents ?? existing.MaklergebuehrCents,
   130	                GrundbuchkostenCents = grundbuchkostenCents ?? existing.GrundbuchkostenCents,
   131	                EstimatedValueCents = estimatedValueCents ?? existing.EstimatedValueCents,
   132	                EstimatedValueDate = estimatedValueDate ?? existing.EstimatedValueDate,
   133	                BuildingCompletionYear = buildingCompletionYear ?? existing.BuildingCompletionYear,
   134	                LandValueCents = landValueCents ?? existing.LandValueCents,
   135	                Id = id,
   136	            });
   137	    }
