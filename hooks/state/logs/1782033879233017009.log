   404	    // ── GET /api/properties/annual-result?year= (server.ts:1648-1660) ───
   405	
   406	    private static IResult GetPropertiesAnnualResult(SqliteConnection connection, int? year)
   407	    {
   408	        var targetYear = year ?? DateTime.Now.Year;
   409	        try
   410	        {
   411	            var result = PropertyAnnualResultCalculator.CalculatePropertiesAnnualResult(connection, targetYear);
   412	            return Results.Ok(result);
   413	        }
   414	        catch (Exception err)
   415	        {
   416	            return Results.Json(new { error = err.Message }, statusCode: 500);
   417	        }
   418	    }
