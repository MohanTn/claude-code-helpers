   309	    // ── POST /api/properties/:id/transactions (server.ts:955-981) ───────
   310	
   311	    public record PostPropertyTransactionRequest(string? Date, string? Type, long? AmountCents, string? Description);
   312	
   313	    private static IResult PostPropertyTransaction(SqliteConnection connection, long id, PostPropertyTransactionRequest body)
   314	    {
   315	        var property = Db.GetPropertyById(connection, id);
   316	        if (property is null) return Results.NotFound(new { error = "not found" });
   317	
   318	        if (string.IsNullOrEmpty(body.Date) || string.IsNullOrEmpty(body.Type) || body.AmountCents is null)
   319	        {
   320	            return Results.BadRequest(new { error = "Missing required fields: date, type, amount_cents" });
   321	        }
   322	
   323	        if (!ValidTransactionTypes.Contains(body.Type))
   324	        {
   325	            return Results.BadRequest(new { error = $"Invalid type. Must be one of: {string.Join(", ", ValidTransactionTypes)}" });
   326	        }
   327	
   328	        var newId = Db.InsertPropertyTransaction(connection, id, body.Date, body.Type, body.AmountCents.Value, body.Description);
   329	        var created = Db.GetPropertyTransactionById(connection, newId);
   330	        return Results.Json(created, statusCode: 201);
   331	    }
