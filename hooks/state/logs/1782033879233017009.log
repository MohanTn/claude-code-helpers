   160	    private static IResult GetProperties(SqliteConnection connection)
   161	    {
   162	        var rows = Db.GetAllProperties(connection);
   163	        return Results.Ok(new { Properties = rows.Select(p => EnrichProperty(connection, p)).ToList() });
   164	    }
