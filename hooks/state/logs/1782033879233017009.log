   210	    // ── PATCH /api/properties/:id (server.ts:835-882) ───────────────────
   211	
   212	    public record PatchPropertyRequest(
   213	        string? Name,
   214	        string? Address,
   215	        long? PurchasePriceCents,
   216	        string? PurchaseDate,
   217	        long? GrunderwerbsteuerCents,
   218	        long? NotarkostenCents,
   219	        long? MaklergebuehrCents,
   220	        long? GrundbuchkostenCents,
   221	        long? EstimatedValueCents,
   222	        string? EstimatedValueDate,
   223	        int? BuildingCompletionYear,
   224	        long? LandValueCents);
   225	
   226	    private static IResult PatchProperty(SqliteConnection connection, long id, PatchPropertyRequest body)
   227	    {
   228	        var existing = Db.GetPropertyById(connection, id);
   229	        if (existing is null) return Results.NotFound(new { error = "not found" });
   230	
   231	        Db.UpdateProperty(
   232	            connection,
   233	            id,
   234	            existing,
   235	            body.Name,
   236	            body.Address,
   237	            body.PurchasePriceCents,
   238	            body.PurchaseDate,
   239	            body.GrunderwerbsteuerCents,
   240	            body.NotarkostenCents,
   241	            body.MaklergebuehrCents,
   242	            body.GrundbuchkostenCents,
   243	            body.EstimatedValueCents,
   244	            body.EstimatedValueDate,
   245	            body.BuildingCompletionYear,
   246	            body.LandValueCents);
   247	
   248	        var updated = Db.GetPropertyById(connection, id)!;
   249	        return Results.Ok(EnrichProperty(connection, updated));
   250	    }
