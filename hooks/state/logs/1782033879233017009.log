   342	    // ── POST /api/properties/:id/cost-links (server.ts:999-1047) ────────
   343	
   344	    public record PostCostLinkRequest(string? CostType, long? TransactionId);
   345	
   346	    private static IResult PostCostLink(SqliteConnection connection, long id, PostCostLinkRequest body)
   347	    {
   348	        try
   349	        {
   350	            if (string.IsNullOrEmpty(body.CostType) || body.TransactionId is null)
   351	            {
   352	                return Results.BadRequest(new { error = "Missing cost_type or transaction_id" });
   353	            }
   354	
   355	            var property = Db.GetPropertyById(connection, id);
   356	            if (property is null) return Results.NotFound(new { error = "Property not found" });
   357	
   358	            if (!CostTypes.Contains(body.CostType))
   359	            {
   360	                return Results.BadRequest(new { error = $"Invalid cost_type. Must be one of: {string.Join(", ", CostTypes)}" });
   361	            }
   362	
   363	            var txn = Db.GetTransactionById(connection, body.TransactionId.Value);
   364	            if (txn is null) return Results.NotFound(new { error = "Transaction not found" });
   365	
   366	            // Check if link already exists
   367	            var existing = Db.GetCostLink(connection, id, body.CostType, body.TransactionId.Value);
   368	            if (existing is not null)
   369	            {
   370	                return Results.Ok(existing);
   371	            }
   372	
   373	            // Insert new link
   374	            Db.InsertCostLink(connection, id, body.CostType, body.TransactionId.Value);
   375	
   376	            var link = Db.GetCostLink(connection, id, body.CostType, body.TransactionId.Value);
   377	            return Results.Json(link, statusCode: 201);
   378	        }
   379	        catch (Exception error)
   380	        {
   381	            return Results.Json(new { error = error.Message }, statusCode: 500);
   382	        }
   383	    }
   384	
   385	    // ── DELETE /api/properties/:id/cost-links/:costType (server.ts:1050-1072) ─
   386	
   387	    private static IResult DeleteCostLink(
   388	        SqliteConnection connection,
   389	        long id,
   390	        string costType,
   391	        [FromQuery(Name = "transaction_id")] long? transactionId)
   392	    {
   393	        if (!CostTypes.Contains(costType))
   394	        {
   395	            return Results.BadRequest(new { error = $"Invalid cost_type: {costType}" });
   396	        }
   397	
   398	        var rowsAffected = Db.DeleteCostLinks(connection, id, costType, transactionId);
   399	
   400	        if (rowsAffected == 0) return Results.NotFound(new { error = "not found" });
   401	        return Results.Ok(new { PropertyId = id, CostType = costType, TransactionId = transactionId, Deleted = true });
   402	    }
