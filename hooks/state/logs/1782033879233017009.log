    47	    // ── enrichProperty (server.ts:723-788) ──────────────────────────────
    48	
    49	    /// <summary>
    50	    /// Wraps a <see cref="PropertyRecord"/> with computed fields: total
    51	    /// acquisition cost, latest mortgage, own_capital/tenant_deposit totals,
    52	    /// current equity, LTV ratio, and cost_links enriched with the
    53	    /// amortization split for EMI payments. Ported 1:1 from server.ts:723-788
    54	    /// (`enrichProperty`). Returns a <see cref="Dictionary{TKey, TValue}"/>
    55	    /// (rather than an anonymous type) so that GET /api/properties/:id/summary
    56	    /// can merge in a `monthly_cash_flow` key, mirroring the TS object-spread
    57	    /// `{ ...enrichProperty(prop), monthly_cash_flow: months }`.
    58	    /// </summary>
    59	    private static Dictionary<string, object?> EnrichProperty(SqliteConnection connection, PropertyRecord property)
    60	    {
    61	        var mortgage = Db.GetLatestMortgageForProperty(connection, property.Id);
    62	        var costLinks = Db.GetCostLinksForProperty(connection, property.Id);
    63	
    64	        var totalAcquisitionCostCents = Db.GetPropertyTotalCostCents(connection, property);
    65	
    66	        // Sum linked own_capital transactions (money put in from own pocket)
    67	        var ownCapitalCents = costLinks
    68	            .Where(l => l.CostType == "own_capital")
    69	            .Sum(l => Math.Abs(l.AmountCents));
    70	
    71	        // Sum linked tenant_deposit transactions (Mietkaution received — a
    72	        // liability to be returned, not rental income; documentation only).
    73	        var tenantDepositCents = costLinks
    74	            .Where(l => l.CostType == "tenant_deposit")
    75	            .Sum(l => Math.Abs(l.AmountCents));
    76	
    77	        // Compute mortgage amortization from linked EMI transactions
    78	        var emiLinks = costLinks
    79	            .Where(l => l.CostType == "mortgage_payment")
    80	            .Select(l => new MortgageAmortization.EmiLink(l.TransactionId, l.Date, l.AmountCents))
    81	            .ToList();
    82	
    83	        var mortgageInfo = mortgage is null
    84	            ? null
    85	            : new MortgageAmortization.MortgageInfo((decimal)mortgage.InterestRate, mortgage.OutstandingBalanceCents);
    86	
    87	        var amortization = MortgageAmortization.ComputeMortgageAmortization(mortgageInfo, emiLinks);
    88	
    89	        // Enrich cost_links with amortization split for EMI payments
    90	        var amortByTxnId = amortization.AmortizedTransactions.ToDictionary(a => a.TransactionId, a => a);
    91	
    92	        var enrichedCostLinks = costLinks.Select(l =>
    93	        {
    94	            if (amortByTxnId.TryGetValue(l.TransactionId, out var am))
    95	            {
    96	                return (object)new
    97	                {
    98	                    l.CostType,
    99	                    l.TransactionId,
   100	                    l.Date,
   101	                    l.Description,
   102	                    l.AmountCents,
   103	                    l.AccountId,
   104	                    InterestCents = am.InterestCents,
   105	                    PrincipalCents = am.PrincipalCents,
   106	                };
   107	            }
   108	            return l;
   109	        }).ToList();
   110	
   111	        var outstandingBalanceCents = mortgage?.OutstandingBalanceCents ?? 0;
   112	        var effectiveOutstandingBalanceCents = outstandingBalanceCents - amortization.TotalPrincipalPaidCents;
   113	
   114	        // Equity = estimated_value - total_acquisition_cost + principal paid (equity built through EMI)
   115	        long? currentEquityCents = property.EstimatedValueCents is { } estimatedValue
   116	            ? estimatedValue - totalAcquisitionCostCents + amortization.TotalPrincipalPaidCents
   117	            : null;
   118	
   119	        double? ltvRatio = property.EstimatedValueCents is { } estimatedValueForLtv && estimatedValueForLtv > 0
   120	            ? (double)effectiveOutstandingBalanceCents / estimatedValueForLtv
   121	            : totalAcquisitionCostCents > 0
   122	                ? (double)effectiveOutstandingBalanceCents / totalAcquisitionCostCents
   123	                : (double?)null;
   124	
   125	        // Keys are snake_case literals (not PascalCase) because
   126	        // Dictionary<string, object?> keys bypass ASP.NET Core's
   127	        // PropertyNamingPolicy (which only rewrites POCO/record property
   128	        // names) — these must match server.ts's JSON output verbatim.
   129	        return new Dictionary<string, object?>
   130	        {
   131	            ["id"] = property.Id,
   132	            ["name"] = property.Name,
   133	            ["address"] = property.Address,
   134	            ["purchase_price_cents"] = property.PurchasePriceCents,
   135	            ["purchase_date"] = property.PurchaseDate,
   136	            ["grunderwerbsteuer_cents"] = property.GrunderwerbsteuerCents,
   137	            ["notarkosten_cents"] = property.NotarkostenCents,
   138	            ["maklergebuehr_cents"] = property.MaklergebuehrCents,
   139	            ["grundbuchkosten_cents"] = property.GrundbuchkostenCents,
   140	            ["estimated_value_cents"] = property.EstimatedValueCents,
   141	            ["estimated_value_date"] = property.EstimatedValueDate,
   142	            ["building_completion_year"] = property.BuildingCompletionYear,
   143	            ["land_value_cents"] = property.LandValueCents,
   144	            ["created_at"] = property.CreatedAt,
   145	            ["total_acquisition_cost_cents"] = totalAcquisitionCostCents,
   146	            ["mortgage"] = mortgage,
   147	            ["own_capital_cents"] = ownCapitalCents,
   148	            ["tenant_deposit_cents"] = tenantDepositCents,
   149	            ["current_equity_cents"] = currentEquityCents,
   150	            ["ltv_ratio"] = ltvRatio,
   151	            ["cost_links"] = enrichedCostLinks,
   152	            ["total_principal_paid_cents"] = amortization.TotalPrincipalPaidCents,
   153	            ["total_interest_paid_cents"] = amortization.TotalInterestPaidCents,
   154	            ["effective_outstanding_balance_cents"] = effectiveOutstandingBalanceCents,
   155	        };
   156	    }
