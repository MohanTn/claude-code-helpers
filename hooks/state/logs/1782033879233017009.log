   166	    // ── POST /api/properties (server.ts:797-833) ────────────────────────
   167	
   168	    public record PostPropertyRequest(
   169	        string? Name,
   170	        string? Address,
   171	        long? PurchasePriceCents,
   172	        string? PurchaseDate,
   173	        long? GrunderwerbsteuerCents,
   174	        long? NotarkostenCents,
   175	        long? MaklergebuehrCents,
   176	        long? GrundbuchkostenCents,
   177	        long? EstimatedValueCents,
   178	        string? EstimatedValueDate,
   179	        int? BuildingCompletionYear,
   180	        long? LandValueCents);
   181	
   182	    private static IResult PostProperty(SqliteConnection connection, PostPropertyRequest body)
   183	    {
   184	        // Mirrors server.ts:811's `!name || !purchase_price_cents || !purchase_date`
   185	        // falsy check: purchase_price_cents of 0 is rejected as "missing", same as TS's `!0`.
   186	        if (string.IsNullOrEmpty(body.Name) || body.PurchasePriceCents is null or 0 || string.IsNullOrEmpty(body.PurchaseDate))
   187	        {
   188	            return Results.BadRequest(new { error = "Missing required fields: name, purchase_price_cents, purchase_date" });
   189	        }
   190	
   191	        var id = Db.InsertProperty(
   192	            connection,
   193	            body.Name,
   194	            body.Address,
   195	            body.PurchasePriceCents.Value,
   196	            body.PurchaseDate,
   197	            body.GrunderwerbsteuerCents ?? 0,
   198	            body.NotarkostenCents ?? 0,
   199	            body.MaklergebuehrCents ?? 0,
   200	            body.GrundbuchkostenCents ?? 0,
   201	            body.EstimatedValueCents,
   202	            body.EstimatedValueDate,
   203	            body.BuildingCompletionYear,
   204	            body.LandValueCents ?? 0);
   205	
   206	        var created = Db.GetPropertyById(connection, id)!;
   207	        return Results.Json(EnrichProperty(connection, created), statusCode: 201);
   208	    }
