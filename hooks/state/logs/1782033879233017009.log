     8	namespace FinanceAnalyser.Api.Endpoints;
     9	
    10	public static class PropertiesEndpoints
    11	{
    12	    // Documentation-only property cost types: linking a transaction here records
    13	    // it against a property but must never feed P&L/cash-flow (own_capital, the
    14	    // purchase down payment) or income (tenant_deposit, a Mietkaution liability
    15	    // to be returned, not rent earned). Ported from server.ts:80.
    16	    private static readonly string[] DocumentationCostTypes = { "own_capital", "tenant_deposit" };
    17	
    18	    // Ported from server.ts:720.
    19	    private static readonly string[] RecurringCostTypes = { "rental_income", "mortgage_payment", "maintenance", "property_tax" };
    20	
    21	    // Ported from server.ts:721: ACQUISITION_COST_TYPES + RECURRING_COST_TYPES + DOCUMENTATION_COST_TYPES.
    22	    private static readonly string[] CostTypes =
    23	        Db.AcquisitionCostTypes.Concat(RecurringCostTypes).Concat(DocumentationCostTypes).ToArray();
    24	
    25	    // Ported from server.ts:961-965.
    26	    private static readonly string[] ValidTransactionTypes =
    27	    {
    28	        "rental_income", "mortgage_payment", "maintenance", "insurance", "property_tax", "other",
    29	        "acquisition_purchase", "acquisition_notary", "acquisition_transfer_tax",
    30	        "acquisition_agent_fee", "acquisition_registry",
    31	    };
    32	
    33	    public static void MapPropertiesEndpoints(this WebApplication app)
    34	    {
    35	        app.MapGet("/api/properties", GetProperties);
    36	        app.MapPost("/api/properties", PostProperty);
    37	        app.MapPatch("/api/properties/{id}", PatchProperty);
    38	        app.MapGet("/api/properties/{id}/summary", GetPropertySummary);
    39	        app.MapGet("/api/properties/{id}/transactions", GetPropertyTransactions);
    40	        app.MapPost("/api/properties/{id}/transactions", PostPropertyTransaction);
    41	        app.MapDelete("/api/properties/{id}/transactions/{txId}", DeletePropertyTransaction);
    42	        app.MapPost("/api/properties/{id}/cost-links", PostCostLink);
    43	        app.MapDelete("/api/properties/{id}/cost-links/{costType}", DeleteCostLink);
    44	        app.MapGet("/api/properties/annual-result", GetPropertiesAnnualResult);
    45	    }
