   239	
   240	test('categorizeAll: ≥90% of non-Internal-Transfer real transactions are categorized as non-Other', () => {
   241	  const all = parseAllReal();
   242	  assert.strictEqual(all.length, 646, 'sanity check: expect 646 total real transactions across all 4 sources');
   243	
   244	  const categorized = categorizeAll(all, SEED_RULES);
   245	
   246	  // Every category must be one of the 15 canonical strings (PRD Section 3).
   247	  for (const t of categorized) {
   248	    assert.ok(
   249	      CANONICAL_CATEGORIES.has(t.category),
   250	      `category "${t.category}" is not one of the 15 canonical categories (txn: "${t.description.slice(0, 80)}")`
   251	    );
   252	  }
   253	
   254	  const counts: Record<string, number> = {};
   255	  for (const t of categorized) {
   256	    counts[t.category] = (counts[t.category] ?? 0) + 1;
   257	  }
   258	
   259	  const nonInternalTransfer = categorized.filter((t) => t.category !== 'Internal Transfer');
   260	  const nonOther = nonInternalTransfer.filter((t) => t.category !== 'Other');
   261	  const pct = (100 * nonOther.length) / nonInternalTransfer.length;
   262	
   263	  console.log('Category breakdown:', counts);
   264	  console.log(
   265	    `Non-Internal-Transfer: ${nonInternalTransfer.length}, non-Other: ${nonOther.length}, coverage: ${pct.toFixed(2)}%`
   266	  );
   267	
   268	  assert.ok(
   269	    pct >= 90,
   270	    `expected >=90% of non-Internal-Transfer transactions to be categorized as non-Other, got ${pct.toFixed(2)}%`
   271	  );
   272	});
