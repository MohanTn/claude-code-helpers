    26	/** Parse all real transactions from all 4 sources (646 total, per PRD Phase 1). */
    27	function parseAllReal(): ParsedTransaction[] {
    28	  const all: ParsedTransaction[] = [];
    29	
    30	  all.push(...parseCommerzbank(path.join(DOCS_DIR, 'bank-transaction.pdf')).transactions);
    31	  all.push(...parseWise(path.join(DOCS_DIR, 'wise-bank-statement-2025.pdf')).transactions);
    32	  all.push(...parseTradeRepublic(path.join(DOCS_DIR, 'trade-republic-account-statement-2025.pdf')).transactions);
    33	
    34	  for (const file of CC_FILES) {
    35	    all.push(...parseTfBank(path.join(DOCS_DIR, 'credit_card', file)).transactions);
    36	  }
    37	
    38	  return all;
    39	}
