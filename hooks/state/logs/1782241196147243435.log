   222	    /// <summary>
   223	    /// Arbeitnehmer-Pauschbetrag (flat-rate employee expense allowance / aka
   224	    /// Werbungskostenpauschale), in cents, by tax year.
   225	    ///
   226	    /// History: raised from €1,000 to €1,200 for tax year 2022 via the
   227	    /// Steuerentlastungsgesetz 2022 (applied retroactively for the full 2022 tax
   228	    /// year, not prorated), then raised again to €1,230 starting tax year 2023,
   229	    /// where it has remained through 2026.
   230	    /// </summary>
   231	    public static readonly Dictionary<int, long> WerbungskostenPauschaleByYear = new()
   232	    {
   233	        // Source: Steuerentlastungsgesetz 2022 (BGBl. 2022 I, published 27 May
   234	        // 2022), retroactive to 1 Jan 2022; raised from €1,000 to €1,200.
   235	        [2022] = 120_000, // €1,200
   236	        // Source: Inflationsausgleichsgesetz, raised from €1,200 to €1,230
   237	        // effective tax year 2023.
   238	        [2023] = 123_000, // €1,230
   239	        // Source: unchanged from 2023; BMF Lohnsteuer-Handbuch 2024.
   240	        [2024] = 123_000, // €1,230
   241	        // Source: unchanged; confirmed in task spec.
   242	        [2025] = 123_000, // €1,230
   243	        // Source: unchanged; confirmed in task spec.
   244	        [2026] = 123_000, // €1,230
   245	    };
