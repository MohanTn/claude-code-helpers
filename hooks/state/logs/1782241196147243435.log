     1	namespace FinanceAnalyser.Core.Tax;
     2	
     3	// German §32a EStG income-tax bracket constants, Solidaritätszuschlag exemption
     4	// thresholds, and the Arbeitnehmer-Pauschbetrag (flat-rate employee expense
     5	// allowance), for tax years 2022-2026.
     6	//
     7	// All monetary figures are stored in CENTS (euros * 100), per this codebase's
     8	// `_cents` convention. Every number below was hand-transcribed from the
     9	// source table in the task spec and cross-checked in constants.test.ts —
    10	// treat any future change to these values as a tax-law transcription task,
    11	// not a refactor: re-verify against the official §32a EStG text / BMF
    12	// publications before touching a digit.
    13	//
    14	// Ported from src/tax/constants.ts. Keep numerically identical to the TS source.
    15	
    16	/// <summary>
    17	/// One year's §32a EStG progressive income-tax bracket definition.
    18	///
    19	/// The German income tax formula is piecewise over 5 zones:
    20	///   Zone 1 (0 .. GrundfreibetragCents):            tax = 0
    21	///   Zone 2 (Zone2LowerCents .. Zone2UpperCents):    tax = (Zone2YCoefficient * y + 1400) * y
    22	///   Zone 3 (Zone3LowerCents .. Zone3UpperCents):    tax = (Zone3ZCoefficient * z + Zone3ZLinearConstant) * z + Zone3ZAddendCents
    23	///   Zone 4 (Zone3UpperCents+1 .. Zone5LowerCents-1): tax = 0.42 * x - Zone4SubtrahendCents
    24	///   Zone 5 (Zone5LowerCents .. infinity):            tax = 0.45 * x - Zone5SubtrahendCents
    25	///
    26	/// Where (per official BMF practice) the inputs are floored to whole euros
    27	/// before being divided:
    28	///   y = floor((zvE_cents/100 - GrundfreibetragCents/100)) / 10000
    29	///   z = floor((zvE_cents/100 - (Zone3LowerCents/100 - 1))) / 10000
    30	///   x = zvE_cents / 100
    31	///
    32	/// This record only stores the raw bracket boundaries/coefficients; the
    33	/// flooring + piecewise dispatch belongs to <see cref="IncomeTax"/>.
    34	/// </summary>
    35	public sealed record TaxBracketYear
    36	{
    37	    /// <summary>Grundfreibetrag (tax-free allowance), in cents. Top of zone 1.</summary>
    38	    public required long GrundfreibetragCents { get; init; }
    39	
    40	    /// <summary>Zone 2 lower bound, in cents (GrundfreibetragCents + 100).</summary>
    41	    public required long Zone2LowerCents { get; init; }
    42	    /// <summary>Zone 2 upper bound, in cents.</summary>
    43	    public required long Zone2UpperCents { get; init; }
    44	    /// <summary>Zone 2 formula: tax = (Zone2YCoefficientCents/100 * y + 1400) * y</summary>
    45	    public required long Zone2YCoefficientCents { get; init; }
    46	    /// <summary>Zone 2 formula linear constant (1400 in every year covered here).</summary>
    47	    public required long Zone2LinearConstant { get; init; }
    48	
    49	    /// <summary>Zone 3 lower bound, in cents (Zone2UpperCents + 100).</summary>
    50	    public required long Zone3LowerCents { get; init; }
    51	    /// <summary>Zone 3 upper bound, in cents.</summary>
    52	    public required long Zone3UpperCents { get; init; }
    53	    /// <summary>Zone 3 formula: tax = (Zone3ZCoefficientCents/100 * z + 2397) * z + Zone3ZAddendCents/100</summary>
    54	    public required long Zone3ZCoefficientCents { get; init; }
    55	    /// <summary>Zone 3 formula linear constant (2397 in every year covered here).</summary>
    56	    public required long Zone3LinearConstant { get; init; }
    57	    /// <summary>Zone 3 formula additive constant, in cents.</summary>
    58	    public required long Zone3ZAddendCents { get; init; }
    59	
    60	    /// <summary>
    61	    /// Zone 4 lower bound, in cents. Equal to Zone3UpperCents + 100 (i.e. the
    62	    /// next whole euro above zone 3's upper bound).
    63	    /// </summary>
    64	    public required long Zone4LowerCents { get; init; }
    65	    /// <summary>Zone 4 formula: tax = 0.42 * x - Zone4SubtrahendCents/100</summary>
    66	    public required long Zone4SubtrahendCents { get; init; }
    67	
    68	    /// <summary>
    69	    /// Zone 5 lower bound, in cents — the zone4/zone5 boundary. This is the
    70	    /// income at which the zone 4 and zone 5 linear formulas cross
    71	    /// (0.42x - Zone4Subtrahend == 0.45x - Zone5Subtrahend), derived as:
    72	    ///   x_cross = (Zone5SubtrahendCents - Zone4SubtrahendCents) / 0.03
    73	    /// Stored explicitly here (rounded to whole cents) so callers never need
    74	    /// to re-derive it.
    75	    /// </summary>
    76	    public required long Zone5LowerCents { get; init; }
    77	    /// <summary>Zone 5 formula: tax = 0.45 * x - Zone5SubtrahendCents/100</summary>
    78	    public required long Zone5SubtrahendCents { get; init; }
    79	}
    80	
    81	/// <summary>
    82	/// Solidaritätszuschlag Freigrenze (exemption threshold): below this taxable
    83	/// income, no Soli is owed. All figures in cents.
    84	/// </summary>
    85	public sealed record SoliExemption
    86	{
    87	    public required long SingleCents { get; init; }
    88	    public required long JointCents { get; init; }
    89	}
    90	
    91	/// <summary>
    92	/// Entfernungspauschale (commute allowance, §9 Abs. 1 Satz 3 Nr. 4 EStG) per-km
    93	/// rate, tiered at the 21st km. Unchanged 2022-2026 (raised to 38ct/km beyond
    94	/// the 20th km by the Steuerentlastungsgesetz 2022, retroactive to 2022, and
    95	/// not adjusted since).
    96	/// </summary>
    97	public sealed record EntfernungspauschaleRate
    98	{
    99	    public required int FirstTierKm { get; init; }
   100	    public required long FirstTierCentsPerKm { get; init; }
   101	    public required long BeyondTierCentsPerKm { get; init; }
   102	}
   103	
   104	/// <summary>
   105	/// Homeoffice-Tagespauschale (§4 Abs. 5 Satz 1 Nr. 6c EStG): flat per-day
   106	/// allowance for days worked from home, capped annually. Raised from €5/day
   107	/// (max 120 days) to €6/day (max 210 days) by the Jahressteuergesetz 2022,
   108	/// effective tax year 2023; unchanged through 2026.
   109	/// </summary>
   110	public sealed record TagespauschaleRate
   111	{
   112	    public required long CentsPerDay { get; init; }
   113	    public required int MaxDays { get; init; }
   114	}
   115	
   116	/// <summary>
   117	/// Static lookup tables for German §32a EStG tax brackets, Soli exemption
   118	/// thresholds, and the Werbungskostenpauschale, by tax year (2022-2026).
   119	/// Ported from src/tax/constants.ts.
   120	/// </summary>
   121	public static class TaxConstants
   122	{
   123	    // x_cross (in cents) = (zone5Sub - zone4Sub) / (0.45 - 0.42) = / 0.03
   124	    private static long Zone5LowerFromCrossing(long zone4SubtrahendCents, long zone5SubtrahendCents) =>
   125	        (long)Math.Round((zone5SubtrahendCents - zone4SubtrahendCents) / 0.03, MidpointRounding.AwayFromZero);
   126	
   127	    /// <summary>
   128	    /// Constructs a TaxBracketYear, deriving all boundary-crossing fields
   129	    /// (Zone2LowerCents, Zone3LowerCents, Zone4LowerCents, Zone5LowerCents)
   130	    /// from the eight hand-transcribed literals in the parameters, so a
   131	    /// future correction to any boundary automatically updates its neighbours.
   132	    /// </summary>
   133	    private static TaxBracketYear MakeBracket(
   134	        long grundfreibetragCents,
   135	        long zone2UpperCents,
   136	        long zone2YCoefficientCents,
   137	        long zone3UpperCents,
   138	        long zone3ZCoefficientCents,
   139	        long zone3ZAddendCents,
   140	        long zone4SubtrahendCents,
   141	        long zone5SubtrahendCents) => new()
   142	        {
   143	            GrundfreibetragCents = grundfreibetragCents,
   144	            Zone2LowerCents = grundfreibetragCents + 100,
   145	            Zone2UpperCents = zone2UpperCents,
   146	            Zone2YCoefficientCents = zone2YCoefficientCents,
   147	            Zone2LinearConstant = 1400,
   148	            Zone3LowerCents = zone2UpperCents + 100,
   149	            Zone3UpperCents = zone3UpperCents,
   150	            Zone3ZCoefficientCents = zone3ZCoefficientCents,
   151	            Zone3LinearConstant = 2397,
   152	            Zone3ZAddendCents = zone3ZAddendCents,
   153	            Zone4LowerCents = zone3UpperCents + 100,
   154	            Zone4SubtrahendCents = zone4SubtrahendCents,
   155	            Zone5LowerCents = Zone5LowerFromCrossing(zone4SubtrahendCents, zone5SubtrahendCents),
   156	            Zone5SubtrahendCents = zone5SubtrahendCents,
   157	        };
   158	
