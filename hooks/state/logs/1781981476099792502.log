   170	/**
   171	 * Solidaritätszuschlag Freigrenze (exemption threshold): below this taxable
   172	 * income, no Soli is owed. All figures in cents.
   173	 */
   174	export interface SoliExemption {
   175	  single_cents: number;
   176	  joint_cents: number;
   177	}
