   187	/**
   188	 * Arbeitnehmer-Pauschbetrag (flat-rate employee expense allowance / aka
   189	 * Werbungskostenpauschale), in cents, by tax year.
   190	 *
   191	 * History: raised from €1,000 to €1,200 for tax year 2022 via the
   192	 * Steuerentlastungsgesetz 2022 (applied retroactively for the full 2022 tax
   193	 * year, not prorated), then raised again to €1,230 starting tax year 2023,
   194	 * where it has remained through 2026.
   195	 */
   196	export const WERBUNGSKOSTEN_PAUSCHALE_BY_YEAR: Record<number, number> = {
   197	  // Source: Steuerentlastungsgesetz 2022 (BGBl. 2022 I, published 27 May
   198	  // 2022), retroactive to 1 Jan 2022; raised from €1,000 to €1,200.
   199	  2022: 120_000, // €1,200
   200	  // Source: Inflationsausgleichsgesetz, raised from €1,200 to €1,230
   201	  // effective tax year 2023.
   202	  2023: 123_000, // €1,230
   203	  // Source: unchanged from 2023; BMF Lohnsteuer-Handbuch 2024.
   204	  2024: 123_000, // €1,230
   205	  // Source: unchanged; confirmed in task spec.
   206	  2025: 123_000, // €1,230
   207	  // Source: unchanged; confirmed in task spec.
   208	  2026: 123_000, // €1,230
   209	};
