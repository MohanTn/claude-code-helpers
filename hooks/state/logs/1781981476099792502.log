     1	// German §32a EStG income-tax bracket constants, Solidaritätszuschlag exemption
     2	// thresholds, and the Arbeitnehmer-Pauschbetrag (flat-rate employee expense
     3	// allowance), for tax years 2022-2026.
     4	//
     5	// All monetary figures are stored in CENTS (euros * 100), per this codebase's
     6	// `_cents` convention. Every number below was hand-transcribed from the
     7	// source table in the task spec and cross-checked in constants.test.ts —
     8	// treat any future change to these values as a tax-law transcription task,
     9	// not a refactor: re-verify against the official §32a EStG text / BMF
    10	// publications before touching a digit.
    11	
    12	/**
    13	 * One year's §32a EStG progressive income-tax bracket definition.
    14	 *
    15	 * The German income tax formula is piecewise over 5 zones:
    16	 *   Zone 1 (0 .. grundfreibetragCents):            tax = 0
    17	 *   Zone 2 (zone2LowerCents .. zone2UpperCents):    tax = (zone2YCoefficient * y + 1400) * y
    18	 *   Zone 3 (zone3LowerCents .. zone3UpperCents):    tax = (zone3ZCoefficient * z + zone3ZLinearConstant) * z + zone3ZAddendCents
    19	 *   Zone 4 (zone3UpperCents+1 .. zone5LowerCents-1): tax = 0.42 * x - zone4SubtrahendCents
    20	 *   Zone 5 (zone5LowerCents .. infinity):            tax = 0.45 * x - zone5SubtrahendCents
    21	 *
    22	 * Where (per official BMF practice) the inputs are floored to whole euros
    23	 * before being divided:
    24	 *   y = floor((zvE_cents/100 - grundfreibetragCents/100)) / 10000
    25	 *   z = floor((zvE_cents/100 - (zone3LowerCents/100 - 1))) / 10000
    26	 *   x = zvE_cents / 100
    27	 *
    28	 * This module only stores the raw bracket boundaries/coefficients; the
    29	 * flooring + piecewise dispatch belongs to the future calculateIncomeTax()
    30	 * implementer, per the task spec.
    31	 */
    32	export interface TaxBracketYear {
    33	  /** Grundfreibetrag (tax-free allowance), in cents. Top of zone 1. */
    34	  grundfreibetragCents: number;
    35	
    36	  /** Zone 2 lower bound, in cents (grundfreibetragCents + 100). */
    37	  zone2LowerCents: number;
    38	  /** Zone 2 upper bound, in cents. */
    39	  zone2UpperCents: number;
    40	  /** Zone 2 formula: tax = (zone2YCoefficientCents/100 * y + 1400) * y */
    41	  zone2YCoefficientCents: number;
    42	  /** Zone 2 formula linear constant (1400 in every year covered here). */
    43	  zone2LinearConstant: number;
    44	
    45	  /** Zone 3 lower bound, in cents (zone2UpperCents + 100). */
    46	  zone3LowerCents: number;
    47	  /** Zone 3 upper bound, in cents. */
    48	  zone3UpperCents: number;
    49	  /** Zone 3 formula: tax = (zone3ZCoefficientCents/100 * z + 2397) * z + zone3ZAddendCents/100 */
    50	  zone3ZCoefficientCents: number;
    51	  /** Zone 3 formula linear constant (2397 in every year covered here). */
    52	  zone3LinearConstant: number;
    53	  /** Zone 3 formula additive constant, in cents. */
    54	  zone3ZAddendCents: number;
    55	
    56	  /**
    57	   * Zone 4 lower bound, in cents. Equal to zone3UpperCents + 100 (i.e. the
    58	   * next whole euro above zone 3's upper bound).
    59	   */
    60	  zone4LowerCents: number;
    61	  /** Zone 4 formula: tax = 0.42 * x - zone4SubtrahendCents/100 */
    62	  zone4SubtrahendCents: number;
    63	
    64	  /**
    65	   * Zone 5 lower bound, in cents — the zone4/zone5 boundary. This is the
    66	   * income at which the zone 4 and zone 5 linear formulas cross
    67	   * (0.42x - zone4Subtrahend == 0.45x - zone5Subtrahend), derived as:
    68	   *   x_cross = (zone5SubtrahendCents - zone4SubtrahendCents) / 0.03
    69	   * Stored explicitly here (rounded to whole cents) so callers never need
    70	   * to re-derive it.
    71	   */
    72	  zone5LowerCents: number;
    73	  /** Zone 5 formula: tax = 0.45 * x - zone5SubtrahendCents/100 */
    74	  zone5SubtrahendCents: number;
    75	}
    76	
    77	function zone5LowerFromCrossing(zone4SubtrahendCents: number, zone5SubtrahendCents: number): number {
    78	  // x_cross (in cents) = (zone5Sub - zone4Sub) / (0.45 - 0.42) = / 0.03
    79	  return Math.round((zone5SubtrahendCents - zone4SubtrahendCents) / 0.03);
    80	}
    81	
    82	/** Constructs a TaxBracketYear, deriving all boundary-crossing fields
    83	 * (zone2LowerCents, zone3LowerCents, zone4LowerCents, zone5LowerCents)
    84	 * from the eight hand-transcribed literals in the parameter object, so
    85	 * a future correction to any boundary automatically updates its neighbours. */
    86	function makeBracket(p: {
    87	  grundfreibetragCents: number;
    88	  zone2UpperCents: number;
    89	  zone2YCoefficientCents: number;
    90	  zone3UpperCents: number;
    91	  zone3ZCoefficientCents: number;
    92	  zone3ZAddendCents: number;
    93	  zone4SubtrahendCents: number;
    94	  zone5SubtrahendCents: number;
    95	}): TaxBracketYear {
    96	  const { grundfreibetragCents, zone2UpperCents, zone2YCoefficientCents,
    97	    zone3UpperCents, zone3ZCoefficientCents, zone3ZAddendCents,
    98	    zone4SubtrahendCents, zone5SubtrahendCents } = p;
    99	  return {
   100	    grundfreibetragCents,
   101	    zone2LowerCents: grundfreibetragCents + 100,
   102	    zone2UpperCents,
   103	    zone2YCoefficientCents,
   104	    zone2LinearConstant: 1400,
   105	    zone3LowerCents: zone2UpperCents + 100,
   106	    zone3UpperCents,
   107	    zone3ZCoefficientCents,
   108	    zone3LinearConstant: 2397,
   109	    zone3ZAddendCents,
   110	    zone4LowerCents: zone3UpperCents + 100,
   111	    zone4SubtrahendCents,
   112	    zone5LowerCents: zone5LowerFromCrossing(zone4SubtrahendCents, zone5SubtrahendCents),
   113	    zone5SubtrahendCents,
   114	  };
   115	}
   116	
