   116	// ─── calculateSplittingTax ───────────────────────────────────────────────────
   117	
   118	test('calculateSplittingTax: symmetric incomes produce exactly 2x single tax', () => {
   119	  // When both spouses earn the same, the halved zvE equals one spouse's
   120	  // full income, so Splitting tax = 2 * singleTax(oneIncome).
   121	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   122	    // Pick an income well into zone 3 for clear numbers.
   123	    const gf = TAX_BRACKETS_BY_YEAR[year].grundfreibetragCents;
   124	    const income = gf + 30_000_00; // GF + 30k
   125	    const splittingTax = calculateSplittingTax(income, income, year);
   126	    // Combined zvE = income * 2, halved = income. So Splitting tax = 2 * singleTax(income).
   127	    const singleTax = calculateIncomeTax(income, year);
   128	    assert.strictEqual(
   129	      splittingTax,
   130	      2 * singleTax,
   131	      `Year ${year}: Splitting with two ${income} incomes should be 2 × single (${2 * singleTax})`,
   132	    );
   133	  }
   134	});
   135	
   136	test('calculateSplittingTax: asymmetric incomes — Splitting reduces tax vs independent filing', () => {
   137	  // Splitting with asymmetric incomes (one high, one low) should produce
   138	  // less total tax than taxing each independently, because the lower earner
   139	  // "pulls down" the combined bracket.
   140	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   141	    const gf = TAX_BRACKETS_BY_YEAR[year].grundfreibetragCents;
   142	    const highIncome = gf + 60_000_00; // deep in zone 4
   143	    const lowIncome = gf + 10_000_00;  // y=1 in zone 2
   144	    const splittingTax = calculateSplittingTax(highIncome, lowIncome, year);
   145	    const independentTax = calculateIncomeTax(highIncome, year) + calculateIncomeTax(lowIncome, year);
   146	    assert.ok(
   147	      splittingTax < independentTax,
   148	      `Year ${year}: Splitting (${splittingTax}) should be < independent (${independentTax}) ` +
   149	      `for asymmetric incomes (${highIncome}, ${lowIncome})`,
   150	    );
   151	  }
   152	});
   153	
   154	test('calculateSplittingTax: works when only one filer has income', () => {
   155	  // When one filer has zero income, Split half = income/2, tax = 2 * singleTax(half).
   156	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   157	    const gf = TAX_BRACKETS_BY_YEAR[year].grundfreibetragCents;
   158	    const income = gf + 40_000_00;
   159	    const splittingTax = calculateSplittingTax(income, 0, year);
   160	    const half = Math.floor(income / 2);
   161	    const expected = 2 * calculateIncomeTax(half, year);
   162	    assert.strictEqual(
   163	      splittingTax,
   164	      expected,
   165	      `Year ${year}: Splitting(${income}, 0) = ${splittingTax}, expected 2×single(${half}) = ${expected}`,
   166	    );
   167	  }
   168	});
   169	
   170	test('calculateSplittingTax: equal to single tax when combined zvE is halved', () => {
   171	  // General property: 2 * single(floor((a+b)/2)) — test against calculateIncomeTax.
   172	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   173	    const b = TAX_BRACKETS_BY_YEAR[year];
   174	    const a = b.grundfreibetragCents + 25_000_00;
   175	    const bb = b.grundfreibetragCents + 35_000_00;
   176	    const actual = calculateSplittingTax(a, bb, year);
   177	    const half = Math.floor((a + bb) / 2);
   178	    const expected = 2 * calculateIncomeTax(half, year);
   179	    assert.strictEqual(
   180	      actual,
   181	      expected,
   182	      `Year ${year}: Splitting(${a}, ${bb}) should be 2×single(${half})`,
   183	    );
   184	  }
   185	});
