   264	test('calculateIncomeTax: returns 0 for zero or negative zvE', () => {
   265	  assert.strictEqual(calculateIncomeTax(0, 2025), 0);
   266	  assert.strictEqual(calculateIncomeTax(-1, 2025), 0);
