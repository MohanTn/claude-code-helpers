   299	// ─── marginalTaxRate ─────────────────────────────────────────────────────────
   300	
   301	test('marginalTaxRate: 0 at and below Grundfreibetrag, continuous across zone boundaries', () => {
   302	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   303	    const b = TAX_BRACKETS_BY_YEAR[year];
   304	    assert.strictEqual(marginalTaxRate(b.grundfreibetragCents, year), 0);
   305	
   306	    // Just inside zone 2: rate should start near 14%.
   307	    const startOfZone2 = marginalTaxRate(b.grundfreibetragCents + 100, year);
   308	    assert.ok(startOfZone2 > 0.13 && startOfZone2 < 0.15, `Year ${year}: start of zone 2 ~14%, got ${startOfZone2}`);
   309	
   310	    // End of zone 2 / start of zone 3 should both read ~24% (continuous).
   311	    const endOfZone2 = marginalTaxRate(b.zone2UpperCents, year);
   312	    const startOfZone3 = marginalTaxRate(b.zone3LowerCents, year);
   313	    assert.ok(Math.abs(endOfZone2 - startOfZone3) < 0.001, `Year ${year}: zone2/3 boundary should be continuous (${endOfZone2} vs ${startOfZone3})`);
   314	    assert.ok(endOfZone2 > 0.23 && endOfZone2 < 0.25, `Year ${year}: end of zone 2 ~24%, got ${endOfZone2}`);
   315	
   316	    // End of zone 3 should read ~42%, matching zone 4's flat rate.
   317	    const endOfZone3 = marginalTaxRate(b.zone3UpperCents, year);
   318	    assert.ok(Math.abs(endOfZone3 - 0.42) < 0.001, `Year ${year}: end of zone 3 ~42%, got ${endOfZone3}`);
   319	
   320	    assert.strictEqual(marginalTaxRate(b.zone4LowerCents, year), 0.42);
   321	    assert.strictEqual(marginalTaxRate(b.zone5LowerCents, year), 0.45);
   322	  }
   323	});
