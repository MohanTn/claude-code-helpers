     1	// Unit tests for calculateIncomeTax, calculateSplittingTax, and
     2	// calculateSolidaritySurcharge — boundary verification and reference
     3	// value assertions per the implementation plan.
     4	
     5	import { test } from 'node:test';
     6	import * as assert from 'node:assert';
     7	import {
     8	  calculateIncomeTax,
     9	  calculateSplittingTax,
    10	  calculateSolidaritySurcharge,
    11	  marginalTaxRate,
    12	} from './income-tax.js';
    13	import { TAX_BRACKETS_BY_YEAR, SOLI_EXEMPTION_BY_YEAR } from './constants.js';
    14	
    15	// ─── calculateIncomeTax ──────────────────────────────────────────────────────
    16	
    17	test('calculateIncomeTax: tax is 0 at exactly Grundfreibetrag (all years)', () => {
    18	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
    19	    const gf = TAX_BRACKETS_BY_YEAR[year].grundfreibetragCents;
    20	    assert.strictEqual(
    21	      calculateIncomeTax(gf, year),
    22	      0,
    23	      `Year ${year}: tax at Grundfreibetrag (${gf}) should be 0`,
    24	    );
    25	  }
    26	});
    27	
    28	test('calculateIncomeTax: tax is exactly 0 at Grundfreibetrag but positive just above it', () => {
    29	  // "y" (§32a EStG: "ein Zehntausendstel des den Grundfreibetrag
    30	  // übersteigenden Teils...") is a decimal fraction, not floored to an
    31	  // integer — so tax rises smoothly from the very first euro above
    32	  // Grundfreibetrag, not only once a full €10,000 has accrued.
    33	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
    34	    const gf = TAX_BRACKETS_BY_YEAR[year].grundfreibetragCents;
    35	    assert.strictEqual(calculateIncomeTax(gf, year), 0, `Year ${year}: tax at Grundfreibetrag should be 0`);
    36	    // A few hundred euros above Grundfreibetrag should already owe tax.
    37	    const justAboveGF = gf + 500_00;
    38	    if (justAboveGF <= TAX_BRACKETS_BY_YEAR[year].zone2UpperCents) {
    39	      assert.ok(
    40	        calculateIncomeTax(justAboveGF, year) > 0,
    41	        `Year ${year}: tax at GF+€500 should already be > 0 (y is a continuous fraction, not floored)`,
    42	      );
    43	    }
    44	  }
    45	});
    46	
    47	test('calculateIncomeTax: tax increases within a single 10,000-euro y/z window (regression guard)', () => {
    48	  // y and z must be used as continuous decimal fractions, not floored to
    49	  // integers — otherwise tax would be flat across an entire €10,000 window
    50	  // before jumping at the next multiple, which is not how the official
    51	  // formula works. Sample two points 1,000 euros apart that fall in the
    52	  // same old-style "bucket" and assert tax still increases between them.
    53	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
    54	    const b = TAX_BRACKETS_BY_YEAR[year];
    55	    const zone3LowerEur = Math.floor(b.zone3LowerCents / 100);
    56	    const a = (zone3LowerEur + 2_000) * 100;
    57	    const c = (zone3LowerEur + 3_000) * 100; // same 10,000-euro window as `a`
    58	    assert.ok(
    59	      calculateIncomeTax(c, year) > calculateIncomeTax(a, year),
    60	      `Year ${year}: tax at zone3Lower+€3,000 should exceed tax at zone3Lower+€2,000`,
    61	    );
    62	  }
    63	});
    64	
    65	test('calculateIncomeTax: monotonically non-decreasing across all zones', () => {
    66	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
    67	    const b = TAX_BRACKETS_BY_YEAR[year];
    68	    // Sample a few points in each zone. Zone 2 only spans ~5,000-9,000
    69	    // euros in every year covered here (it never reaches a full
    70	    // €10,000), so "grundfreibetrag + €10,000" actually lands above
    71	    // zone2Upper — sort numerically rather than relying on listed order.
    72	    const points = [
    73	      b.grundfreibetragCents,
    74	      b.grundfreibetragCents + 10_000_00,
    75	      b.zone2UpperCents,
    76	      b.zone3LowerCents,
    77	      b.zone3UpperCents - 100,
    78	      b.zone3UpperCents,
    79	      b.zone4LowerCents,
    80	      b.zone4LowerCents + 10_000_00,
    81	      b.zone5LowerCents,
    82	      b.zone5LowerCents + 10_000_00,
    83	    ].filter(p => p > 0).sort((a, c) => a - c);
    84	
    85	    let prev = -1;
    86	    for (const p of points) {
    87	      const tax = calculateIncomeTax(p, year);
    88	      assert.ok(
    89	        tax >= prev,
    90	        `Year ${year}: tax at ${p} (${tax}) should be >= previous (${prev})`,
    91	      );
    92	      prev = tax;
    93	    }
    94	  }
    95	});
    96	
    97	test('calculateIncomeTax: zone 5 marginal rate is 45% (top rate)', () => {
    98	  // In zone 5, tax = 0.45*x - zone5Subtrahend/100, then floored to whole
    99	  // euros — so the return value is always a multiple of 100 cents, and a
   100	  // single 1-euro step can show a 0 or 100-cent diff depending on
   101	  // rounding alignment (never a literal 45). Compare over 100 euros
   102	  // instead, where that ±1-euro rounding noise is negligible.
   103	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   104	    const b = TAX_BRACKETS_BY_YEAR[year];
   105	    const x1 = b.zone5LowerCents + 10_000_00; // well into zone 5
   106	    const x2 = x1 + 100_00; // 100 euros more
   107	    const diff = calculateIncomeTax(x2, year) - calculateIncomeTax(x1, year);
   108	    // Expected: 100 euros * 45% = 4,500 cents, ±100 cents of floor noise.
   109	    assert.ok(
   110	      diff >= 4_400 && diff <= 4_600,
   111	      `Year ${year}: marginal rate in zone 5 should be ~45% (got ${diff} cents per €100)`,
   112	    );
   113	  }
   114	});
