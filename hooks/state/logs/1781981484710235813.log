   269	// ─── Reference-value pinning tests ───────────────────────────────────────────
   270	// These lock down the actual return values for specific inputs.  Any change
   271	// to these numbers signals an intentional (or accidental) formula change and
   272	// must be verified against the official §32a EStG text.
   273	
   274	test('calculateIncomeTax: reference values pin the formula (2025)', () => {
   275	  // €64,520 gross (per plan spec reference point).
   276	  const tax = calculateIncomeTax(6_452_000, 2025);
   277	  // §32a EStG: z is a decimal fraction, not floored to an integer.
   278	  // z = (64520-17443)/10000 = 4.7077
   279	  // tax = (176.64*4.7077+2397)*4.7077+1015.13 = 16214.26... → €16,214.
   280	  assert.strictEqual(tax, 1_621_400);
   281	
   282	  // €12,096 (Grundfreibetrag 2025) → tax = 0.
   283	  assert.strictEqual(calculateIncomeTax(1_209_600, 2025), 0);
   284	
   285	  // €30,000 — well into zone 3, cross-checked manually.
   286	  // x=30000, z = (30000-17443)/10000 = 1.2557 (NOT floored to 1)
   287	  // tax = (176.64*1.2557+2397)*1.2557+1015.13 = 4303.56... → 4303 → 430300 cents.
   288	  assert.strictEqual(calculateIncomeTax(3_000_000, 2025), 430_300);
   289	
   290	  // €80,000 — zone 4, 42% marginal.
   291	  // tax = 0.42*80000 - 10911.92 = 33600.00 - 10911.92 = 22688.08 → 22688 → 2268800 cents.
   292	  assert.strictEqual(calculateIncomeTax(8_000_000, 2025), 2_268_800);
   293	
   294	  // €300,000 — zone 5 (Reichensteuer), 45% marginal.
   295	  // tax = 0.45*300000 - 19246.67 = 135000.00 - 19246.67 = 115753.33 → 115753 → 11575300 cents.
   296	  assert.strictEqual(calculateIncomeTax(30_000_000, 2025), 11_575_300);
   297	});
