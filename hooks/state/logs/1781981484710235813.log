   257	// ─── calculateIncomeTax: error handling ──────────────────────────────────────
   258	
   259	test('calculateIncomeTax: throws on unknown year', () => {
   260	  assert.throws(() => calculateIncomeTax(1_000_00, 1999));
   261	  assert.throws(() => calculateIncomeTax(1_000_00, 2027));
   262	});
