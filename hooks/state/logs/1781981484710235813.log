   187	// ─── calculateSolidaritySurcharge ────────────────────────────────────────────
   188	
   189	test('calculateSolidaritySurcharge: zero below Freigrenze', () => {
   190	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   191	    const soli = SOLI_EXEMPTION_BY_YEAR[year];
   192	    // Single filer: at exactly the single exemption, Soli should be 0.
   193	    assert.strictEqual(
   194	      calculateSolidaritySurcharge(soli.single_cents, year, 'single'),
   195	      0,
   196	      `Year ${year} single: Soli at exemption threshold ${soli.single_cents} should be 0`,
   197	    );
   198	    // Joint: at exactly the joint exemption, Soli should be 0.
   199	    assert.strictEqual(
   200	      calculateSolidaritySurcharge(soli.joint_cents, year, 'joint'),
   201	      0,
   202	      `Year ${year} joint: Soli at exemption threshold ${soli.joint_cents} should be 0`,
   203	    );
   204	    // One euro above → should be non-zero (Milderungszone floors to 0 for sub-cent values,
   205	    // so use 1 euro = 100 cents above).
   206	    const aboveSingle = calculateSolidaritySurcharge(soli.single_cents + 100, year, 'single');
   207	    assert.ok(aboveSingle > 0, `Year ${year} single: Soli 1€ above Freigrenze should be > 0`);
   208	  }
   209	});
   210	
   211	test('calculateSolidaritySurcharge: never exceeds 5.5% of assessed tax', () => {
   212	  // The base rate is 5.5%, but the Milderungszone caps it.  In either case,
   213	  // it should never exceed 5.5% of the assessed tax (the cap formula can't
   214	  // produce a number above 5.5%).
   215	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   216	    const b = TAX_BRACKETS_BY_YEAR[year];
   217	    const income = b.zone5LowerCents + 50_000_00; // well into zone 5
   218	    const tax = calculateIncomeTax(income, year);
   219	    const soli = calculateSolidaritySurcharge(tax, year, 'single');
   220	    const maxSoli = Math.floor(tax * 0.055);
   221	    assert.ok(
   222	      soli <= maxSoli,
   223	      `Year ${year}: Soli ${soli} should be <= 5.5% of tax ${maxSoli}`,
   224	    );
   225	  }
   226	});
   227	
   228	test('calculateSolidaritySurcharge: capped by Milderungszone (not full 5.5%)', () => {
   229	  // Just above the Freigrenze, the Milderungszone should cap Soli at
   230	  // 11.9% of the excess over the exemption, which is much less than 5.5%
   231	  // of the full assessed tax.  Test by passing an assessed tax one euro
   232	  // above the joint Freigrenze — Soli should be at most 12 cents.
   233	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   234	    const soli = SOLI_EXEMPTION_BY_YEAR[year];
   235	    const justAbove = soli.joint_cents + 100; // 1 euro above Freigrenze
   236	    const soliResult = calculateSolidaritySurcharge(justAbove, year, 'joint');
   237	    // Milderungszone cap: 11.9% of (justAbove - exemption) = 11.9% of 100 cents ≈ 11-12 cents.
   238	    assert.ok(
   239	      soliResult <= 12,
   240	      `Year ${year}: Soli 1€ above joint Freigrenze should be ≤12 cents (Milderungszone), got ${soliResult}`,
   241	    );
   242	  }
   243	});
   244	
   245	test('calculateSolidaritySurcharge: throws on unknown year', () => {
   246	  assert.throws(() => calculateSolidaritySurcharge(1_000_00, 1999, 'single'));
   247	  assert.throws(() => calculateSolidaritySurcharge(1_000_00, 2027, 'single'));
   248	});
   249	
   250	test('calculateSolidaritySurcharge: joint exemption is double the single', () => {
   251	  for (const year of [2022, 2023, 2024, 2025, 2026]) {
   252	    const s = SOLI_EXEMPTION_BY_YEAR[year];
   253	    assert.strictEqual(s.joint_cents, s.single_cents * 2, `${year} joint = 2× single`);
   254	  }
   255	});
