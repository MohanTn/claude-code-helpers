using System.Globalization;
using System.Text;
using UglyToad.PdfPig;
using UglyToad.PdfPig.Content;

namespace FinanceAnalyser.Parsers;

/// <summary>
/// Reconstructs `pdftotext -layout`-equivalent text from PdfPig's word/bounding-box
/// model, so the existing regex/line-based bank-statement parsers (ported from the
/// TypeScript implementation) can be reused with minimal changes.
///
/// This is NOT byte-identical to pdftotext's output. It only needs to be
/// regex-pattern-compatible: bank parser regexes split on runs of whitespace
/// (\s+ / \s{2,}) rather than fixed-width column slicing, so a reasonable
/// whitespace reconstruction (proportional to the visual gap between words) is
/// sufficient.
/// </summary>
public static class PdfTextExtractor
{
    // Y-coordinate tolerance (in PDF points) for clustering words into the same
    // visual row. PdfPig's bounding boxes for words on the same printed line
    // typically agree on baseline/top within a point or two; small statement
    // fonts (~7-9pt) mean 2-3pt is enough to merge same-row words without
    // merging adjacent table rows.
    private const double RowYTolerance = 3.0;

    /// <summary>
    /// Extracts text from the PDF at <paramref name="pdfPath"/>, reconstructing
    /// one line per visual row with columns space-aligned (à la `pdftotext -layout`).
    /// Pages are concatenated with a single newline.
    /// </summary>
    public static string ExtractLayoutText(string pdfPath)
    {
        if (!File.Exists(pdfPath))
        {
            throw new FileNotFoundException($"ExtractLayoutText: file not found: {pdfPath}", pdfPath);
        }

        using var document = PdfDocument.Open(pdfPath);
        var pageTexts = new List<string>();

        foreach (var page in document.GetPages())
        {
            pageTexts.Add(ExtractPageLayoutText(page));
        }

        return string.Join("\n", pageTexts);
    }

    private static string ExtractPageLayoutText(Page page)
    {
        // Only consider normal left-to-right horizontal text. Some statements
        // embed vertically-stacked decorative/barcode-like strings (e.g. a
        // column of single characters spelling out an internal reference code)
        // at the same X position repeated down the page; pdftotext -layout
        // does not interleave these into the horizontal table rows, so we
        // exclude anything that isn't Horizontal to avoid corrupting
        // otherwise-clean transaction rows with stray characters.
        var words = page.GetWords()
            .Where(w => w.TextOrientation == TextOrientation.Horizontal)
            .ToList();
        if (words.Count == 0)
        {
            return string.Empty;
        }

        // Estimate a single "character width" unit for the page, used to convert
        // horizontal gaps between words into a number of space characters. This
        // approximates pdftotext -layout's column alignment without requiring a
        // true fixed-width character grid.
        double charWidth = EstimateCharWidth(words);

        // pdftotext -layout normalizes so that the leftmost text actually used on
        // the page starts at column 0 — it does not preserve the page's absolute
        // physical left margin as leading whitespace. Mirror that by using the
        // minimum word-left X on the page (not x=0) as the column-0 baseline.
        double leftMargin = words.Min(w => w.BoundingBox.Left);

        var rows = ClusterIntoRows(words);

        // Estimate the "normal" single-line vertical step (baseline-to-baseline
        // gap for consecutive, non-blank-separated lines), so that larger gaps
        // between rows can be translated into the corresponding number of blank
        // lines — pdftotext -layout represents vertical whitespace this way
        // (e.g. a blank line between table records), but PdfPig's word model has
        // no notion of an "empty line" at all, only the words that exist.
        double lineStep = EstimateLineStep(rows);

        var sb = new StringBuilder();
        double? previousRowY = null;
        foreach (var row in rows)
        {
            double rowY = row.Average(w => w.BoundingBox.Bottom);
            if (previousRowY.HasValue && lineStep > 0)
            {
                double gap = previousRowY.Value - rowY;
                // pdftotext -layout does not scale blank-line count
                // proportionally to the physical vertical gap (a large gap from
                // a section header or table-record separator does not yield
                // multiple consecutive blank lines) — it collapses any gap
                // meaningfully larger than one normal line step down to a
                // single blank line. Mirror that with a fixed threshold rather
                // than a proportional step count.
                if (gap > lineStep * 1.5)
                {
                    sb.Append('\n');
                }
            }

            sb.Append(RenderRow(row, charWidth, leftMargin));
            sb.Append('\n');
            previousRowY = rowY;
        }

        // Trim the single trailing newline added by the loop above; callers join
        // pages with their own separator.
        if (sb.Length > 0 && sb[^1] == '\n')
        {
            sb.Length--;
        }

        return sb.ToString();
    }

    /// <summary>
    /// Groups words into visual rows by clustering on vertical position (using
    /// the bounding box's bottom coordinate), then sorts each row left-to-right.
    /// Rows are returned top-to-bottom (PDF y grows upward, so descending y).
    /// </summary>
    private static List<List<Word>> ClusterIntoRows(List<Word> words)
    {
        // Sort by descending Y (top of page first), then by X for a stable
        // initial ordering before clustering.
        var sorted = words
            .OrderByDescending(w => w.BoundingBox.Bottom)
            .ThenBy(w => w.BoundingBox.Left)
            .ToList();

        var rows = new List<List<Word>>();
        var currentRow = new List<Word> { sorted[0] };
        double currentRowY = sorted[0].BoundingBox.Bottom;

        for (int i = 1; i < sorted.Count; i++)
        {
            var word = sorted[i];
            double y = word.BoundingBox.Bottom;

            if (Math.Abs(y - currentRowY) <= RowYTolerance)
            {
                currentRow.Add(word);
                // Track the running average so the tolerance band doesn't drift
                // across a long row of words with slightly varying baselines.
                currentRowY = currentRow.Average(w => w.BoundingBox.Bottom);
            }
            else
            {
                rows.Add(currentRow);
                currentRow = new List<Word> { word };
                currentRowY = y;
            }
        }

        rows.Add(currentRow);

        // Within each row, sort strictly left-to-right by X0.
        foreach (var row in rows)
        {
            row.Sort((a, b) => a.BoundingBox.Left.CompareTo(b.BoundingBox.Left));
        }

        return rows;
    }

    /// <summary>
    /// Renders a single row of words left-to-right, inserting a number of spaces
    /// between consecutive words proportional to the horizontal gap between them
    /// (estimated in character-width units), with a minimum of one space.
    /// </summary>
    private static string RenderRow(List<Word> row, double charWidth, double leftMargin)
    {
        var sb = new StringBuilder();
        Word? previous = null;

        foreach (var word in row)
        {
            if (previous != null)
            {
                double gap = word.BoundingBox.Left - previous.BoundingBox.Right;
                int spaces = gap > 0 ? Math.Max(1, (int)Math.Round(gap / charWidth)) : 1;
                sb.Append(' ', spaces);
            }
            else
            {
                // Leading indentation: approximate the gap from the page's
                // left margin (the minimum word-left X actually used on the
                // page, not x=0) so columns that start indented relative to
                // other rows (e.g. table cells) still line up reasonably
                // under whitespace-collapsing regexes, while matching
                // pdftotext -layout's behavior of not padding every line
                // with the page's absolute physical margin.
                double gap = word.BoundingBox.Left - leftMargin;
                int leadingSpaces = gap > 0 ? (int)Math.Round(gap / charWidth) : 0;
                sb.Append(' ', Math.Max(0, leadingSpaces));
            }

            sb.Append(word.Text);
            previous = word;
        }

        return sb.ToString();
    }

    /// <summary>
    /// Estimates the typical baseline-to-baseline single-line vertical step for
    /// the page, used to convert larger row-to-row Y gaps into a corresponding
    /// number of blank lines.
    ///
    /// Derived from the MEDIAN row-to-row Y gap on the page (excluding
    /// negligible/zero gaps). Two simpler estimators were tried and rejected
    /// empirically against the real fixture PDFs:
    /// - Median glyph bounding-box height: systematically underestimates real
    ///   line pitch for documents with digit-heavy "words" (short bounding
    ///   boxes) whose actual printed line pitch is 2-3x that, e.g. DATEV
    ///   payslips — this made ordinary same-paragraph row transitions falsely
    ///   exceed the blank-line threshold.
    /// - Minimum row-to-row gap: a single page can mix multiple line pitches
    ///   (e.g. a DATEV payslip's small-font footnote block at ~5pt pitch vs.
    ///   ~10-13pt body text pitch), so the page-wide minimum can be far below
    ///   the body-text pitch, again causing false-positive blank lines in the
    ///   body sections.
    /// The median is a reasonable middle ground for the documents actually
    /// seen in this codebase: on every real fixture (Commerzbank, Wise, Trade
    /// Republic, TF Bank statements; DATEV and Infoniqa payslips) single-line
    /// (non-blank-separated) row transitions are the majority of row-to-row
    /// gaps on the page, even in formats like Trade Republic's 3-line/
    /// 1-blank-line record structure (2 single-line gaps per record vs. 1
    /// blank-line gap), so the median lands within the single-line cluster
    /// rather than the blank-line cluster.
    /// </summary>
    private static double EstimateLineStep(List<List<Word>> rows)
    {
        if (rows.Count < 2)
        {
            return 1.0;
        }

        var gaps = new List<double>();
        double? previousRowY = null;
        foreach (var row in rows)
        {
            double rowY = row.Average(w => w.BoundingBox.Bottom);
            if (previousRowY.HasValue)
            {
                double gap = previousRowY.Value - rowY;
                if (gap > 0.5)
                {
                    gaps.Add(gap);
                }
            }
            previousRowY = rowY;
        }

        if (gaps.Count == 0)
        {
            return 1.0;
        }

        gaps.Sort();
        return gaps[gaps.Count / 2];
    }

    /// <summary>
    /// Estimates a representative single-character width (in PDF points) for the
    /// page, used to convert horizontal pixel gaps into a whitespace-run length.
    /// Computed as the median (word width / character count) across all words
    /// with non-empty text, which is robust to a handful of very narrow/wide
    /// "words" (e.g. punctuation-only tokens).
    /// </summary>
    private static double EstimateCharWidth(List<Word> words)
    {
        var ratios = new List<double>();
        foreach (var word in words)
        {
            var text = word.Text;
            if (string.IsNullOrEmpty(text))
            {
                continue;
            }
            double width = word.BoundingBox.Width;
            if (width <= 0)
            {
                continue;
            }
            ratios.Add(width / text.Length);
        }

        if (ratios.Count == 0)
        {
            // Fallback: a typical 8-9pt monospace-ish character width.
            return 4.0;
        }

        ratios.Sort();
        double median = ratios[ratios.Count / 2];

        // Guard against degenerate (near-zero) estimates which would blow up the
        // gap-to-spaces division into an enormous run of spaces.
        return median > 0.1 ? median : 4.0;
    }
}
===PayslipParser===
using FinanceAnalyser.Core.Models;

namespace FinanceAnalyser.Parsers;

/// <summary>
/// Combined payslip parser entrypoint: sniffs a payslip PDF's format and
/// delegates to the appropriate format-specific parser (DATEV or Infoniqa
/// ONE), or returns a skip result for non-payslip / unrecognized documents.
/// Ported from src/parsers/payslip.ts.
///
/// To avoid reading the same PDF through PdfPig twice, the text is extracted
/// once here via <see cref="PdfTextExtractor.ExtractLayoutText"/>, sniffed
/// against that single read, then passed through to the matching
/// format-specific parser so it does not need to re-derive its own text.
/// </summary>
public static class PayslipParser
{
    private const string MeldebescheinigungSniffString = "Meldebescheinigung zur Sozialversicherung";
    private const string DatevSniffString = "Abrechnung der Brutto/Netto-Bezüge";
    private const string InfoniqaSniffString = "Infoniqa ONE";

    /// <summary>
    /// Sniffs <paramref name="pdfPath"/>'s content and delegates to the
    /// matching format-specific payslip parser:
    ///   1. "Meldebescheinigung zur Sozialversicherung" -&gt; skipped directly
    ///      (not a payslip at all; same skip reason/string the DATEV parser
    ///      itself would produce for this case).
    ///   2. "Abrechnung der Brutto/Netto-Bezüge" -&gt; delegates to
    ///      <see cref="PayslipDatevParser.Parse"/>.
    ///   3. "Infoniqa ONE" -&gt; delegates to
    ///      <see cref="PayslipInfoniqaParser.Parse"/>.
    ///   4. Anything else -&gt; a result with an empty payslip list and
    ///      SkippedReason "Unrecognized payslip format".
    /// </summary>
    public static PayslipParseResult Parse(string pdfPath)
    {
        var text = PdfTextExtractor.ExtractLayoutText(pdfPath);

        if (text.Contains(MeldebescheinigungSniffString, StringComparison.Ordinal))
        {
            return new PayslipParseResult(
                new List<ParsedPayslip>(),
                $"{MeldebescheinigungSniffString} — not a payslip");
        }

        if (text.Contains(DatevSniffString, StringComparison.Ordinal))
        {
            return PayslipDatevParser.Parse(pdfPath, text);
        }

        if (text.Contains(InfoniqaSniffString, StringComparison.Ordinal))
        {
            return PayslipInfoniqaParser.Parse(pdfPath, text);
        }

        return new PayslipParseResult(new List<ParsedPayslip>(), "Unrecognized payslip format");
    }
}
