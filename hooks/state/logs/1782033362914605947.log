     1	using FinanceAnalyser.Core.Models;
     2	
     3	namespace FinanceAnalyser.Data.Tests;
     4	
     5	/// <summary>
     6	/// Ported from src/db/index.test.ts's account-related tests:
     7	/// "getAccountByName / getAllAccounts return seeded accounts".
     8	/// </summary>
     9	public class DbAccountsTests
    10	{
    11	    [Fact]
    12	    public void GetAccountByNameAndGetAllAccounts_ReturnSeededAccounts()
    13	    {
    14	        using var connection = Db.OpenConnection(":memory:");
    15	        Db.Migrate(connection, new List<CategoryRule>());
    16	
    17	        var all = Db.GetAllAccounts(connection);
    18	        Assert.Equal(4, all.Count);
    19	
    20	        var commerzbank = Db.GetAccountByName(connection, "Commerzbank GiroKonto");
    21	        Assert.NotNull(commerzbank);
    22	        Assert.Equal("Commerzbank", commerzbank!.Institution);
    23	        Assert.Equal("asset", commerzbank.Type);
    24	
    25	        var tfBank = Db.GetAccountByName(connection, "TF Bank Mastercard Gold");
    26	        Assert.NotNull(tfBank);
    27	        Assert.Equal(1, tfBank!.IsCreditCard);
    28	
    29	        Assert.Null(Db.GetAccountByName(connection, "Nonexistent Account"));
    30	    }
    31	
    32	    [Fact]
    33	    public void GetAccountById_ReturnsMatchingAccount()
    34	    {
    35	        using var connection = Db.OpenConnection(":memory:");
    36	        Db.Migrate(connection, new List<CategoryRule>());
    37	
    38	        var byName = Db.GetAccountByName(connection, "Wise EUR");
    39	        Assert.NotNull(byName);
    40	
    41	        var byId = Db.GetAccountById(connection, byName!.Id);
    42	        Assert.NotNull(byId);
    43	        Assert.Equal("Wise EUR", byId!.Name);
    44	
    45	        Assert.Null(Db.GetAccountById(connection, 9999));
    46	    }
    47	}
=== DbCategoryRulesTests.cs ===
     1	using FinanceAnalyser.Core.Models;
     2	
     3	namespace FinanceAnalyser.Data.Tests;
     4	
     5	/// <summary>
     6	/// Ported from src/db/index.test.ts's "seedCategoryRulesIfEmpty seeds rules
     7	/// only when table is empty".
     8	/// </summary>
     9	public class DbCategoryRulesTests
    10	{
    11	    [Fact]
    12	    public void SeedCategoryRulesIfEmpty_SeedsOnlyWhenTableEmpty()
    13	    {
    14	        using var connection = Db.OpenConnection(":memory:");
    15	        Db.Migrate(connection, new List<CategoryRule>());
    16	
    17	        var rules = new List<CategoryRule>
    18	        {
    19	            new(null, 10, "description", "contains", "REWE", "Groceries"),
    20	            new(null, 999, "description", "default", null, "Other"),
    21	        };
    22	
    23	        Db.SeedCategoryRulesIfEmpty(connection, rules);
    24	        var stored = Db.GetAllCategoryRules(connection);
    25	        Assert.Equal(2, stored.Count);
    26	        Assert.Equal(10, stored[0].Priority);
    27	        Assert.Equal(999, stored[1].Priority);
    28	
    29	        // Re-running with a different rule set should NOT modify the table
    30	        // (idempotent on non-empty table).
    31	        var otherRules = new List<CategoryRule>
    32	        {
    33	            new(null, 5, "description", "default", null, "Other"),
    34	        };
    35	        Db.SeedCategoryRulesIfEmpty(connection, otherRules);
    36	        stored = Db.GetAllCategoryRules(connection);
    37	        Assert.Equal(2, stored.Count);
    38	    }
    39	}
=== DbTransactionsTests.cs ===
     1	using Dapper;
     2	using FinanceAnalyser.Core.Models;
     3	
     4	namespace FinanceAnalyser.Data.Tests;
     5	
     6	/// <summary>
     7	/// Ported from src/db/index.test.ts's transaction-related tests:
     8	/// "insertTransaction dedups via UNIQUE(source_pdf, source_hash)",
     9	/// "insertTransaction allows same source_hash for a different source_pdf",
    10	/// "getTransactionsForRecategorization / updateTransactionCategory respect is_manual_override".
    11	/// </summary>
    12	public class DbTransactionsTests
    13	{
    14	    private static CategorizedTransaction MakeTxn(
    15	        string? description = null,
    16	        string? sourcePdf = null,
    17	        string? category = null)
    18	    {
    19	        return new CategorizedTransaction(
    20	            Date: "2025-01-15",
    21	            Description: description ?? "Test transaction",
    22	            AmountCents: -1000,
    23	            Currency: "EUR",
    24	            RawText: "15.01.2025 Test transaction -10.00 EUR",
    25	            SourcePdf: sourcePdf ?? "test.pdf",
    26	            Category: category ?? "Other");
    27	    }
    28	
    29	    [Fact]
    30	    public void InsertTransaction_DedupsViaUniqueSourcePdfAndSourceHash()
    31	    {
    32	        using var connection = Db.OpenConnection(":memory:");
    33	        Db.Migrate(connection, new List<CategoryRule>());
    34	        var account = Db.GetAccountByName(connection, "Commerzbank GiroKonto")!;
    35	
    36	        var txn = MakeTxn();
    37	        const string sourceHash = "abc123";
    38	
    39	        var first = Db.InsertTransaction(connection, account.Id, txn, sourceHash);
    40	        Assert.True(first.Inserted);
    41	        Assert.NotNull(first.Id);
    42	
    43	        var second = Db.InsertTransaction(connection, account.Id, txn, sourceHash);
    44	        Assert.False(second.Inserted);
    45	        Assert.Null(second.Id);
    46	
    47	        var count = connection.ExecuteScalar<long>("SELECT COUNT(*) FROM transactions");
    48	        Assert.Equal(1, count);
    49	    }
    50	
    51	    [Fact]
    52	    public void InsertTransaction_AllowsSameSourceHashForDifferentSourcePdf()
    53	    {
    54	        using var connection = Db.OpenConnection(":memory:");
    55	        Db.Migrate(connection, new List<CategoryRule>());
    56	        var account = Db.GetAccountByName(connection, "Commerzbank GiroKonto")!;
    57	
    58	        var t1 = MakeTxn(sourcePdf: "jan.pdf");
    59	        var t2 = MakeTxn(sourcePdf: "feb.pdf");
    60	        const string sourceHash = "samehash";
    61	
    62	        Assert.True(Db.InsertTransaction(connection, account.Id, t1, sourceHash).Inserted);
    63	        Assert.True(Db.InsertTransaction(connection, account.Id, t2, sourceHash).Inserted);
    64	
    65	        var count = connection.ExecuteScalar<long>("SELECT COUNT(*) FROM transactions");
    66	        Assert.Equal(2, count);
    67	    }
    68	
    69	    [Fact]
    70	    public void RecategorizationWorkflow_RespectsIsManualOverride()
    71	    {
    72	        using var connection = Db.OpenConnection(":memory:");
    73	        Db.Migrate(connection, new List<CategoryRule>());
    74	        var account = Db.GetAccountByName(connection, "Commerzbank GiroKonto")!;
    75	
    76	        Db.InsertTransaction(connection, account.Id, MakeTxn(description: "REWE Markt", category: "Groceries"), "hash1");
    77	        Db.InsertTransaction(connection, account.Id, MakeTxn(description: "Some override", category: "Shopping"), "hash2");
    78	
    79	        var rows = Db.GetTransactionsForRecategorization(connection, account.Id);
    80	        Assert.Equal(2, rows.Count);
    81	
    82	        var overrideRow = rows.Single(r => r.Description == "Some override");
    83	        connection.Execute("UPDATE transactions SET is_manual_override = 1 WHERE id = @Id", new { overrideRow.Id });
    84	
    85	        var refreshed = Db.GetTransactionsForRecategorization(connection, account.Id);
    86	        var refreshedOverride = refreshed.Single(r => r.Id == overrideRow.Id);
    87	        Assert.Equal(1, refreshedOverride.IsManualOverride);
    88	
    89	        // UpdateTransactionCategory itself does not check the flag (callers
    90	        // must filter); verify it updates the row regardless.
    91	        var normalRow = refreshed.Single(r => r.Description == "REWE Markt");
    92	        Db.UpdateTransactionCategory(connection, normalRow.Id, "Other");
    93	
    94	        var updatedCategory = connection.ExecuteScalar<string>(
    95	            "SELECT category FROM transactions WHERE id = @Id", new { normalRow.Id });
    96	        Assert.Equal("Other", updatedCategory);
    97	    }
    98	
    99	    [Fact]
   100	    public void GetTransactionsForRecategorization_WithoutAccountId_ReturnsAllAccounts()
   101	    {
   102	        using var connection = Db.OpenConnection(":memory:");
   103	        Db.Migrate(connection, new List<CategoryRule>());
   104	        var commerzbank = Db.GetAccountByName(connection, "Commerzbank GiroKonto")!;
   105	        var wise = Db.GetAccountByName(connection, "Wise EUR")!;
   106	
   107	        Db.InsertTransaction(connection, commerzbank.Id, MakeTxn(), "hashA");
   108	        Db.InsertTransaction(connection, wise.Id, MakeTxn(), "hashB");
   109	
   110	        var rows = Db.GetTransactionsForRecategorization(connection);
   111	        Assert.Equal(2, rows.Count);
   112	    }
   113	}
