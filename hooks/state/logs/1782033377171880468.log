1109:     const existing = db.prepare('SELECT * FROM mortgages WHERE id = ?').get(mortgageId) as any;
1110:     if (!existing) return res.status(404).json({ error: 'not found' });
1111: 
1112:     const { loan_amount_cents, outstanding_balance_cents, balance_as_of, monthly_payment_cents, interest_rate, bank_name } = req.body;
1113: 
1114:     db.prepare(`
