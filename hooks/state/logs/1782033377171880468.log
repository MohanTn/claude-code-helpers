1118:         balance_as_of = ?,
1119:         monthly_payment_cents = ?,
1120:         interest_rate = ?,
1121:         bank_name = ?
1122:       WHERE id = ?
1123:     `).run(
1124:       loan_amount_cents ?? existing.loan_amount_cents,
1125:       outstanding_balance_cents ?? existing.outstanding_balance_cents,
1126:       balance_as_of ?? existing.balance_as_of,
1127:       monthly_payment_cents ?? existing.monthly_payment_cents,
1128:       interest_rate ?? existing.interest_rate,
1129:       bank_name ?? existing.bank_name,
1130:       mortgageId,
