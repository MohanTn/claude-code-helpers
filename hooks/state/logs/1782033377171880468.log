1137:   // ─────────────────────────────────────────
1138:   // INVESTMENT HOLDINGS ENDPOINTS
1139:   // ─────────────────────────────────────────
1140: 
1141:   function enrichHolding(h: any): any {
1142:     const currentValueCents = h.last_price_cents != null
1143:       ? Math.round(h.shares * h.last_price_cents)
1144:       : null;
1145:     const costBasisCents = Math.round(h.shares * h.avg_cost_per_share_cents);
1146:     const unrealizedPlCents = currentValueCents != null ? currentValueCents - costBasisCents : null;
1147:     const unrealizedPlPct = currentValueCents != null && costBasisCents > 0
1148:       ? ((currentValueCents - costBasisCents) / costBasisCents) * 100
1149:       : null;
1150: 
1151:     return {
1152:       ...h,
1153:       current_value_cents: currentValueCents,
1154:       cost_basis_cents: costBasisCents,
1155:       unrealized_pl_cents: unrealizedPlCents,
1156:       unrealized_pl_pct: unrealizedPlPct,
1157:     };
1158:   }
1159: 
1160:   // GET /api/holdings
1161:   app.get('/api/holdings', (_req: Request, res: Response) => {
1162:     const rows = db.prepare('SELECT * FROM holdings ORDER BY symbol').all() as any[];
1163:     return res.json({ holdings: rows.map(enrichHolding) });
1164:   });
1165: 
1166:   // POST /api/holdings
1167:   app.post('/api/holdings', (req: Request, res: Response) => {
1168:     const { symbol, isin, name, shares, avg_cost_per_share_cents, currency = 'EUR' } = req.body;
1169: 
1170:     if (!symbol || shares === undefined || avg_cost_per_share_cents === undefined) {
1171:       return res.status(400).json({ error: 'Missing required fields: symbol, shares, avg_cost_per_share_cents' });
1172:     }
1173: 
1174:     try {
1175:       const result = db.prepare(`
1176:         INSERT INTO holdings (symbol, isin, name, shares, avg_cost_per_share_cents, currency)
1177:         VALUES (?,?,?,?,?,?)
1178:       `).run(symbol, isin ?? null, name ?? null, shares, avg_cost_per_share_cents, currency);
1179: 
1180:       const created = db.prepare('SELECT * FROM holdings WHERE id = ?').get(result.lastInsertRowid) as any;
1181:       return res.status(201).json(enrichHolding(created));
1182:     } catch (err) {
1183:       if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
1184:         return res.status(400).json({ error: `Holding with symbol "${symbol}" already exists. Use PATCH to update.` });
1185:       }
1186:       throw err;
1187:     }
1188:   });
1189: 
1190:   // PATCH /api/holdings/:id
1191:   app.patch('/api/holdings/:id', (req: Request, res: Response) => {
1192:     const holdingId = parseInt(req.params.id, 10);
1193:     const existing = db.prepare('SELECT * FROM holdings WHERE id = ?').get(holdingId) as any;
1194:     if (!existing) return res.status(404).json({ error: 'not found' });
1195: 
1196:     const { symbol, isin, name, shares, avg_cost_per_share_cents, currency } = req.body;
1197: 
1198:     try {
1199:       db.prepare(`
1200:         UPDATE holdings SET symbol=?, isin=?, name=?, shares=?, avg_cost_per_share_cents=?, currency=?
1201:         WHERE id=?
1202:       `).run(
1203:         symbol ?? existing.symbol,
1204:         isin ?? existing.isin,
1205:         name ?? existing.name,
1206:         shares ?? existing.shares,
1207:         avg_cost_per_share_cents ?? existing.avg_cost_per_share_cents,
1208:         currency ?? existing.currency,
1209:         holdingId,
1210:       );
1211:       const updated = db.prepare('SELECT * FROM holdings WHERE id = ?').get(holdingId) as any;
1212:       return res.json(enrichHolding(updated));
1213:     } catch (err) {
1214:       if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {
1215:         return res.status(400).json({ error: 'A holding with that symbol already exists' });
1216:       }
1217:       throw err;
1218:     }
1219:   });
