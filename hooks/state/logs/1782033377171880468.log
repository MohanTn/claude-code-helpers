1100:     );
1101: 
1102:     const created = db.prepare('SELECT * FROM mortgages WHERE id = ?').get(result.lastInsertRowid);
1103:     return res.status(201).json(created);
1104:   });
1105: 
1106:   // PATCH /api/mortgages/:id
