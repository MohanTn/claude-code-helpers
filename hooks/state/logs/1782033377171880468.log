1229:   // POST /api/holdings/refresh-prices  — fetch latest prices from Yahoo Finance
1230:   app.post('/api/holdings/refresh-prices', async (req: Request, res: Response) => {
1231:     const rows = db.prepare("SELECT * FROM holdings WHERE symbol IS NOT NULL AND symbol != ''").all() as any[];
1232: 
1233:     if (rows.length === 0) {
1234:       return res.json({ updated: 0, errors: [] });
1235:     }
1236: 
1237:     let YahooFinance: any;
1238:     try {
1239:       const yf = await import('yahoo-finance2');
1240:       YahooFinance = yf.default;
1241:     } catch {
1242:       return res.status(500).json({ error: 'yahoo-finance2 not available' });
1243:     }
1244: 
1245:     const yf = new YahooFinance({ suppressNotices: ['yahooSurvey'] });
1246: 
1247:     // Resolve a raw ISIN or crypto shortcode to a proper Yahoo Finance ticker.
1248:     // Prefers EUR-denominated exchange listings (.DE > .MI > .PA > first result).
1249:     // For crypto shortcodes (BTC, ETH, etc.) tries {SYM}-EUR first.
1250:     // Returns the resolved ticker, or null on failure.
1251:     async function resolveSymbol(sym: string): Promise<string | null> {
1252:       const ISIN = /^[A-Z]{2}[A-Z0-9]{9}[0-9]$/;
1253:       const CRYPTO = /^[A-Z]{2,6}$/;
1254: 
1255:       if (ISIN.test(sym)) {
1256:         try {
1257:           const res = await yf.search(sym, {}, { validateResult: false });
1258:           const quotes: any[] = (res?.quotes ?? []).filter((q: any) => q.isYahooFinance);
1259:           const pick = quotes.find((q: any) => q.symbol?.endsWith('.DE'))
1260:             ?? quotes.find((q: any) => q.symbol?.endsWith('.MI'))
1261:             ?? quotes.find((q: any) => q.symbol?.endsWith('.PA'))
1262:             ?? quotes.find((q: any) => q.symbol?.endsWith('.AS'))
1263:             ?? quotes[0];
1264:           if (pick?.symbol) return pick.symbol;
1265:         } catch { /* fall through */ }
1266:         // Fallback: direct {ISIN}.DE probe
1267:         try {
1268:           const q = await yf.quote(`${sym}.DE`, {}, { validateResult: false });
1269:           if (q?.regularMarketPrice != null) return `${sym}.DE`;
1270:         } catch { /* ignore */ }
1271:       }
1272: 
1273:       if (CRYPTO.test(sym)) {
1274:         try {
1275:           const q = await yf.quote(`${sym}-EUR`, {}, { validateResult: false });
1276:           if (q?.regularMarketPrice != null) return `${sym}-EUR`;
1277:         } catch { /* ignore */ }
1278:       }
1279: 
1280:       return null;
1281:     }
1282: 
1283:     const errors: string[] = [];
1284:     let updated = 0;
1285:     const today = new Date().toISOString().slice(0, 10);
1286: 
1287:     for (const holding of rows) {
1288:       try {
1289:         // Auto-resolve placeholder ISINs / crypto codes to real Yahoo tickers
1290:         const needsResolution = /^[A-Z]{2}[A-Z0-9]{9}[0-9]$/.test(holding.symbol)
1291:           || /^[A-Z]{2,6}$/.test(holding.symbol);
1292:         let resolvedSymbol: string = holding.symbol;
1293:         if (needsResolution) {
1294:           const found = await resolveSymbol(holding.symbol);
1295:           if (found) resolvedSymbol = found;
1296:         }
1297: 
1298:         const quote = await yf.quote(resolvedSymbol, {}, { validateResult: false });
1299:         const price = quote?.regularMarketPrice;
1300:         if (price == null) {
1301:           errors.push(`${holding.symbol}: no price returned`);
1302:           continue;
1303:         }
1304:         const priceCents = Math.round(price * 100);
1305:         // Persist resolved ticker so future refreshes skip re-resolution
1306:         db.prepare('UPDATE holdings SET last_price_cents=?, last_price_date=?, symbol=? WHERE id=?')
1307:           .run(priceCents, today, resolvedSymbol, holding.id);
1308:         updated++;
1309:       } catch (err) {
1310:         errors.push(`${holding.symbol}: ${err instanceof Error ? err.message : String(err)}`);
1311:       }
1312:     }
1313: 
1314:     return res.json({ updated, errors });
1315:   });
1316: 
