{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "type": "command", "bash": "node \"$HOME/.copilot/scaffold/hooks/session-start.mjs\"", "timeoutSec": 15 }
    ],
    "preToolUse": [
      { "type": "command", "bash": "node \"$HOME/.copilot/scaffold/hooks/pre-tool-use.mjs\"", "timeoutSec": 15 }
    ],
    "postToolUse": [
      { "type": "command", "bash": "node \"$HOME/.copilot/scaffold/hooks/post-tool-use.mjs\"", "timeoutSec": 15 }
    ],
    "agentStop": [
      { "type": "command", "bash": "node \"$HOME/.copilot/scaffold/hooks/agent-stop.mjs\"", "timeoutSec": 15 }
    ]
  }
}
